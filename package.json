{
  "name": "nebulous-nebula",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "prebuild": "npx tsx scripts/check-admin-middleware.ts",
    "build": "astro build",
    "preview": "npm run build && wrangler dev",
    "astro": "astro",
    "generate-types": "wrangler types",
    "deploy": "npm run build && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:build": "npm test && npx astro build",
    "db:migrate": "wrangler d1 execute BLOG_DB --remote --file=migrations/001_init.sql",
    "db:migrate:local": "wrangler d1 execute BLOG_DB --file=migrations/001_init.sql",
    "db:migrate:phase3": "wrangler d1 execute BLOG_DB --remote --file=migrations/002_pipeline.sql",
    "db:migrate:phase3:local": "wrangler d1 execute BLOG_DB --file=migrations/002_pipeline.sql",
    "db:rollback:phase3": "wrangler d1 execute BLOG_DB --remote --file=migrations/002_rollback.sql",
    "db:migrate:phase4": "wrangler d1 execute BLOG_DB --remote --file=migrations/004_humanizer.sql",
    "db:migrate:phase4:local": "wrangler d1 execute BLOG_DB --file=migrations/004_humanizer.sql",
    "db:rollback:phase4": "wrangler d1 execute BLOG_DB --remote --file=migrations/004_rollback.sql",
    "db:seed": "echo 'No seed data for production. Use migrations only.'",
    "blog:validate": "npx tsx scripts/validate-post.ts",
    "blog:generate-types": "wrangler types"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.51.0",
    "@astrojs/cloudflare": "^13.2.1",
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.1.9",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "@vitest/coverage-istanbul": "^3.2.4",
    "@vitest/coverage-v8": "^3.0.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.85.0"
  },
  "overrides": {
    "vite": "^7"
  }
}
