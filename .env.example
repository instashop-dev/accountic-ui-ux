# Environment variables read by the /api/capture Astro server route.
#
# Local dev (full Worker emulation):
#   1. Copy this file to `.dev.vars` (gitignored)
#   2. Fill in the values
#   3. Run: npm run preview        (== `astro build && wrangler dev`)
#
# Production: set the same keys on the Worker:
#   Cloudflare → Workers → <project> → Settings → Variables and Secrets.
#
# Email is sent via the Cloudflare `send_email` binding (Email Routing).
# The recipient must be a verified destination address on the same Cloudflare
# account; the SIGNUP_NOTIFY binding in wrangler.jsonc pins it to info@accountic.in.

# From address — must be on a domain with Email Routing enabled (accountic.in).
# Mailbox does not need to exist; it's only used as the From: header.
SIGNUP_NOTIFY_FROM=notify@accountic.in
