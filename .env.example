# Environment variables read by the /api/capture Astro server route.
#
# Local dev (full Worker emulation):
#   1. Copy this file to `.dev.vars` (gitignored)
#   2. Fill in the values
#   3. Run: npm run preview        (== `astro build && wrangler dev`)
#
# Production: set the same three keys on the Worker:
#   Cloudflare → Workers → <project> → Settings → Variables and Secrets.

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where signup notifications land (comma-separated allowed)
SIGNUP_NOTIFY_TO=pilot@accountic.in

# From address
# Testing:    onboarding@resend.dev (only delivers to your Resend-account email)
# Production: a sender on a Resend-verified domain (e.g. notify@accountic.in)
SIGNUP_NOTIFY_FROM=onboarding@resend.dev
