# Cloudflare Pages Functions read environment from `.dev.vars` (local dev)
# and from the Pages dashboard (production). This file is documentation only.
#
# Local dev:
#   1. Copy this file to `.dev.vars` (gitignored)
#   2. Fill in the values
#   3. Run: npx wrangler pages dev -- npm run dev
#
# Production: set the same three keys in
#   Cloudflare → Pages → <project> → Settings → Environment variables.

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where signup notifications land (comma-separated allowed)
SIGNUP_NOTIFY_TO=pilot@accountic.in

# From address
# Testing:    onboarding@resend.dev
# Production: a sender on a Resend-verified domain
SIGNUP_NOTIFY_FROM=onboarding@resend.dev
