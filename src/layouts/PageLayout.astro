---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	eyebrow?: string;
	heading?: string;
	lede?: string;
	narrow?: boolean;
}

const { title, description, eyebrow, heading, lede, narrow = false } = Astro.props;
const fullTitle = `${title} · ${SITE_TITLE}`;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={fullTitle} description={description} />
	</head>
	<body>
		<Header />

		<main id="main">
			{(eyebrow || heading || lede) && (
				<section class="page-hero">
					<div class={`container ${narrow ? 'page-container--narrow' : ''}`}>
						{eyebrow && <span class="eyebrow">{eyebrow}</span>}
						{heading && <h1>{heading}</h1>}
						{lede && <p class="lede">{lede}</p>}
					</div>
				</section>
			)}

			<section class={`page-body ${narrow ? 'page-body--narrow' : ''}`}>
				<div class={`container ${narrow ? 'page-container--narrow' : ''}`}>
					<slot />
				</div>
			</section>
		</main>

		<Footer />

		<style>
			.page-hero {
				position: relative;
				padding: 9rem 0 3rem;
				background-color: var(--eth-bg);
				background-image:
					linear-gradient(180deg, transparent 0%, transparent 55%, var(--eth-bg) 100%),
					radial-gradient(ellipse 60% 50% at 20% 30%, rgba(253, 230, 138, 0.45) 0%, transparent 100%),
					radial-gradient(ellipse 55% 45% at 85% 20%, rgba(249, 168, 212, 0.35) 0%, transparent 100%),
					radial-gradient(ellipse 50% 40% at 60% 70%, rgba(147, 197, 253, 0.3) 0%, transparent 100%);
			}

			.page-hero h1 {
				margin: 0.75rem 0 1rem;
				max-width: 20ch;
			}

			.page-hero .eyebrow {
				color: var(--eth-accent);
			}

			.page-hero .lede {
				font-size: clamp(1rem, 1.6vw, 1.125rem);
				color: var(--eth-text-secondary);
				max-width: 54ch;
				margin: 0;
			}

			.page-body {
				padding: var(--space-16) 0 var(--space-20);
			}

			.page-body--narrow {
				padding: var(--space-12) 0 var(--space-16);
			}

			.page-container--narrow {
				max-width: 780px;
			}

			@media (max-width: 640px) {
				.page-hero { padding: 7rem 0 2rem; }
			}
		</style>
	</body>
</html>
