---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	eyebrow?: string;
	heading?: string;
	lede?: string;
	narrow?: boolean;
}

const { title, description, eyebrow, heading, lede, narrow = false } = Astro.props;
const fullTitle = `${title} · ${SITE_TITLE}`;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={fullTitle} description={description} />
	</head>
	<body>
		<Header />

		<main id="main">
			{(eyebrow || heading || lede) && (
				<section class="page-hero">
					<div class={`container ${narrow ? 'page-container--narrow' : ''} page-hero-inner`}>
						<div class="page-hero-copy">
							{eyebrow && <span class="eyebrow">{eyebrow}</span>}
							{heading && <h1>{heading}</h1>}
							{lede && <p class="lede">{lede}</p>}
						</div>
						<div class="page-hero-art" aria-hidden="true">
							<slot name="visual" />
						</div>
					</div>
				</section>
			)}

			<section class={`page-body ${narrow ? 'page-body--narrow' : ''}`}>
				<div class={`container ${narrow ? 'page-container--narrow' : ''}`}>
					<slot />
				</div>
			</section>
		</main>

		<Footer />

		<style>
			.page-hero {
				position: relative;
				padding: 7.5rem 0 3rem;
				background-color: var(--color-paper);
				border-bottom: 1px solid var(--color-rule);
			}

			.page-hero-inner {
				display: grid;
				grid-template-columns: 1.5fr 1fr;
				gap: 2.5rem;
				align-items: center;
			}

			.page-hero-art {
				display: flex;
				justify-content: flex-end;
				align-items: center;
				min-height: 180px;
			}

			.page-hero-art:empty { display: none; }

			.page-hero-art :global(svg) {
				max-width: 100%;
				height: auto;
			}

			.page-hero h1 {
				margin: 0.75rem 0 1rem;
				max-width: 20ch;
			}

			@media (max-width: 820px) {
				.page-hero-inner { grid-template-columns: 1fr; }
				.page-hero-art { justify-content: flex-start; min-height: 0; margin-top: 1rem; }
				.page-hero-art :global(svg) { max-width: 220px; }
			}

			.page-hero .lede {
				font-size: clamp(1rem, 1.6vw, 1.125rem);
				color: var(--color-ink-3);
				max-width: 54ch;
				margin: 0;
			}

			.page-body {
				padding: var(--space-3xl) 0 var(--space-4xl);
			}

			.page-body--narrow {
				padding: var(--space-2xl) 0 var(--space-3xl);
			}

			.page-body p {
				max-width: 70ch;
			}

			.page-container--narrow {
				max-width: 780px;
			}

			@media (max-width: 640px) {
				.page-hero { padding: 7rem 0 2rem; }
			}
		</style>
	</body>
</html>
