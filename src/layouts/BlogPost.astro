---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & { slug: string };

const { title, description, pubDate, updatedDate, pillar, author, readTime, tone, slug } = Astro.props;

/* Pick up to 3 related posts: same pillar first, then fill with latest others. */
const allPosts = await getCollection('blog');
const sameP = allPosts
	.filter((p) => p.data.pillar === pillar && p.id !== slug)
	.sort((a, b) => +b.data.pubDate - +a.data.pubDate);
const otherP = allPosts
	.filter((p) => p.data.pillar !== pillar && p.id !== slug)
	.sort((a, b) => +b.data.pubDate - +a.data.pubDate);
const related = [...sameP, ...otherP].slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${title} · ${SITE_TITLE} blog`} description={description} />
	</head>
	<body>
		<Header />

		<main id="main">
			<article class={`post post-tone-${tone}`}>
				<header class="post-header">
					<div class="container post-header-inner">
						<a class="post-back" href="/blog" aria-label="Back to blog index">
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="m15 18-6-6 6-6"></path>
							</svg>
							Blog
						</a>

						<span class={`post-pillar pillar-${tone}`}>{pillar}</span>

						<h1 class="post-title">{title}</h1>
						<p class="post-dek">{description}</p>

						<div class="post-meta">
							<span class="post-author">
								<span class="avatar-dot" aria-hidden="true"></span>
								{author}
							</span>
							<span class="post-sep" aria-hidden="true">·</span>
							<time datetime={pubDate.toISOString()}>
								<FormattedDate date={pubDate} />
							</time>
							<span class="post-sep" aria-hidden="true">·</span>
							<span>{readTime} min read</span>
							{updatedDate && (
								<>
									<span class="post-sep" aria-hidden="true">·</span>
									<span class="updated">Updated <FormattedDate date={updatedDate} /></span>
								</>
							)}
						</div>
					</div>
				</header>

				<div class="container post-body-wrap">
					<div class="post-body">
						<slot />
					</div>
				</div>
			</article>

			{related.length > 0 && (
				<section class="related" aria-labelledby="related-title">
					<div class="container">
						<div class="related-head">
							<span class="section-label">Keep reading</span>
							<h2 id="related-title">Related notes from the firm.</h2>
						</div>
						<ul class="related-grid">
							{related.map((p) => (
								<li>
									<a class={`related-card related-${p.data.tone}`} href={`/blog/${p.id}/`}>
										<span class="related-pillar">{p.data.pillar}</span>
										<h3>{p.data.title}</h3>
										<p>{p.data.description}</p>
										<span class="related-meta">
											<FormattedDate date={p.data.pubDate} /> · {p.data.readTime} min
										</span>
									</a>
								</li>
							))}
						</ul>
					</div>
				</section>
			)}

			<section class="post-cta">
				<div class="container">
					<div class="post-cta-card">
						<span class="eyebrow">Join the May 2026 pilot cohort</span>
						<h2>Draft your next notice with Accountic.</h2>
						<p>
							3 notices on us. No card required. If the verification layer misses a citation,
							the credit returns — automatically.
						</p>
						<div class="cta-actions">
							<a class="btn btn-primary" href="/#cta">Start free trial</a>
							<a class="btn btn-secondary" href="/contact">Book a demo</a>
						</div>
					</div>
				</div>
			</section>
		</main>

		<Footer />

		<style>
			/* ──────────────────────────── Post header + tinted pillar */
			.post-header {
				padding: 8rem 0 3rem;
				position: relative;
				background-color: var(--eth-bg);
			}

			/* Six pastel header gradients, one per tone */
			.post-tone-emerald .post-header {
				background-image:
					linear-gradient(180deg, transparent 0%, transparent 70%, var(--eth-bg) 100%),
					radial-gradient(ellipse 60% 40% at 20% 30%, rgba(167, 243, 208, 0.55) 0%, transparent 100%),
					radial-gradient(ellipse 50% 40% at 85% 40%, rgba(147, 197, 253, 0.28) 0%, transparent 100%);
			}
			.post-tone-amber .post-header {
				background-image:
					linear-gradient(180deg, transparent 0%, transparent 70%, var(--eth-bg) 100%),
					radial-gradient(ellipse 60% 40% at 20% 30%, rgba(253, 230, 138, 0.6) 0%, transparent 100%),
					radial-gradient(ellipse 55% 40% at 85% 35%, rgba(252, 211, 77, 0.3) 0%, transparent 100%);
			}
			.post-tone-rose .post-header {
				background-image:
					linear-gradient(180deg, transparent 0%, transparent 70%, var(--eth-bg) 100%),
					radial-gradient(ellipse 60% 40% at 20% 30%, rgba(249, 168, 212, 0.55) 0%, transparent 100%),
					radial-gradient(ellipse 55% 40% at 85% 35%, rgba(253, 230, 138, 0.3) 0%, transparent 100%);
			}
			.post-tone-sky .post-header {
				background-image:
					linear-gradient(180deg, transparent 0%, transparent 70%, var(--eth-bg) 100%),
					radial-gradient(ellipse 60% 40% at 20% 30%, rgba(147, 197, 253, 0.55) 0%, transparent 100%),
					radial-gradient(ellipse 55% 40% at 85% 35%, rgba(191, 219, 254, 0.4) 0%, transparent 100%);
			}
			.post-tone-violet .post-header {
				background-image:
					linear-gradient(180deg, transparent 0%, transparent 70%, var(--eth-bg) 100%),
					radial-gradient(ellipse 60% 40% at 20% 30%, rgba(221, 214, 254, 0.65) 0%, transparent 100%),
					radial-gradient(ellipse 55% 40% at 85% 35%, rgba(249, 168, 212, 0.3) 0%, transparent 100%);
			}
			.post-tone-stone .post-header {
				background-image:
					linear-gradient(180deg, transparent 0%, transparent 70%, var(--eth-bg) 100%),
					radial-gradient(ellipse 60% 40% at 20% 30%, rgba(226, 232, 240, 0.8) 0%, transparent 100%),
					radial-gradient(ellipse 55% 40% at 85% 35%, rgba(203, 213, 225, 0.4) 0%, transparent 100%);
			}

			.post-header-inner {
				max-width: 780px;
			}

			.post-back {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				color: var(--eth-text-secondary);
				font-size: 0.85rem;
				font-weight: 500;
				margin-bottom: 1.5rem;
				padding: 0.35rem 0.75rem;
				background: rgba(255, 255, 255, 0.5);
				border: 1px solid rgba(255, 255, 255, 0.8);
				border-radius: 9999px;
				backdrop-filter: var(--eth-glass-blur);
				-webkit-backdrop-filter: var(--eth-glass-blur);
			}

			.post-back:hover { color: var(--eth-text); background: rgba(255, 255, 255, 0.7); }

			.post-pillar {
				display: inline-block;
				font-size: 0.72rem;
				font-weight: 600;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				padding: 0.35rem 0.8rem;
				border-radius: 9999px;
				margin-bottom: 1.25rem;
			}

			.pillar-emerald { background: rgba(16, 185, 129, 0.14); color: #065f46; }
			.pillar-amber   { background: rgba(245, 158, 11, 0.16); color: #78350f; }
			.pillar-rose    { background: rgba(244, 114, 182, 0.16); color: #9d174d; }
			.pillar-sky     { background: rgba(59, 130, 246, 0.14); color: #1e40af; }
			.pillar-violet  { background: rgba(139, 92, 246, 0.14); color: #5b21b6; }
			.pillar-stone   { background: rgba(100, 116, 139, 0.14); color: #334155; }

			.post-title {
				font-size: clamp(2rem, 4vw, 3rem);
				font-weight: 600;
				letter-spacing: -0.035em;
				line-height: 1.1;
				margin: 0 0 1rem;
				max-width: 22ch;
			}

			.post-dek {
				font-size: clamp(1rem, 1.6vw, 1.15rem);
				color: var(--eth-text-secondary);
				line-height: 1.65;
				margin: 0 0 1.75rem;
				max-width: 60ch;
			}

			.post-meta {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.5rem;
				font-size: 0.88rem;
				color: var(--eth-text-secondary);
			}

			.post-author {
				display: inline-flex;
				align-items: center;
				gap: 0.45rem;
				color: var(--eth-text);
				font-weight: 500;
			}

			.avatar-dot {
				width: 22px;
				height: 22px;
				border-radius: 9999px;
				background: linear-gradient(135deg, var(--eth-accent), #0ea5e9);
			}

			.post-sep { color: var(--eth-border-light); }
			.updated { font-style: italic; color: var(--eth-text-muted); }

			/* ──────────────────────────── Post body (prose) */
			.post-body-wrap {
				padding: var(--space-12) 0 var(--space-20);
			}

			.post-body {
				max-width: 68ch;
				margin-inline: auto;
				font-size: 1.05rem;
				line-height: 1.75;
				color: var(--eth-text);
			}

			.post-body :global(h2) {
				font-size: clamp(1.35rem, 2.2vw, 1.65rem);
				font-weight: 600;
				letter-spacing: -0.02em;
				margin: 2.25rem 0 0.75rem;
				color: var(--eth-text);
			}

			.post-body :global(h3) {
				font-size: 1.15rem;
				font-weight: 600;
				margin: 1.75rem 0 0.5rem;
				color: var(--eth-text);
			}

			.post-body :global(p) {
				color: var(--eth-text);
				margin: 0 0 1.15rem;
				line-height: 1.75;
			}

			.post-body :global(strong) {
				font-weight: 600;
				color: var(--eth-text);
			}

			.post-body :global(em) { font-style: italic; }

			.post-body :global(a) {
				color: var(--eth-accent);
				font-weight: 500;
				text-decoration: underline;
				text-decoration-color: rgba(16, 185, 129, 0.35);
				text-underline-offset: 3px;
				text-decoration-thickness: 1.5px;
				transition: text-decoration-color 200ms ease, color 200ms ease;
			}

			.post-body :global(a:hover) {
				color: var(--eth-accent-hover);
				text-decoration-color: var(--eth-accent-hover);
			}

			.post-body :global(ul),
			.post-body :global(ol) {
				margin: 0 0 1.25rem;
				padding-left: 1.5rem;
			}

			.post-body :global(li) {
				margin-bottom: 0.5rem;
			}

			.post-body :global(li::marker) {
				color: var(--eth-accent);
			}

			.post-body :global(blockquote) {
				margin: 1.5rem 0;
				padding: 1.25rem 1.5rem;
				background: var(--eth-surface-alt);
				border-left: 3px solid var(--eth-accent);
				border-radius: 0 1rem 1rem 0;
				color: var(--eth-text);
				font-style: normal;
			}

			.post-body :global(blockquote p) {
				margin: 0 0 0.5rem;
			}

			.post-body :global(blockquote p:last-child) { margin: 0; }

			.post-body :global(hr) {
				border: none;
				border-top: 1px dashed var(--eth-border);
				margin: 2.5rem 0;
			}

			.post-body :global(code) {
				font-family: 'ui-monospace', 'SF Mono', Consolas, monospace;
				font-size: 0.88em;
				background: var(--eth-surface-alt);
				padding: 0.15em 0.35em;
				border-radius: 4px;
			}

			.post-body :global(pre) {
				background: var(--eth-text);
				color: #e2e8f0;
				padding: 1.25rem 1.5rem;
				border-radius: 14px;
				overflow-x: auto;
				font-size: 0.9rem;
				line-height: 1.6;
				margin: 1.5rem 0;
			}

			.post-body :global(pre code) {
				background: none;
				padding: 0;
				color: inherit;
			}

			.post-body :global(img) {
				border-radius: 14px;
				margin: 1.5rem 0;
				max-width: 100%;
				height: auto;
			}

			/* ──────────────────────────── Related */
			.related {
				padding: var(--space-12) 0 var(--space-16);
				border-top: 1px solid var(--eth-border);
			}

			.related-head { margin-bottom: var(--space-6); }
			.related-head h2 { margin: 0.5rem 0 0; font-size: clamp(1.35rem, 2.2vw, 1.65rem); }

			.related-grid {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1rem;
			}

			.related-card {
				display: block;
				padding: 1.5rem;
				border-radius: 1.5rem;
				background: var(--eth-surface);
				border: 1px solid var(--eth-border);
				box-shadow: var(--eth-shadow-sm);
				color: var(--eth-text);
				transition: transform 200ms ease, box-shadow 200ms ease;
				position: relative;
				overflow: hidden;
			}

			.related-card::before {
				content: '';
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				height: 4px;
				background: linear-gradient(90deg, transparent, currentColor, transparent);
				opacity: 0.6;
			}

			.related-emerald::before { color: #10b981; }
			.related-amber::before   { color: #f59e0b; }
			.related-rose::before    { color: #f472b6; }
			.related-sky::before     { color: #3b82f6; }
			.related-violet::before  { color: #8b5cf6; }
			.related-stone::before   { color: #64748b; }

			.related-card:hover {
				transform: translateY(-3px);
				box-shadow: var(--eth-shadow);
				color: var(--eth-text);
			}

			.related-pillar {
				display: inline-block;
				font-size: 0.68rem;
				font-weight: 600;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: var(--eth-text-muted);
				margin-bottom: 0.6rem;
			}

			.related-card h3 {
				margin: 0 0 0.5rem;
				font-size: 1.05rem;
				font-weight: 600;
				letter-spacing: -0.015em;
				line-height: 1.3;
			}

			.related-card p {
				margin: 0 0 0.85rem;
				font-size: 0.9rem;
				color: var(--eth-text-secondary);
				line-height: 1.55;
				display: -webkit-box;
				-webkit-line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.related-meta {
				font-size: 0.78rem;
				color: var(--eth-text-muted);
			}

			/* ──────────────────────────── Post CTA */
			.post-cta { padding: 0 0 var(--space-20); }

			.post-cta-card {
				background-color: var(--eth-bg);
				background-image:
					radial-gradient(ellipse 80% 60% at 20% 40%, rgba(253, 230, 138, 0.45) 0%, transparent 100%),
					radial-gradient(ellipse 70% 50% at 80% 60%, rgba(249, 168, 212, 0.35) 0%, transparent 100%),
					radial-gradient(ellipse 60% 50% at 50% 80%, rgba(147, 197, 253, 0.3) 0%, transparent 100%);
				border-radius: var(--eth-layout-radius);
				padding: clamp(2rem, 5vw, 3rem);
				text-align: center;
				border: 1px solid rgba(255, 255, 255, 0.5);
				box-shadow: var(--eth-shadow);
			}

			.post-cta-card .eyebrow { color: var(--eth-accent); }
			.post-cta-card h2 { margin: 0.5rem auto 0.75rem; max-width: 18ch; }
			.post-cta-card p { color: var(--eth-text-secondary); max-width: 50ch; margin: 0 auto 1.5rem; }
			.cta-actions { display: inline-flex; gap: 0.6rem; flex-wrap: wrap; justify-content: center; }

			@media (max-width: 900px) {
				.related-grid { grid-template-columns: 1fr; }
			}
		</style>
	</body>
</html>
