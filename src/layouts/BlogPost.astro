			.post-body :global(p) {
				color: var(--color-ink-2);
				margin: 0 0 1.15rem;
				line-height: 1.75;
			}

			.post-body :global(strong) {
				font-weight: 600;
				color: var(--color-ink);
			}

			.post-body :global(em) { font-style: italic; }

			.post-body :global(a) {
				color: var(--color-accent-2);
				font-weight: 500;
				text-decoration: underline;
				text-decoration-color: var(--color-rule-2);
				text-underline-offset: 3px;
				text-decoration-thickness: 1.5px;
				transition: text-decoration-color 200ms ease, color 200ms ease;
			}

			.post-body :global(a:hover) {
				color: var(--color-accent);
				text-decoration-color: var(--color-accent);
			}

			.post-body :global(ul),
			.post-body :global(ol) {
				margin: 0 0 1.25rem;
				padding-left: 1.5rem;
			}

			.post-body :global(li) {
				margin-bottom: 0.5rem;
			}

			.post-body :global(li::marker) {
				color: var(--color-ink-3);
			}

			.post-body :global(blockquote) {
				margin: 1.5rem 0;
				padding: 1.25rem 1.5rem;
				background: var(--color-paper-2);
				border-left: 3px solid var(--color-accent);
				border-radius: 0 var(--radius-md) var(--radius-md) 0;
				color: var(--color-ink-2);
				font-style: normal;
			}

			.post-body :global(blockquote p) {
				margin: 0 0 0.5rem;
			}

			.post-body :global(blockquote p:last-child) { margin: 0; }

			.post-body :global(hr) {
				border: none;
				border-top: 1px dashed var(--color-rule);
				margin: 2.5rem 0;
			}

			.post-body :global(code) {
				font-family: var(--font-mono);
				font-size: 0.88em;
				background: var(--color-paper-3);
				padding: 0.15em 0.35em;
				border-radius: var(--radius-xs);
			}

			.post-body :global(pre) {
				background: var(--color-graphite);
				color: var(--color-on-dark);
				padding: 1.25rem 1.5rem;
				border-radius: var(--radius-lg);
				overflow-x: auto;
				font-family: var(--font-mono);
				font-size: 0.9rem;
				line-height: 1.6;
				margin: 1.5rem 0;
			}

			.post-body :global(pre code) {
				background: none;
				padding: 0;
				color: inherit;
			}

			.post-body :global(img) {
				border-radius: var(--radius-lg);
				margin: 1.5rem 0;
				max-width: 100%;
				height: auto;
			}

			.post-asof {
				margin: 2.5rem 0 0;
				padding-top: 1.25rem;
				border-top: 1px dashed var(--color-rule);
				color: var(--color-ink-4);
				font-size: 0.85rem;
			}

			/* ──────────────────────────── Related */
			.related {
				padding: clamp(3.5rem, 8vw, var(--space-4xl)) 0;
				border-top: 1px solid var(--color-rule);
