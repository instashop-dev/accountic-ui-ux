				font-style: normal;
				font-size: clamp(1.35rem, 2.2vw, 1.65rem);
				font-weight: 600;
				letter-spacing: var(--tracking-snug);
				margin: 2.25rem 0 var(--space-sm);
				color: var(--color-ink);
			}

			.post-body :global(h3) {
				font-family: var(--font-display);
				font-style: normal;
				font-size: 1.15rem;
				font-weight: 600;
