---
import type { CollectionEntry, MarkdownHeading } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & { slug: string; headings?: MarkdownHeading[] };

const { title, description, pubDate, updatedDate, pillar, author, readTime, tone, slug, headings = [] } =
	Astro.props;

/* Strip "CA " prefix, drop firm suffix, take first + last initial. */
function getInitials(name: string): string {
	const primary = name.replace(/^CA\s+/i, '').split(',')[0].trim();
	const parts = primary.split(/\s+/).filter(Boolean);
	if (parts.length >= 2) return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
	return (parts[0] || 'DC').slice(0, 2).toUpperCase();
}

const initials = getInitials(author);

/* Author role line: everything after the first comma, if any, else 'Accountic'. */
const authorRole = author.includes(',') ? author.split(',').slice(1).join(',').trim() : 'Accountic';
const authorName = author.split(',')[0].trim();

/* Only H2s become mini-TOC entries; guard against empty headings. */
const tocEntries = headings.filter((h) => h.depth === 2);

/* Pick up to 3 related posts: same pillar first, then fill with latest others. */
const allPosts = await getCollection('blog');
const sameP = allPosts
	.filter((p) => p.data.pillar === pillar && p.id !== slug)
	.sort((a, b) => +b.data.pubDate - +a.data.pubDate);
const otherP = allPosts
	.filter((p) => p.data.pillar !== pillar && p.id !== slug)
	.sort((a, b) => +b.data.pubDate - +a.data.pubDate);
const related = [...sameP, ...otherP].slice(0, 3);

/* JSON-LD for AEO/SEO: Article + BreadcrumbList. */
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/og-default.png', Astro.url).toString();

const articleLd = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description,
	datePublished: pubDate.toISOString(),
	dateModified: (updatedDate || pubDate).toISOString(),
	author: {
		'@type': 'Person',
		name: authorName,
		jobTitle: authorRole,
	},
	publisher: {
		'@type': 'Organization',
		name: SITE_TITLE,
		logo: { '@type': 'ImageObject', url: new URL('/favicon.svg', Astro.url).toString() },
	},
	image: ogImage,
	mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL.toString() },
	articleSection: pillar,
};

const breadcrumbLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.url).toString() },
		{ '@type': 'ListItem', position: 2, name: 'Blog', item: new URL('/blog', Astro.url).toString() },
		{ '@type': 'ListItem', position: 3, name: title, item: canonicalURL.toString() },
	],
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${title} · ${SITE_TITLE} blog`} description={description} type="article" />
		<meta property="article:published_time" content={pubDate.toISOString()} />
		{updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
		<meta property="article:author" content={authorName} />
		<meta property="article:section" content={pillar} />
		<script type="application/ld+json" set:html={JSON.stringify(articleLd)} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
	</head>
	<body>
		<Header />

		{/* Thin reading-progress bar pinned to top of viewport */}
		<div class="reading-progress" aria-hidden="true">
			<div class="reading-progress-fill" data-progress-fill></div>
		</div>

		<main id="main">
			<article class={`post post-tone-${tone}`}>
				<header class="post-header">
					<div class="container post-header-inner">

						{/* Top chrome: back pill + share */}
						<div class="post-top-row">
							<a class="post-back" href="/blog" aria-label="Back to blog index">
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<path d="m15 18-6-6 6-6"></path>
								</svg>
								All posts
							</a>

							<div class="post-top-actions">
								<button type="button" class="action-btn" data-copy-link aria-label="Copy link to this article">
									<svg class="action-ico action-ico-default" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M10 13a5 5 0 0 0 7.07 0l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.72"/>
										<path d="M14 11a5 5 0 0 0-7.07 0l-3 3a5 5 0 0 0 7.07 7.07l1.72-1.72"/>
									</svg>
									<svg class="action-ico action-ico-done" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M20 6 9 17l-5-5"/>
									</svg>
									<span class="action-label action-label-default">Copy link</span>
									<span class="action-label action-label-done">Link copied</span>
								</button>

								<a class="action-btn" href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.toString())}`} target="_blank" rel="noopener noreferrer" aria-label="Share on LinkedIn">
									<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
										<path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14zM8 18v-7H5v7h3zM6.5 9.7A1.7 1.7 0 1 0 6.5 6.3a1.7 1.7 0 0 0 0 3.4zM18 18v-3.9c0-2.1-1.1-3.1-2.7-3.1-1.2 0-1.8.7-2.1 1.2V11h-3v7h3v-4c0-.2 0-.4.1-.6.2-.5.6-1 1.3-1 .9 0 1.3.7 1.3 1.7V18h3z"/>
									</svg>
									<span class="action-label">LinkedIn</span>
								</a>
							</div>
						</div>

						{/* Pillar chip */}
						<span class={`post-pillar pillar-${tone}`}>
							<span class={`pillar-dot dot-${tone}`} aria-hidden="true"></span>
							{pillar}
						</span>

						<h1 class="post-title">{title}</h1>
						<p class="post-dek">{description}</p>

						{/* Author / meta card */}
						<div class="post-byline">
							<div class={`byline-avatar avatar-${tone}`} aria-hidden="true">
								<span>{initials}</span>
							</div>
							<div class="byline-main">
								<div class="byline-name">{authorName}</div>
								<div class="byline-role">{authorRole}</div>
							</div>
							<div class="byline-sep" aria-hidden="true"></div>
							<dl class="byline-meta">
								<div class="byline-meta-item">
									<dt>Published</dt>
									<dd>
										<time datetime={pubDate.toISOString()}>
											<FormattedDate date={pubDate} />
										</time>
									</dd>
								</div>
								<div class="byline-meta-item">
									<dt>Read time</dt>
									<dd>{readTime} min</dd>
								</div>
								{updatedDate && (
									<div class="byline-meta-item byline-meta-updated">
										<dt>Updated</dt>
										<dd>
											<time datetime={updatedDate.toISOString()}>
												<FormattedDate date={updatedDate} />
											</time>
										</dd>
									</div>
								)}
							</dl>
						</div>

						{/* Auto in-article TOC — only when there are 2+ H2s */}
						{tocEntries.length > 1 && (
							<details class="post-toc" open>
								<summary class="post-toc-summary">
									<span class="toc-label">
										<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
											<line x1="8" y1="6" x2="21" y2="6"/>
											<line x1="8" y1="12" x2="21" y2="12"/>
											<line x1="8" y1="18" x2="21" y2="18"/>
											<line x1="3" y1="6" x2="3.01" y2="6"/>
											<line x1="3" y1="12" x2="3.01" y2="12"/>
											<line x1="3" y1="18" x2="3.01" y2="18"/>
										</svg>
										In this article
										<span class="toc-count">{tocEntries.length}</span>
									</span>
									<svg class="toc-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<polyline points="6 9 12 15 18 9"></polyline>
									</svg>
								</summary>
								<ol class="post-toc-list">
									{tocEntries.map((h, i) => (
										<li>
											<a href={`#${h.slug}`}>
												<span class="toc-num">{String(i + 1).padStart(2, '0')}</span>
												<span class="toc-text">{h.text}</span>
											</a>
										</li>
									))}
								</ol>
							</details>
						)}
					</div>
				</header>

				<div class="container post-body-wrap">
					<div class="post-body">
						<slot />
						{(() => {
						const d = updatedDate || pubDate;
						const formatted = d.toLocaleDateString('en-us', { year: 'numeric', month: 'short', day: 'numeric' });
						return (
							<p class="post-asof">
								<em>As of <time datetime={d.toISOString()}>{formatted}</time>.</em>
							</p>
						);
					})()}
					</div>
				</div>
			</article>

			{related.length > 0 && (
				<section class="related" aria-labelledby="related-title">
					<div class="container">
						<div class="related-head">
							<span class="section-label">Keep reading</span>
							<h2 id="related-title">Related notes from the firm.</h2>
						</div>
						<ul class="related-grid">
							{related.map((p) => (
								<li>
									<a class={`related-card related-${p.data.tone}`} href={`/blog/${p.id}/`}>
										<span class="related-pillar">{p.data.pillar}</span>
										<h3>{p.data.title}</h3>
										<p>{p.data.description}</p>
										<span class="related-meta">
											<FormattedDate date={p.data.pubDate} /> · {p.data.readTime} min
										</span>
									</a>
								</li>
							))}
						</ul>
					</div>
				</section>
			)}

			<section class="post-cta">
				<div class="container">
					<div class="post-cta-card">
						<span class="eyebrow">Join the May 2026 pilot cohort</span>
						<h2>Draft your next notice with Accountic.</h2>
						<p>
							3 notices on us. No card required. If the verification layer misses a citation,
							the credit returns — automatically.
						</p>
						<div class="cta-actions">
							<a class="btn btn-primary" href="/#cta">Start free trial</a>
							<a class="btn btn-secondary" href="/contact">Book a demo</a>
						</div>
					</div>
				</div>
			</section>
		</main>

		<Footer />

		<style>
			/* ──────────────────────────── Post header + pillar */
			.post-header {
				padding: var(--space-5xl) 0 var(--space-2xl);
				position: relative;
				background: var(--color-paper);
				border-bottom: 1px solid var(--color-rule);
			}

			.post-header-inner {
				max-width: 780px;
			}

			/* Reading progress bar */
			.reading-progress {
				position: fixed;
				top: 0;
				left: 0;
				right: 0;
				height: 3px;
				background: transparent;
				z-index: 100;
				pointer-events: none;
			}

			.reading-progress-fill {
				height: 100%;
				width: 0;
				background: var(--color-accent);
			}

			/* Top row: back link on the left, share actions on the right */
			.post-top-row {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: var(--space-sm);
				margin-bottom: var(--space-xl);
				flex-wrap: wrap;
			}

			.post-back {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				color: var(--color-ink-3);
				font-family: var(--font-mono);
				font-size: 0.78rem;
				letter-spacing: var(--tracking-label);
				min-height: 44px;
				padding: var(--space-xs) 0.9rem;
				background: var(--color-paper);
				border: 1px solid var(--color-rule);
				border-radius: var(--radius-sm);
				transition: color 200ms ease, border-color 200ms ease, transform 200ms ease;
			}

			.post-back:hover {
				color: var(--color-ink);
				border-color: var(--color-rule-2);
				transform: translateX(-2px);
			}

			.post-top-actions { display: flex; gap: 0.4rem; flex-wrap: wrap; }

			.action-btn {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				min-height: 44px;
				padding: var(--space-xs) 0.85rem;
				background: var(--color-paper);
				border: 1px solid var(--color-rule);
				border-radius: var(--radius-sm);
				color: var(--color-ink-3);
				font-family: var(--font-mono);
				font-size: 0.76rem;
				letter-spacing: var(--tracking-label);
				cursor: pointer;
				transition: color 200ms ease, border-color 200ms ease;
				text-decoration: none;
			}

			.action-btn:hover {
				border-color: var(--color-rule-2);
				color: var(--color-ink);
			}

			.action-btn.is-done {
				background: var(--color-accent-soft);
				color: var(--color-accent-2);
				border-color: var(--color-accent);
			}

			.action-ico-done,
			.action-label-done { display: none; }
			.action-btn.is-done .action-ico-default,
			.action-btn.is-done .action-label-default { display: none; }
			.action-btn.is-done .action-ico-done,
			.action-btn.is-done .action-label-done { display: inline-flex; }

			/* Pillar chip (neutral mono label + accent tick) */
			.post-pillar {
				display: inline-flex;
				align-items: center;
				gap: 0.45rem;
				font-family: var(--font-mono);
				font-size: var(--text-xs);
				font-weight: 500;
				letter-spacing: var(--tracking-label);
				text-transform: uppercase;
				color: var(--color-ink-4);
				padding: 0.4rem 0.85rem;
				border-radius: var(--radius-sm);
				margin-bottom: 1.25rem;
				background: var(--color-paper-2);
				border: 1px solid var(--color-rule);
			}

			.pillar-emerald,
			.pillar-amber,
			.pillar-rose,
			.pillar-sky,
			.pillar-violet,
			.pillar-stone { background: var(--color-paper-2); color: var(--color-ink-4); border-color: var(--color-rule); }

			.pillar-dot {
				width: 6px;
				height: 6px;
				border-radius: var(--radius-2xs);
				display: inline-block;
			}

			.dot-emerald,
			.dot-amber,
			.dot-rose,
			.dot-sky,
			.dot-violet,
			.dot-stone { background: var(--color-accent); }

			.post-title {
				font-family: var(--font-display);
				font-style: normal;
				font-size: clamp(2rem, 4vw, 3rem);
				font-weight: 600;
				letter-spacing: var(--tracking-tight);
				line-height: 1.1;
				margin: 0 0 var(--space-md);
				max-width: 22ch;
			}

			.post-dek {
				font-size: clamp(1.05rem, 1.6vw, 1.2rem);
				color: var(--color-ink-3);
				line-height: 1.65;
				margin: 0 0 var(--space-xl);
				max-width: 60ch;
			}

			/* Byline card */
			.post-byline {
				display: grid;
				grid-template-columns: auto 1fr auto auto;
				align-items: center;
				gap: var(--space-md);
				padding: var(--space-md) 1.25rem;
				background: var(--color-paper-2);
				border: 1px solid var(--color-rule);
				border-radius: var(--radius-lg);
				margin: 0 0 1.25rem;
			}

			.byline-avatar {
				width: 40px;
				height: 40px;
				border-radius: var(--radius-pill);
				display: inline-flex;
				align-items: center;
				justify-content: center;
				font-family: var(--font-mono);
				font-weight: 600;
				font-size: 0.82rem;
				color: var(--color-ink);
				letter-spacing: 0.02em;
				background: var(--color-paper-3);
				border: 1px solid var(--color-rule);
			}

			.avatar-emerald,
			.avatar-amber,
			.avatar-rose,
			.avatar-sky,
			.avatar-violet,
			.avatar-stone { background: var(--color-paper-3); }

			.byline-main { min-width: 0; }

			.byline-name {
				font-family: var(--font-display);
				font-size: 0.95rem;
				font-weight: 600;
				color: var(--color-ink);
				line-height: 1.3;
			}

			.byline-role {
				font-family: var(--font-mono);
				font-size: var(--text-xs);
				letter-spacing: var(--tracking-label);
				color: var(--color-ink-4);
				line-height: 1.3;
				margin-top: 2px;
			}

			.byline-sep {
				width: 1px;
				align-self: stretch;
				background: var(--color-rule);
				margin: 0.1rem 0;
			}

			.byline-meta {
				display: flex;
				align-items: center;
				gap: 1.25rem;
				margin: 0;
				font-size: 0.8rem;
			}

			.byline-meta-item { display: flex; flex-direction: column; gap: 1px; }

			.byline-meta dt {
				font-family: var(--font-mono);
				font-size: var(--text-2xs);
				font-weight: 500;
				letter-spacing: var(--tracking-label);
				text-transform: uppercase;
				color: var(--color-ink-4);
				margin: 0;
				line-height: 1.2;
			}

			.byline-meta dd {
				margin: 0;
				font-family: var(--font-mono);
				letter-spacing: var(--tracking-label);
				color: var(--color-ink-4);
				font-size: var(--text-sm2);
				font-weight: 500;
				font-variant-numeric: tabular-nums;
				line-height: 1.3;
			}

			.byline-meta-updated dd { color: var(--color-accent-2); }

			/* In-article TOC */
			.post-toc {
				margin-top: 0.75rem;
				background: var(--color-paper);
				border: 1px solid var(--color-rule);
				border-radius: var(--radius-lg);
				overflow: hidden;
			}

			.post-toc-summary {
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 0.9rem 1.25rem;
				cursor: pointer;
				list-style: none;
				user-select: none;
			}

			.post-toc-summary::-webkit-details-marker { display: none; }

			.toc-label {
				display: inline-flex;
				align-items: center;
				gap: 0.55rem;
				font-family: var(--font-mono);
				font-size: var(--text-xs);
				font-weight: 500;
				letter-spacing: var(--tracking-label);
				text-transform: uppercase;
				color: var(--color-ink-4);
			}

			.toc-label svg { color: var(--color-ink-4); }

			.toc-count {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				min-width: 20px;
				padding: 0 0.4rem;
				height: 20px;
				border-radius: var(--radius-pill);
				background: var(--color-paper-3);
				color: var(--color-ink-4);
				font-family: var(--font-mono);
				font-size: var(--text-xs);
				font-variant-numeric: tabular-nums;
				font-weight: 500;
			}

			.toc-chevron {
				color: var(--color-ink-4);
				transition: transform 240ms ease;
			}

			.post-toc[open] .toc-chevron { transform: rotate(180deg); }

			.post-toc-list {
				list-style: none;
				padding: 0.25rem 0.5rem 0.75rem;
				margin: 0;
				border-top: 1px solid var(--color-rule);
				counter-reset: none;
				display: grid;
				gap: 2px;
			}

			.post-toc-list li { margin: 0; }

			.post-toc-list a {
				display: grid;
				grid-template-columns: auto 1fr;
				align-items: baseline;
				gap: 0.75rem;
				padding: 0.6rem 0.75rem;
				border-radius: var(--radius-sm);
				color: var(--color-ink);
				font-size: 0.92rem;
				line-height: 1.45;
				text-decoration: none;
				transition: background 180ms ease, color 180ms ease;
			}

			.post-toc-list a:hover {
				background: var(--color-paper-2);
				color: var(--color-accent-2);
			}

			.toc-num {
				font-family: var(--font-mono);
				font-size: var(--text-xs);
				font-weight: 500;
				color: var(--color-ink-4);
				letter-spacing: var(--tracking-label);
				min-width: 1.8em;
			}

			.toc-text { color: inherit; }

			.post-toc-list a:hover .toc-num { color: var(--color-accent-2); }

			@media (max-width: 640px) {
				.post-byline {
					grid-template-columns: auto 1fr;
					gap: 0.85rem;
				}
				.byline-sep { display: none; }
				.byline-meta {
					grid-column: 1 / -1;
					padding-top: 0.85rem;
					margin-top: 0.15rem;
					border-top: 1px dashed var(--color-rule);
					gap: 1rem;
				}
				.post-top-row { margin-bottom: var(--space-lg); }
				.post-top-actions .action-label { display: none; }
				.action-btn { padding: var(--space-xs); width: 44px; height: 44px; justify-content: center; }
