			.related-grid {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 1rem;
			}

			.related-card {
				display: block;
				padding: 1.5rem;
				border-radius: var(--radius-lg);
				background: var(--color-paper);
				border: 1px solid var(--color-rule);
				color: var(--color-ink);
				transition: border-color 200ms ease;
				position: relative;
				overflow: hidden;
			}

			.related-emerald,
			.related-amber,
			.related-rose,
			.related-sky,
			.related-violet,
			.related-stone { color: var(--color-ink); }

			.related-card:hover {
				border-color: var(--color-accent);
				color: var(--color-ink);
			}

			.related-pillar {
				display: inline-block;
				font-family: var(--font-mono);
				font-size: var(--text-xs);
				font-weight: 500;
				letter-spacing: var(--tracking-label);
				text-transform: uppercase;
				color: var(--color-ink-4);
				margin-bottom: 0.6rem;
			}

			.related-card h3 {
				font-family: var(--font-display);
				font-style: normal;
				margin: 0 0 0.5rem;
				font-size: 1.05rem;
				font-weight: 600;
				letter-spacing: -0.015em;
				line-height: 1.3;
			}

			.related-card p {
				margin: 0 0 0.85rem;
				font-size: var(--text-body);
				color: var(--color-ink-3);
				line-height: 1.55;
				display: -webkit-box;
				-webkit-line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.related-meta {
				font-family: var(--font-mono);
				font-size: var(--text-xs);
				letter-spacing: var(--tracking-label);
				color: var(--color-ink-4);
			}

			/* ──────────────────────────── Post CTA */
			.post-cta { padding: 0 0 clamp(3.5rem, 8vw, var(--space-4xl)); }

			.post-cta-card {
				background: var(--color-paper-2);
				border-radius: var(--radius-lg);
				padding: clamp(2rem, 5vw, 3rem);
				text-align: center;
				border: 1px solid var(--color-rule);
			}

			.post-cta-card .eyebrow { color: var(--color-ink-4); }
			.post-cta-card h2 { margin: 0.5rem auto 0.75rem; max-width: 18ch; }
			.post-cta-card p { color: var(--color-ink-3); max-width: 50ch; margin: 0 auto 1.5rem; }
			.cta-actions { display: inline-flex; gap: 0.6rem; flex-wrap: wrap; justify-content: center; }

			@media (max-width: 900px) {
				.related-grid { grid-template-columns: 1fr; }
			}
		</style>

		<script is:inline>
			(function () {
				/* Reading progress bar — tracks article scroll only, not header. */
				const fill = document.querySelector('[data-progress-fill]');
				const article = document.querySelector('.post');
				if (fill && article) {
					let ticking = false;
					function update() {
						const rect = article.getBoundingClientRect();
						const viewportH = window.innerHeight;
						const total = rect.height - viewportH;
						const scrolled = Math.min(Math.max(-rect.top, 0), Math.max(total, 0));
						const pct = total > 0 ? (scrolled / total) * 100 : 0;
						fill.style.width = pct + '%';
						ticking = false;
					}
					window.addEventListener(
						'scroll',
						function () {
							if (!ticking) {
								window.requestAnimationFrame(update);
								ticking = true;
							}
						},
						{ passive: true }
					);
					window.addEventListener('resize', update, { passive: true });
					update();
				}

				/* Copy link to clipboard with 1.8s "Link copied" state. */
				const copyBtn = document.querySelector('[data-copy-link]');
				if (copyBtn && navigator.clipboard) {
					copyBtn.addEventListener('click', function () {
						navigator.clipboard
							.writeText(location.href.split('#')[0])
							.then(function () {
								copyBtn.classList.add('is-done');
								copyBtn.setAttribute('aria-label', 'Link copied');
								setTimeout(function () {
									copyBtn.classList.remove('is-done');
									copyBtn.setAttribute('aria-label', 'Copy link to this article');
								}, 1800);
							})
							.catch(function () {});
					});
				}
			})();
		</script>
	</body>
</html>
