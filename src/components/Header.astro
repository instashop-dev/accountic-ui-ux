---
import { SITE_TITLE } from '../consts';

// ⌘K palette destinations — all real, existing routes/anchors.
const paletteNav = [
	{ label: 'Modules', href: '/#modules' },
	{ label: 'How it works', href: '/#how-it-works' },
	{ label: 'Why Accountic', href: '/#why-accountic' },
	{ label: 'Platform', href: '/#platform' },
	{ label: 'Pricing', href: '/#pricing' },
	{ label: 'Blog', href: '/blog' },
	{ label: 'Contact sales', href: '/contact' },
	{ label: 'Security & trust', href: '/security' },
];
const paletteActions = [
	{ label: 'Start free — ₹1,000 credits', href: 'https://app.accountic.in/signup' },
];
---

<header class="nav" id="site-nav">
	<div class="nav-inner">
		<div class="nav-left">
			<a href="/" class="brand" aria-label={`${SITE_TITLE} — home`}>
				<span class="brand-mark" aria-hidden="true">
					<svg viewBox="0 0 32 32" width="24" height="24" xmlns="http://www.w3.org/2000/svg">
						<rect class="bm-bg" x="0" y="0" width="32" height="32" rx="6" />
						<g class="bm-fg" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round" fill="none">
							<path d="M7 24.5 L16 7 L25 24.5" />
							<path d="M11 18 L21 18" />
						</g>
					</svg>
				</span>
				<span class="brand-name">{SITE_TITLE}</span>
			</a>

			<nav class="nav-links" aria-label="Primary">
				<a href="/#modules">Modules</a>
				<a href="/#how-it-works">How it works</a>
				<a href="/#pricing">Pricing</a>
			</nav>
		</div>

		<div class="nav-right">
			<button type="button" class="cmdk-trigger" id="cmdk-open" aria-haspopup="dialog" aria-expanded="false" aria-controls="cmdk">
				<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
				<span class="cmdk-trigger-label">Search</span>
				<kbd class="cmdk-kbd" aria-hidden="true">⌘K</kbd>
			</button>
			<a class="btn-primary" href="https://app.accountic.in/signup">Start free</a>
		</div>
	</div>
</header>

{/* ⌘K command palette — opens on click and ⌘K / Ctrl+K */}
<div class="cmdk-backdrop" id="cmdk" role="dialog" aria-modal="true" aria-label="Command palette — search Accountic" hidden>
	<div class="cmdk-panel" role="document">
		<div class="cmdk-search">
			<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
			<input type="text" id="cmdk-input" class="cmdk-input" placeholder="Search modules, pages, actions…" autocomplete="off" spellcheck="false" aria-label="Search" aria-controls="cmdk-list" />
			<kbd class="cmdk-esc" aria-hidden="true">ESC</kbd>
		</div>
		<div class="cmdk-list" id="cmdk-list" role="listbox" aria-label="Results">
			<p class="cmdk-group">Navigate</p>
			{paletteNav.map((item) => (
				<a class="cmdk-item" role="option" href={item.href} data-label={item.label}>
					<span>{item.label}</span>
					<svg class="cmdk-item-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
				</a>
			))}
			<p class="cmdk-group">Get started</p>
			{paletteActions.map((item) => (
				<a class="cmdk-item cmdk-item--action" role="option" href={item.href} data-label={item.label}>
					<span>{item.label}</span>
					<svg class="cmdk-item-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
				</a>
			))}
			<p class="cmdk-empty" id="cmdk-empty" hidden>No matches.</p>
		</div>
	</div>
</div>

<style>
	.nav {
		position: sticky;
		top: 0;
		z-index: 50;
		background: color-mix(in oklab, var(--color-paper) 93%, transparent);
		border-bottom: 1px solid var(--color-rule);
		backdrop-filter: blur(10px) saturate(1.1);
		-webkit-backdrop-filter: blur(10px) saturate(1.1);
	}

	.nav-inner {
		max-width: var(--wrap);
		margin-inline: auto;
		height: 60px;
		padding-inline: clamp(1rem, 4vw, 1.5rem);
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-lg);
	}

	.nav-left { display: flex; align-items: center; gap: var(--space-xl); min-width: 0; }

	.brand {
		display: inline-flex;
		align-items: center;
		gap: var(--space-xs);
		color: var(--color-ink);
		font-family: var(--font-display);
		font-weight: 600;
		font-size: 1.05rem;
		letter-spacing: -0.02em;
		white-space: nowrap;
	}

	.brand-mark { display: inline-flex; color: var(--color-accent); }
	.brand-mark .bm-bg { fill: currentColor; }
	.brand-mark .bm-fg { stroke: var(--color-accent-ink); }

	.nav-links { display: flex; align-items: center; gap: var(--space-lg); }

	.nav-links a {
		position: relative;
		color: var(--color-ink-3);
		font-size: var(--text-sm2);
		font-weight: 500;
		padding-block: 0.5rem;
		white-space: nowrap;
		transition: color var(--dur-1) var(--ease-out);
	}

	.nav-links a::after {
		content: '';
		position: absolute;
		left: 0;
		bottom: 0.15rem;
		width: 100%;
		height: 1.5px;
		background: var(--color-accent);
		transform: scaleX(0);
		transform-origin: left;
		transition: transform var(--dur-2) var(--ease-out);
	}

	.nav-links a:hover { color: var(--color-ink); }
	.nav-links a:hover::after { transform: scaleX(1); }

	.nav-right { display: flex; align-items: center; gap: var(--space-sm); }

	.cmdk-trigger {
		display: inline-flex;
		align-items: center;
		gap: var(--space-xs);
		height: 38px;
		padding-inline: 0.7rem;
		background: var(--color-paper);
		border: 1px solid var(--color-border-control);
		border-radius: var(--radius-sm);
		color: var(--color-ink-3);
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		cursor: pointer;
		transition: border-color var(--dur-1) var(--ease-out), color var(--dur-1) var(--ease-out);
	}

	.cmdk-trigger:hover { border-color: var(--color-accent); color: var(--color-ink); }
	.cmdk-trigger-label { letter-spacing: 0.02em; }

	.cmdk-kbd,
	.cmdk-esc {
		font-family: var(--font-mono);
		font-size: 0.66rem;
		color: var(--color-ink-4);
		border: 1px solid var(--color-rule-2);
		border-radius: var(--radius-xs);
		padding: 0.1rem 0.3rem;
		line-height: 1;
	}

	.btn-primary {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		height: 38px;
		padding-inline: 1rem;
		background: var(--color-accent-2);
		color: var(--color-accent-ink);
		font-family: var(--font-display);
		font-size: var(--text-sm2);
		font-weight: 600;
		letter-spacing: var(--tracking-snug);
		border-radius: var(--radius-sm);
		white-space: nowrap;
		transition: background-color var(--dur-1) var(--ease-out);
	}

	.btn-primary:hover { background: var(--color-accent-3); }

	.nav :focus-visible,
	.cmdk-backdrop :focus-visible {
		outline: 2px solid var(--color-focus);
		outline-offset: 2px;
		border-radius: var(--radius-xs);
	}

	/* ── ⌘K command palette ── */
	.cmdk-backdrop {
		position: fixed;
		inset: 0;
		z-index: 100;
		display: flex;
		justify-content: center;
		align-items: flex-start;
		padding: clamp(1rem, 12vh, 8rem) 1rem 1rem;
		background: color-mix(in oklab, var(--color-graphite) 42%, transparent);
		backdrop-filter: blur(4px);
		-webkit-backdrop-filter: blur(4px);
		opacity: 0;
		transition: opacity var(--dur-2) var(--ease-out);
	}

	.cmdk-backdrop.is-open { opacity: 1; }
	.cmdk-backdrop[hidden] { display: none; }

	.cmdk-panel {
		width: 100%;
		max-width: 560px;
		background: var(--color-paper);
		border: 1px solid var(--color-rule-2);
		border-radius: var(--radius-lg);
		box-shadow: 0 24px 60px -20px oklch(24% 0.02 258 / 0.35);
		overflow: hidden;
		opacity: 0;
		transform: translateY(-6px) scale(0.98);
		transform-origin: top center;
		transition: opacity var(--dur-2) var(--ease-out), transform var(--dur-2) var(--ease-out);
	}

	.cmdk-backdrop.is-open .cmdk-panel { opacity: 1; transform: none; }

	.cmdk-search {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
		padding: 0.9rem 1rem;
		border-bottom: 1px solid var(--color-rule);
		color: var(--color-ink-4);
	}

	.cmdk-input {
		flex: 1;
		min-width: 0;
		border: none;
		background: transparent;
		font-family: var(--font-sans);
		font-size: var(--text-base);
		color: var(--color-ink);
	}

	.cmdk-input:focus { outline: none; }
	.cmdk-input::placeholder { color: var(--color-ink-4); }

	.cmdk-list { max-height: min(52vh, 420px); overflow-y: auto; padding: var(--space-xs); }

	.cmdk-group {
		margin: 0.6rem 0.75rem 0.3rem;
		font-family: var(--font-mono);
		font-size: 0.66rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-ink-4);
	}

	.cmdk-item {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-sm);
		padding: 0.7rem 0.75rem;
		border-radius: var(--radius-sm);
		color: var(--color-ink-2);
		font-size: var(--text-sm2);
		font-weight: 500;
	}

	.cmdk-item-arrow { color: var(--color-ink-4); flex-shrink: 0; opacity: 0; transition: opacity var(--dur-1) var(--ease-out); }
	.cmdk-item--action { color: var(--color-accent-2); font-weight: 600; }

	.cmdk-item:hover,
	.cmdk-item.is-active {
		background: var(--color-accent-soft);
		color: var(--color-ink);
	}

	.cmdk-item.is-active .cmdk-item-arrow,
	.cmdk-item:hover .cmdk-item-arrow { opacity: 1; color: var(--color-accent); }

	.cmdk-empty { padding: 1rem 0.75rem; margin: 0; color: var(--color-ink-4); font-size: var(--text-sm2); }

	@media (max-width: 40rem) {
		.nav-links { display: none; }
		.cmdk-trigger-label { display: none; }
		.cmdk-trigger { padding-inline: 0.7rem; min-height: 44px; }
		.btn-primary { height: 44px; }
	}

	@media (prefers-reduced-motion: reduce) {
		.nav-links a::after,
		.cmdk-item-arrow,
		.btn-primary,
		.cmdk-trigger,
		.cmdk-backdrop,
		.cmdk-panel { transition: none; }
	}
</style>

<script>
	(() => {
		const backdrop = document.getElementById('cmdk');
		const panel = backdrop?.querySelector('.cmdk-panel') as HTMLElement | null;
		const input = document.getElementById('cmdk-input') as HTMLInputElement | null;
		const list = document.getElementById('cmdk-list');
		const empty = document.getElementById('cmdk-empty');
		const trigger = document.getElementById('cmdk-open');
		if (!backdrop || !panel || !input || !list || !trigger) return;

		const items = () => Array.from(list.querySelectorAll<HTMLAnchorElement>('.cmdk-item'));
		const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		let lastFocus: HTMLElement | null = null;
		let closeTimer = 0;

		const visibleItems = () => items().filter((el) => !el.hidden);

		const setActive = (idx: number) => {
			const vis = visibleItems();
			vis.forEach((el) => el.classList.remove('is-active'));
			if (!vis.length) return;
			const clamped = (idx + vis.length) % vis.length;
			const el = vis[clamped];
			el.classList.add('is-active');
			el.scrollIntoView({ block: 'nearest' });
		};

		const activeIndex = () => visibleItems().findIndex((el) => el.classList.contains('is-active'));

		const filter = () => {
			const q = input.value.trim().toLowerCase();
			let anyVisible = false;
			items().forEach((el) => {
				const match = (el.dataset.label || '').toLowerCase().includes(q);
				el.hidden = !match;
				if (match) anyVisible = true;
			});
			// Hide group headers with no visible items beneath is skipped for simplicity;
			// keep them — they still read as section labels.
			if (empty) empty.hidden = anyVisible;
			setActive(0);
		};

		const open = () => {
			lastFocus = document.activeElement as HTMLElement;
			window.clearTimeout(closeTimer);
			backdrop.hidden = false;
			trigger.setAttribute('aria-expanded', 'true');
			document.documentElement.style.overflow = 'hidden';
			input.value = '';
			filter();
			// next frame so the enter transition runs from the hidden state
			requestAnimationFrame(() => backdrop.classList.add('is-open'));
			input.focus();
		};

		const close = () => {
			backdrop.classList.remove('is-open');
			trigger.setAttribute('aria-expanded', 'false');
			document.documentElement.style.overflow = '';
			if (reduceMotion) backdrop.hidden = true;
			else closeTimer = window.setTimeout(() => { backdrop.hidden = true; }, 250);
			if (lastFocus && typeof lastFocus.focus === 'function') lastFocus.focus();
		};

		trigger.addEventListener('click', open);

		document.addEventListener('keydown', (e) => {
			if ((e.key === 'k' || e.key === 'K') && (e.metaKey || e.ctrlKey)) {
				e.preventDefault();
				backdrop.hidden ? open() : close();
			}
		});

		backdrop.addEventListener('click', (e) => {
			if (e.target === backdrop) close();
		});

		input.addEventListener('input', filter);

		backdrop.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') { e.preventDefault(); close(); return; }
			if (e.key === 'ArrowDown') { e.preventDefault(); setActive(activeIndex() + 1); return; }
			if (e.key === 'ArrowUp') { e.preventDefault(); setActive(activeIndex() - 1); return; }
			if (e.key === 'Enter') {
				const vis = visibleItems();
				const el = vis[activeIndex()] || vis[0];
				if (el) { e.preventDefault(); el.click(); }
				return;
			}
			if (e.key === 'Tab') {
				// Focus trap: only input + visible items are focusable inside.
				const focusables = [input, ...visibleItems()];
				const first = focusables[0];
				const last = focusables[focusables.length - 1];
				if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
				else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
			}
		});

		list.addEventListener('mousemove', (e) => {
			const el = (e.target as HTMLElement).closest('.cmdk-item') as HTMLElement | null;
			if (!el || el.hidden) return;
			visibleItems().forEach((i) => i.classList.remove('is-active'));
			el.classList.add('is-active');
		});
	})();
</script>
