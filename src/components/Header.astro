---
import { SITE_TITLE } from '../consts';
---

<header class="nav" id="site-nav" aria-label="Primary">
	<div class="nav-inner">
		<a href="/" class="brand" aria-label={`${SITE_TITLE} — home`}>
			<span class="brand-mark" aria-hidden="true">
				<svg viewBox="0 0 32 32" width="26" height="26" fill="none" xmlns="http://www.w3.org/2000/svg">
					<rect x="1" y="1" width="30" height="30" rx="9" fill="#10B981" />
					<path d="M10 21.5V10.5h3.8c2 0 3.2 1 3.2 2.5 0 1-.5 1.8-1.4 2.2 1.2.3 2 1.2 2 2.6 0 1.7-1.4 3-3.6 3H10Zm2.2-6.6h1.3c.9 0 1.5-.4 1.5-1.1 0-.8-.6-1.2-1.5-1.2h-1.3v2.3Zm0 4.7h1.6c1 0 1.7-.5 1.7-1.3s-.7-1.3-1.7-1.3h-1.6v2.6Z" fill="#fff" />
				</svg>
			</span>
			<span class="brand-name">{SITE_TITLE}</span>
		</a>

		<nav class="nav-links" aria-label="Primary navigation">
			<a href="#how-it-works">How it works</a>
			<a href="#why-accountic">Why Accountic</a>
			<a href="#pricing">Pricing</a>
			<a href="#founders">Founders</a>
		</nav>

		<div class="nav-actions">
			<a class="nav-link-subtle" href="/login">Sign in</a>
			<a class="btn btn-primary btn-sm" href="#cta">Get started</a>
		</div>
	</div>
</header>

<style>
	.nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 50;
		padding: 0.75rem 1rem 0;
		pointer-events: none;
	}

	.nav-inner {
		pointer-events: auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		max-width: 900px;
		margin-inline: auto;
		padding: 0.45rem 0.45rem 0.45rem 1.25rem;
		height: 56px;

		background: var(--eth-nav-glass);
		border: 1px solid var(--eth-nav-glass-border);
		border-radius: var(--eth-pill-radius);
		backdrop-filter: blur(40px) saturate(180%);
		-webkit-backdrop-filter: blur(40px) saturate(180%);
		box-shadow: var(--eth-nav-glass-shadow);
		transition: max-width 350ms ease, box-shadow 350ms ease;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		color: var(--eth-text);
		font-weight: 600;
		font-size: 0.98rem;
		letter-spacing: -0.01em;
	}

	.brand:hover { color: var(--eth-text); }

	.brand-mark { display: inline-flex; }

	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.35rem;
	}

	.nav-links a {
		color: var(--eth-text-secondary);
		font-size: 0.9rem;
		font-weight: 500;
		padding: 0.5rem 0.85rem;
		border-radius: var(--eth-pill-radius);
		transition: color 200ms ease, background-color 200ms ease;
	}

	.nav-links a:hover {
		color: var(--eth-text);
		background: rgba(255, 255, 255, 0.55);
	}

	.nav-actions {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.nav-link-subtle {
		color: var(--eth-text-secondary);
		font-weight: 500;
		font-size: 0.9rem;
		padding: 0.5rem 0.75rem;
	}

	.nav-link-subtle:hover {
		color: var(--eth-text);
	}

	.btn-sm {
		padding: 0.5rem 1rem;
		font-size: 0.85rem;
		min-height: 40px;
	}

	@media (max-width: 860px) {
		.nav-links { display: none; }
	}

	@media (max-width: 520px) {
		.nav-link-subtle { display: none; }
	}
</style>
