---
import { SITE_TITLE } from '../consts';
const year = new Date().getFullYear();

const groups = [
	{
		label: 'Product',
		links: [
			{ label: 'Modules', href: '/#modules' },
			{ label: 'How it works', href: '/#how-it-works' },
			{ label: 'Why Accountic', href: '/#why-accountic' },
			{ label: 'Pricing', href: '/#pricing' },
			{ label: 'Blog', href: '/blog' },
		],
	},
	{
		label: 'Company',
		links: [
			{ label: 'Founding team', href: '/#founders' },
			{ label: 'Contact sales', href: '/contact' },
			{ label: 'Security & trust', href: '/security' },
			{ label: 'Careers', href: '/careers' },
		],
	},
	{
		label: 'Legal',
		links: [
			{ label: 'Data Processing Agreement', href: '/dpa' },
			{ label: 'Privacy policy', href: '/privacy' },
			{ label: 'Terms of service', href: '/terms' },
			{ label: 'DPDP compliance', href: '/dpdp' },
		],
	},
];
---

<footer class="site-footer">
	<div class="footer-wrap">
		<div class="footer-statement">
			<p class="footer-eyebrow"><span class="tick" aria-hidden="true"></span>ACCOUNTIC · BUILT BY CAs</p>
			<p class="statement">
				The compliance, reconciliation, and reporting your firm repeats every week —
				<span class="accent">finished, verified, and posted straight into Tally.</span>
			</p>
			<a class="statement-cta" href="https://app.accountic.in/signup">
				Start free — ₹1,000 credits
				<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
			</a>
		</div>

		<nav class="footer-cols" aria-label="Footer">
			{groups.map((g) => (
				<div class="footer-col">
					<p class="footer-col-label">{g.label}</p>
					<ul>
						{g.links.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
					</ul>
				</div>
			))}
		</nav>
	</div>

	<div class="footer-meta">
		<a href="/" class="brand" aria-label={`${SITE_TITLE} — home`}>
			<span class="brand-mark" aria-hidden="true">
				<svg viewBox="0 0 32 32" width="20" height="20" xmlns="http://www.w3.org/2000/svg">
					<rect class="bm-bg" x="0" y="0" width="32" height="32" rx="6" />
					<g class="bm-fg" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round" fill="none">
						<path d="M7 24.5 L16 7 L25 24.5" />
						<path d="M11 18 L21 18" />
					</g>
				</svg>
			</span>
			<span class="brand-name">{SITE_TITLE}</span>
		</a>
		<p class="meta-line">Infra by Thalia · SOC 2 Type II · India data residency · DPDP-ready</p>
		<p class="meta-copy">© {year} Accountic Technologies Pvt. Ltd. · Made in India</p>
	</div>
</footer>

<style>
	.site-footer {
		background: var(--color-paper);
		border-top: 1px solid var(--color-rule);
		color: var(--color-ink-3);
	}

	.footer-wrap {
		max-width: var(--wrap);
		margin-inline: auto;
		padding: var(--space-4xl) clamp(1rem, 4vw, 1.5rem) var(--space-2xl);
		display: grid;
		grid-template-columns: 1.3fr 1fr;
		gap: var(--space-3xl);
		align-items: start;
	}

	.footer-eyebrow {
		display: inline-flex;
		align-items: center;
		gap: var(--space-xs);
		margin: 0 0 var(--space-lg);
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		letter-spacing: 0.08em;
		color: var(--color-ink-4);
	}

	.tick { width: 6px; height: 6px; border-radius: var(--radius-2xs); background: var(--color-accent); }

	.statement {
		margin: 0;
		font-family: var(--font-display);
		font-weight: 500;
		font-size: var(--text-3xl);
		line-height: 1.2;
		letter-spacing: -0.02em;
		color: var(--color-ink);
		max-width: 22ch;
		overflow-wrap: anywhere;
	}

	.statement .accent { color: var(--color-accent-2); }

	.statement-cta {
		display: inline-flex;
		align-items: center;
		gap: var(--space-xs);
		margin-top: var(--space-lg);
		font-family: var(--font-display);
		font-weight: 600;
		font-size: var(--text-sm2);
		color: var(--color-ink);
	}

	.statement-cta svg { transition: transform var(--dur-2) var(--ease-out); }
	.statement-cta:hover { color: var(--color-accent-2); }
	.statement-cta:hover svg { transform: translateX(3px); }

	.footer-cols {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: var(--space-xl);
	}

	.footer-col-label {
		margin: 0 0 var(--space-md);
		font-family: var(--font-mono);
		font-size: 0.66rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-ink-4);
	}

	.footer-col ul { list-style: none; margin: 0; padding: 0; display: grid; gap: var(--space-2xs); }

	.footer-col a {
		position: relative;
		display: inline-block;
		padding-block: 0.35rem;
		color: var(--color-ink-3);
		font-size: var(--text-sm2);
		transition: color var(--dur-1) var(--ease-out);
	}

	.footer-col a:hover { color: var(--color-accent-2); }

	.footer-meta {
		max-width: var(--wrap);
		margin-inline: auto;
		padding: var(--space-lg) clamp(1rem, 4vw, 1.5rem);
		border-top: 1px solid var(--color-rule);
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: var(--space-sm) var(--space-lg);
		font-size: var(--text-xs);
		color: var(--color-ink-4);
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: var(--space-xs);
		color: var(--color-ink);
		font-family: var(--font-display);
		font-weight: 600;
		font-size: 0.95rem;
	}

	.brand-mark { display: inline-flex; color: var(--color-accent); }
	.brand-mark .bm-bg { fill: currentColor; }
	.brand-mark .bm-fg { stroke: var(--color-accent-ink); }

	.meta-line { margin: 0; font-family: var(--font-mono); letter-spacing: 0.02em; }
	.meta-copy { margin: 0; margin-left: auto; }

	.site-footer :focus-visible {
		outline: 2px solid var(--color-focus);
		outline-offset: 2px;
		border-radius: var(--radius-xs);
	}

	@media (max-width: 60rem) {
		.footer-wrap { grid-template-columns: 1fr; gap: var(--space-2xl); }
	}

	@media (max-width: 40rem) {
		.footer-cols { grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); }
		.meta-copy { margin-left: 0; flex-basis: 100%; }
	}

	@media (prefers-reduced-motion: reduce) {
		.statement-cta svg, .footer-col a, .statement-cta { transition: none; }
	}
</style>
