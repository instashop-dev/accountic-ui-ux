---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
	title="Contact sales"
	description="Talk to the Accountic team about firm-tier pricing, DPAs, and custom onboarding for your CA practice."
	eyebrow="Contact sales"
	heading="Let's get your firm onto Accountic."
	lede="Tell us about your practice and we'll be in touch within one business day. For pilot cohorts, we typically onboard in under 48 hours."
>
	<svg slot="visual" viewBox="0 0 260 200" width="260" height="200" fill="none" xmlns="http://www.w3.org/2000/svg">
		{/* Incoming chat bubble (from user, white) */}
		<g>
			<path d="M28 52 Q28 38 42 38 H152 Q166 38 166 52 V82 Q166 96 152 96 H68 L48 110 V96 Q28 96 28 82 Z" fill="#ffffff" stroke="#e2e8f0" stroke-width="1.4" />
			<rect x="44" y="52" width="80" height="5" rx="2.5" fill="#cbd5e1" />
			<rect x="44" y="63" width="100" height="5" rx="2.5" fill="#cbd5e1" />
			<rect x="44" y="74" width="60" height="5" rx="2.5" fill="#cbd5e1" />
		</g>
		{/* Outgoing reply bubble (emerald) */}
		<g>
			<path d="M232 116 Q232 102 218 102 H118 Q104 102 104 116 V142 Q104 156 118 156 H208 L226 172 V156 Q232 156 232 142 Z" fill="#10b981" />
			<rect x="120" y="118" width="92" height="5" rx="2.5" fill="#ffffff" opacity="0.9" />
			<rect x="120" y="129" width="70" height="5" rx="2.5" fill="#ffffff" opacity="0.6" />
			<circle cx="210" cy="142" r="9" fill="#ffffff" />
			<path d="M205 142l3 3 6-6" stroke="#10b981" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none" />
		</g>
		{/* Small dots / signals */}
		<circle cx="22" cy="30" r="4" fill="#fde68a" />
		<circle cx="244" cy="38" r="5" fill="#fbcfe8" />
		<circle cx="18" cy="130" r="3" fill="#bfdbfe" />
	</svg>
	<div class="contact-grid" data-capture data-source="contact-page" data-endpoint="/api/capture">
		<form class="contact-form" data-capture-form data-state="form" novalidate>
			<div class="field-row">
				<label class="field">
					<span class="field-label">Full name</span>
					<input name="name" type="text" required autocomplete="name" placeholder="CA Rajesh Mehta" />
				</label>
				<label class="field">
					<span class="field-label">Firm name</span>
					<input name="firm" type="text" required placeholder="DPS &amp; Co." />
				</label>
			</div>

			<div class="field-row">
				<label class="field">
					<span class="field-label">Work email</span>
					<input name="email" type="email" required autocomplete="email" placeholder="partner@firm.in" />
				</label>
				<label class="field">
					<span class="field-label">Phone <span class="optional">(optional)</span></span>
					<input name="phone" type="tel" autocomplete="tel" placeholder="+91 98xx xxx xxx" />
				</label>
			</div>

			<div class="field-row">
				<label class="field">
					<span class="field-label">Firm size</span>
					<select name="size" required>
						<option value="" disabled selected>Select firm size…</option>
						<option>Solo practitioner</option>
						<option>2–5 professionals</option>
						<option>6–15 professionals</option>
						<option>16–30 professionals</option>
						<option>30+ professionals</option>
					</select>
				</label>

				<label class="field">
					<span class="field-label">Monthly notice volume <span class="optional">(optional)</span></span>
					<select name="volume">
						<option value="" disabled selected>Select volume…</option>
						<option>Under 10 notices</option>
						<option>10–50 notices</option>
						<option>50–200 notices</option>
						<option>200+ notices</option>
					</select>
				</label>
			</div>

			<label class="field">
				<span class="field-label">What would you like to discuss?</span>
				<textarea name="message" rows="4" placeholder="Pilot terms, DPA availability, bulk historical upload…"></textarea>
			</label>

			<div class="form-foot">
				<button type="submit" class="btn btn-primary">
					Request a conversation
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
					</svg>
				</button>
				<p class="foot-note">
					By submitting you agree to our <a href="/privacy">privacy policy</a>. We'll only contact you about your request.
				</p>
			</div>
			<p class="form-error" data-capture-error role="alert" hidden>Please fill in your name, firm, and a valid work email.</p>
		</form>

		<div class="contact-thanks" data-state="thanks" hidden>
			<div class="thanks-icon" aria-hidden="true">
				<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
					<path d="M20 6 9 17l-5-5"></path>
				</svg>
			</div>
			<h2>Thanks — we'll be in touch.</h2>
			<p>
				We received <strong data-capture-email>your email</strong> and one of the founders will reach out within one business day. Pilot-cohort onboarding typically takes under 48 hours.
			</p>
			<div class="thanks-next">
				<p class="thanks-next-label">While you wait</p>
				<ul>
					<li><a href="/security">Read our security &amp; DPA posture →</a></li>
					<li><a href="/dpdp">Review our DPDP compliance →</a></li>
					<li><a href="/#pricing">Browse the per-notice pricing →</a></li>
				</ul>
			</div>
		</div>

		<aside class="contact-aside">
			<div class="aside-card">
				<h3>What happens next</h3>
				<ol>
					<li><strong>We reply within 1 business day</strong> — usually faster.</li>
					<li><strong>30-minute discovery</strong> on notice volume, firm setup, historical corpus.</li>
					<li><strong>Pilot onboarding</strong> with your first 10 notices under close review.</li>
					<li><strong>Firm-tier terms</strong> including DPA, if applicable.</li>
				</ol>
			</div>

			<div class="aside-card">
				<h3>Direct channels</h3>
				<ul class="direct">
					<li>
						<span class="dir-label">Sales</span>
						<a href="mailto:sales@accountic.com">sales@accountic.com</a>
					</li>
					<li>
						<span class="dir-label">Partnerships</span>
						<a href="mailto:partners@accountic.com">partners@accountic.com</a>
					</li>
					<li>
						<span class="dir-label">Security &amp; DPA</span>
						<a href="mailto:security@accountic.com">security@accountic.com</a>
					</li>
					<li>
						<span class="dir-label">Support</span>
						<a href="mailto:support@accountic.com">support@accountic.com</a>
					</li>
				</ul>
			</div>

			<div class="aside-card subtle">
				<p class="small">
					<strong>Not ready to talk?</strong> Start with 3 free notices — no card required.
				</p>
				<a href="/#cta" class="btn btn-secondary btn-small">Start free trial</a>
			</div>
		</aside>
	</div>
</PageLayout>

<style>
	.contact-grid {
		display: grid;
		grid-template-columns: 1.4fr 1fr;
		gap: 2.5rem;
		align-items: start;
	}

	.contact-form {
		background: var(--eth-surface);
		border: 1px solid var(--eth-border);
		border-radius: var(--eth-card-radius);
		padding: clamp(1.5rem, 3vw, 2.25rem);
		box-shadow: var(--eth-shadow-sm);
		display: grid;
		gap: 1rem;
	}

	.field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

	@media (max-width: 520px) { .field-row { grid-template-columns: 1fr; } }

	.field { display: grid; gap: 0.4rem; }

	.field-label {
		font-size: 0.85rem;
		color: var(--eth-text);
		font-weight: 500;
		display: flex;
		justify-content: space-between;
	}

	.optional { color: var(--eth-text-muted); font-weight: 400; }

	.field input,
	.field select,
	.field textarea {
		padding: 0.85rem 1rem;
		font-size: 0.95rem;
		font-family: inherit;
		border: 1px solid var(--eth-border);
		border-radius: 1rem; /* MASTER: 1rem for data inputs, not pill */
		background: var(--eth-surface);
		color: var(--eth-text);
		min-height: 48px;
		resize: vertical;
		transition: border-color 180ms ease, box-shadow 180ms ease;
	}

	.field textarea { border-radius: 1rem; }

	/* Focus uses the global soft-glow rule from global.css — no override here. */

	.form-foot {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
		margin-top: 0.5rem;
	}

	.foot-note {
		font-size: 0.8rem;
		color: var(--eth-text-muted);
		margin: 0;
		max-width: 32ch;
	}

	.foot-note a { color: var(--eth-text); text-decoration: underline; text-decoration-color: var(--eth-border-light); }

	.contact-aside { display: grid; gap: 1rem; }

	.aside-card {
		background: var(--eth-surface);
		border: 1px solid var(--eth-border);
		border-radius: var(--eth-card-radius);
		padding: 1.5rem;
		box-shadow: var(--eth-shadow-sm);
	}

	.aside-card h3 {
		font-size: 1rem;
		margin: 0 0 0.85rem;
		font-weight: 600;
	}

	.aside-card ol { margin: 0; padding-left: 1.25rem; display: grid; gap: 0.5rem; color: var(--eth-text-secondary); font-size: 0.9rem; }

	.aside-card ol strong { color: var(--eth-text); font-weight: 600; }

	.direct { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.75rem; }

	.direct li { display: grid; gap: 0.15rem; }

	.dir-label {
		font-size: 0.72rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--eth-text-muted);
		font-weight: 600;
	}

	.direct a { color: var(--eth-text); font-weight: 500; font-size: 0.92rem; }

	.aside-card.subtle {
		background: var(--eth-surface-alt);
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		align-items: flex-start;
	}

	.aside-card .small { font-size: 0.9rem; margin: 0; color: var(--eth-text-secondary); }
	.aside-card .small strong { color: var(--eth-text); }

	.btn-small { padding: 0.55rem 1rem; font-size: 0.85rem; min-height: 40px; }

	.form-error {
		margin: -0.25rem 0 0;
		color: #b91c1c;
		font-size: 0.85rem;
		font-weight: 500;
	}

	.contact-thanks {
		grid-column: 1 / -1;
		background: var(--eth-surface);
		border: 1px solid var(--eth-border);
		border-radius: var(--eth-card-radius);
		padding: clamp(2rem, 5vw, 3rem);
		box-shadow: var(--eth-shadow);
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.thanks-icon {
		width: 64px;
		height: 64px;
		border-radius: 9999px;
		background: var(--eth-accent-soft);
		color: var(--eth-accent);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 1rem;
	}

	.contact-thanks h2 { margin: 0 0 0.75rem; font-size: clamp(1.5rem, 2.4vw, 2rem); }
	.contact-thanks > p { max-width: 52ch; color: var(--eth-text-secondary); margin: 0 auto; }
	.contact-thanks strong { color: var(--eth-text); font-weight: 600; }

	.thanks-next {
		margin-top: 2rem;
		padding-top: 1.5rem;
		border-top: 1px dashed var(--eth-border);
		width: 100%;
		max-width: 440px;
	}

	.thanks-next-label {
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--eth-text-muted);
		margin: 0 0 0.6rem;
	}

	.thanks-next ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 0.4rem;
	}

	.thanks-next a {
		color: var(--eth-accent);
		font-weight: 500;
		font-size: 0.95rem;
	}

	@media (max-width: 900px) {
		.contact-grid { grid-template-columns: 1fr; }
	}
</style>

<script is:inline>
	(function () {
		const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

		function storeCapture(payload, source) {
			try {
				const key = 'accountic:captures';
				const existing = JSON.parse(localStorage.getItem(key) || '[]');
				existing.push({ ...payload, source, at: new Date().toISOString() });
				localStorage.setItem(key, JSON.stringify(existing));
			} catch (_) { /* storage unavailable — silently skip */ }
		}

		function sendCapture(payload, source) {
			const card = document.querySelector(`[data-capture][data-source="${source}"]`);
			const endpoint = card && card.dataset.endpoint;
			if (!endpoint) return Promise.resolve();
			return fetch(endpoint, {
				method: 'POST',
				headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
				body: JSON.stringify({ ...payload, source, page: location.pathname }),
			}).catch(() => {});
		}

		const card = document.querySelector('[data-capture][data-source="contact-page"]');
		if (!card) return;
		const form = card.querySelector('[data-capture-form]');
		const err = card.querySelector('[data-capture-error]');
		const emailOut = card.querySelector('[data-capture-email]');
		const formState = card.querySelector('[data-state="form"]');
		const thanksState = card.querySelector('[data-state="thanks"]');
		if (!form) return;

		form.addEventListener('submit', function (event) {
			event.preventDefault();
			const data = new FormData(form);
			const name = (data.get('name') || '').toString().trim();
			const firm = (data.get('firm') || '').toString().trim();
			const email = (data.get('email') || '').toString().trim();
			if (!name || !firm || !EMAIL_RE.test(email)) {
				if (err) err.hidden = false;
				return;
			}
			if (err) err.hidden = true;

			const submitBtn = form.querySelector('button[type="submit"]');
			if (submitBtn) { submitBtn.disabled = true; submitBtn.style.opacity = '0.6'; }

			const payload = {
				name, firm, email,
				phone: (data.get('phone') || '').toString().trim(),
				size: (data.get('size') || '').toString().trim(),
				volume: (data.get('volume') || '').toString().trim(),
				message: (data.get('message') || '').toString().trim(),
			};

			storeCapture(payload, 'contact-page');
			sendCapture(payload, 'contact-page').finally(function () {
				if (emailOut) emailOut.textContent = email;
				if (formState) formState.hidden = true;
				if (thanksState) thanksState.hidden = false;
				window.scrollTo({ top: card.getBoundingClientRect().top + window.scrollY - 80, behavior: 'smooth' });
			});
		});
	})();
</script>
