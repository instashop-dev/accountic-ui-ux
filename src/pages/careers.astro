---
import PageLayout from '../layouts/PageLayout.astro';

const roles = [
	{
		title: 'Founding Backend Engineer (RAG / Retrieval)',
		team: 'Engineering',
		location: 'Mumbai · Hybrid',
		type: 'Full-time',
		blurb: 'Own the citation-verification pipeline from ingestion to retrieval. Production RAG experience required. You will ship the single most differentiating thing we sell.',
	},
	{
		title: 'Founding Product Engineer (TypeScript / Astro)',
		team: 'Engineering',
		location: 'Mumbai · Hybrid',
		type: 'Full-time',
		blurb: 'Build the workbench CAs work in every day. Tight feedback loops with 10 paying firms. Obsess over latency, clarity, and the 30-minute promise.',
	},
	{
		title: 'Senior Associate — Tax Research',
		team: 'Domain',
		location: 'Mumbai · On-site',
		type: 'Full-time',
		blurb: 'CA or equivalent with 3+ years in direct-tax litigation. Curate the IT Act, CBDT circulars, and case-law repository. Review model outputs. Write the quarterly accuracy report.',
	},
	{
		title: 'Founding Customer Engineer',
		team: 'GTM',
		location: 'Mumbai · Hybrid',
		type: 'Full-time',
		blurb: 'Onboard the first 100 firms. Sit in on their first 10 notices each. Turn friction into product bugs. Background in tax practice, sales engineering, or both.',
	},
];

const values = [
	{
		title: 'Depth before breadth.',
		body: "V1 does one thing — Income Tax notice drafting — to a standard a senior CA will put their name on. We'd rather ship one workflow that works than five that kind of work.",
	},
	{
		title: 'Honest about accuracy.',
		body: 'We publish our citation-verification error rate quarterly. A bad draft that reaches a Tax Officer damages a CA\'s standing. That shapes every product trade-off.',
	},
	{
		title: 'India, first and seriously.',
		body: "Data residency, DPDP, ICAI ethics, Razorpay billing — not as afterthoughts. Built because our customers' compliance posture depends on ours.",
	},
	{
		title: 'Practitioners in the loop.',
		body: 'Founded jointly by a CA firm with 45 years of practice and a SOC-certified technology partner. Every workflow decision runs past people who have drafted these replies themselves.',
	},
];
---

<PageLayout
	title="Careers"
	description="Help build the AI workbench for Indian Chartered Accountancy. Mumbai-based, founding-team roles across engineering, tax research, and customer engineering."
	eyebrow="Careers"
	heading="Build the workbench for 1.6 lakh Indian CAs."
	lede="We're a small founding team in Mumbai, working on the single most repetitive high-stakes task in Indian accountancy. If you want to ship something measurably trusted by professionals, read on."
>
	<svg slot="visual" class="hero-visual" viewBox="0 0 260 200" width="260" height="200" fill="none" xmlns="http://www.w3.org/2000/svg">
		<circle cx="75" cy="90" r="28" class="hv-disc" />
		<circle cx="75" cy="82" r="10" class="hv-figure" />
		<path d="M55 110 Q75 100 95 110 L92 125 Q75 118 58 125 Z" class="hv-figure" />
		<circle cx="145" cy="70" r="26" class="hv-disc" />
		<circle cx="145" cy="62" r="9" class="hv-figure" />
		<path d="M127 88 Q145 79 163 88 L161 102 Q145 95 129 102 Z" class="hv-figure" />
		<circle cx="210" cy="100" r="30" class="hv-disc" />
		<circle cx="210" cy="92" r="11" class="hv-figure" />
		<path d="M188 121 Q210 110 232 121 L229 138 Q210 130 191 138 Z" class="hv-figure" />
		<rect x="48" y="150" width="170" height="36" rx="18" class="hv-paper hv-accent-stroke" stroke-width="1.5" />
		<text x="133" y="172" text-anchor="middle" class="hv-accent-text" font-family="Inter, system-ui, sans-serif" font-size="12" font-weight="600">We're hiring</text>
	</svg>
	<section class="about">
		<div class="about-head">
			<span class="eyebrow">Why this, why now</span>
			<h2>Responding to an Income Tax notice is a CA's highest-stakes recurring task.</h2>
		</div>
		<div class="about-grid">
			<p>
				A routine notice burns 3–4 hours. A scrutiny or reassessment can consume days. Across
				~1.6 lakh practicing CAs in India, this is the single largest pool of skilled, repetitive
				work in the profession.
			</p>
			<p>
				Accountic V1 is a focused AI workbench for Income Tax notice response, with a
				citation-verification layer backed by a credit-refund policy — the only one of its kind
				in the Indian market. We launch May 2026. The work you'd do in the next 12 months will
				define whether Indian CAs trust AI with the filings their signature goes on.
			</p>
		</div>
	</section>

	<section class="values">
		<div class="values-head">
			<span class="eyebrow">How we work</span>
			<h2>Four things we believe.</h2>
		</div>
		<div class="values-grid">
			{values.map((v) => (
				<article class="value-card">
					<h3>{v.title}</h3>
					<p>{v.body}</p>
				</article>
			))}
		</div>
	</section>

	<section class="roles" id="open-roles">
		<div class="roles-head">
			<span class="eyebrow">Open roles</span>
			<h2>Founding-team positions.</h2>
			<p class="lede">Every role is founding. Every hire sits within 20 feet of the co-founders. Compensation is market cash + meaningful equity for founding hires.</p>
		</div>

		<ul class="role-list">
			{roles.map((r) => (
				<li class="role-card">
					<div class="role-meta">
						<span class="role-team">{r.team}</span>
						<span class="role-dot">·</span>
						<span class="role-loc">{r.location}</span>
						<span class="role-dot">·</span>
						<span class="role-type">{r.type}</span>
					</div>
					<h3>{r.title}</h3>
					<p>{r.blurb}</p>
					<a class="role-apply" href={`mailto:careers@accountic.com?subject=${encodeURIComponent('Application — ' + r.title)}`}>
						Apply
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
						</svg>
					</a>
				</li>
			))}
		</ul>
	</section>

	<section class="general">
		<div class="general-card">
			<h2>Don't see your role?</h2>
			<p>
				If you've spent years drafting tax notices, building production RAG systems, or running
				customer-facing motions for professional-services software — we want to hear from you.
			</p>
			<a class="btn btn-primary" href="mailto:careers@accountic.com">
				Email careers@accountic.com
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
				</svg>
			</a>
		</div>
	</section>
</PageLayout>

<style>
	/* Hero illustration — colour routed through CSS (no inline hex) */
	.hero-visual { color: var(--color-accent); }
	.hv-disc { fill: var(--color-paper-3); }
	.hv-figure { fill: var(--color-ink-3); }
	.hv-paper { fill: var(--color-paper); }
	.hv-accent-stroke { stroke: var(--color-accent); }
	.hv-accent-text { fill: var(--color-accent-2); }

	.about-head,
	.values-head,
	.roles-head { margin-bottom: var(--space-xl); }

	.about-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-2xl);
		margin-bottom: var(--space-3xl);
	}

	.about-grid p {
		color: var(--color-ink-3);
		font-size: var(--text-body);
		line-height: 1.75;
		margin: 0;
	}

	.values-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: var(--space-lg);
		margin-bottom: var(--space-3xl);
	}

	.value-card {
		background: var(--color-paper);
		border: 1px solid var(--color-rule);
		border-radius: var(--radius-lg);
		padding: var(--space-xl);
		transition: border-color var(--dur-1) var(--ease-out);
	}

	.value-card:hover { border-color: var(--color-rule-2); }

	.value-card h3 { font-family: var(--font-display); font-size: var(--text-lg); font-weight: 600; margin: 0 0 var(--space-xs); color: var(--color-ink); }
	.value-card p { margin: 0; color: var(--color-ink-3); line-height: 1.65; font-size: var(--text-body); }

	.roles-head .lede { max-width: 54ch; font-size: var(--text-lg); line-height: 1.6; }

	.role-list {
		list-style: none;
		padding: 0;
		margin: 0 0 var(--space-3xl);
		display: grid;
		gap: var(--space-sm);
	}

	.role-card {
		background: var(--color-paper);
		border: 1px solid var(--color-rule);
		border-radius: var(--radius-lg);
		padding: var(--space-xl);
		display: grid;
		grid-template-columns: 1fr auto;
		grid-template-areas:
			'meta meta'
			'title apply'
			'blurb blurb';
		gap: var(--space-sm) var(--space-md);
		align-items: center;
		transition: border-color var(--dur-1) var(--ease-out);
	}

	.role-card:hover {
		border-color: var(--color-rule-2);
	}

	/* Mono meta row — location/type; explicit letter-spacing so it never inherits
	   the body's negative tracking (per design.md mono-label spec). */
	.role-meta {
		grid-area: meta;
		display: flex;
		align-items: center;
		gap: var(--space-xs);
		flex-wrap: wrap;
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		letter-spacing: var(--tracking-label);
		text-transform: uppercase;
		color: var(--color-ink-4);
	}

	.role-team { font-weight: 600; }
	.role-dot { color: var(--color-rule-2); }

	.role-card h3 { grid-area: title; font-family: var(--font-display); font-size: var(--text-lg); font-weight: 600; margin: 0; color: var(--color-ink); }
	.role-card p { grid-area: blurb; margin: 0; color: var(--color-ink-3); font-size: var(--text-body); line-height: 1.6; }

	/* Neutral at rest — cobalt only on hover (accent scarcity) */
	.role-apply {
		grid-area: apply;
		display: inline-flex;
		align-items: center;
		gap: var(--space-xs);
		min-height: 44px;
		font-family: var(--font-display);
		font-weight: 600;
		color: var(--color-ink);
		font-size: var(--text-sm2);
		white-space: nowrap;
		padding: var(--space-xs) var(--space-md);
		border: 1px solid var(--color-border-control);
		border-radius: var(--radius-sm);
		transition: background-color var(--dur-1) var(--ease-out), border-color var(--dur-1) var(--ease-out), color var(--dur-1) var(--ease-out);
	}

	.role-apply:hover { background: var(--color-accent-soft); border-color: var(--color-accent); color: var(--color-accent-2); }

	.general-card {
		background: var(--color-graphite);
		color: var(--color-on-dark-2);
		border-radius: var(--radius-lg);
		padding: clamp(var(--space-xl), 5vw, var(--space-2xl));
		text-align: center;
	}

	.general-card h2 { color: var(--color-on-dark); margin: 0 0 var(--space-sm); }
	.general-card p { color: var(--color-on-dark-2); margin: 0 auto var(--space-lg); max-width: 44ch; font-size: var(--text-body); }

	@media (max-width: 820px) {
		.about-grid,
		.values-grid { grid-template-columns: 1fr; }

		.role-card {
			grid-template-columns: 1fr;
			grid-template-areas:
				'meta'
				'title'
				'blurb'
				'apply';
		}
		.role-apply { justify-self: flex-start; }
	}
</style>
