---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const pageTitle = `Sign in · ${SITE_TITLE}`;
const pageDescription =
	'Sign in to Accountic — AI-powered Income Tax notice drafting for Indian Chartered Accountants.';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
	</head>
	<body>
		<Header />

		<main class="auth">
			<div class="container auth-container">
				<section class="auth-card" aria-label="Sign in">
					<div class="auth-brand" aria-hidden="true">
						<svg class="auth-logo" viewBox="0 0 32 32" width="36" height="36" fill="none" xmlns="http://www.w3.org/2000/svg">
							<rect class="auth-logo-bg" x="1" y="1" width="30" height="30" rx="9" />
							<g class="auth-logo-mark" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" fill="none">
								<path d="M8.5 23 L16 9 L23.5 23" />
								<path d="M13.5 16 L18.5 16" />
								<path d="M12 19 L20 19" />
							</g>
						</svg>
					</div>

					<h1>Welcome back.</h1>
					<p class="auth-sub">Sign in to pick up where you left off.</p>

					<div class="auth-sso" role="group" aria-label="Single sign-on">
						<button class="sso-btn" type="button">
							<svg width="18" height="18" viewBox="0 0 48 48" aria-hidden="true">
								<path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
								<path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
								<path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
								<path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
							</svg>
							<span>Continue with Google</span>
						</button>
						<button class="sso-btn" type="button">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M21 10V8a2 2 0 0 0-2-2h-1l-4-4-4 4H9a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-2"/>
								<path d="M3 13h10l-3-3m3 3-3 3"/>
							</svg>
							<span>Continue with SSO</span>
						</button>
					</div>

					<div class="auth-divider"><span>or sign in with email</span></div>

					<form class="auth-form" onsubmit="event.preventDefault(); alert('Dashboard coming soon. Launching May 2026.');" novalidate>
						<label class="auth-field">
							<span class="auth-label">Work email</span>
							<input
								type="email"
								name="email"
								placeholder="firm-email@yourca.in"
								required
								autocomplete="email"
							/>
						</label>

						<label class="auth-field">
							<span class="auth-label">
								Password
								<a href="/reset" class="auth-aux">Forgot?</a>
							</span>
							<div class="auth-pwd">
								<input
									type="password"
									name="password"
									id="auth-pwd-input"
									required
									autocomplete="current-password"
									placeholder="••••••••"
								/>
								<button type="button" class="pwd-toggle" data-pwd-toggle aria-label="Show password">
									<svg class="pwd-eye" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
										<circle cx="12" cy="12" r="3"/>
									</svg>
								</button>
							</div>
						</label>

						<label class="auth-remember">
							<input type="checkbox" name="remember" />
							<span>Keep me signed in on this device</span>
						</label>

						<button type="submit" class="btn btn-primary auth-submit">
							Sign in
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
							</svg>
						</button>
					</form>

					<p class="auth-alt">
						New to Accountic?
						<a href="/#cta">Start a free trial</a> — 3 notices on us, no card required.
					</p>
				</section>

				<ul class="auth-trust" aria-label="Compliance">
					<li>
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
							<path d="m9 12 2 2 4-4"/>
						</svg>
						SOC 2 Type II
					</li>
					<li>
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<rect x="4" y="11" width="16" height="10" rx="2"/>
							<path d="M8 11V7a4 4 0 0 1 8 0v4"/>
						</svg>
						DPDP-ready
					</li>
					<li>
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<circle cx="12" cy="12" r="9"/>
							<path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/>
						</svg>
						India-resident data
					</li>
					<li>
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
							<circle cx="9" cy="7" r="4"/>
							<path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
						</svg>
						Built by CAs &amp; engineers
					</li>
				</ul>
			</div>
		</main>

		<Footer />

		<style>
			.auth {
				position: relative;
				min-height: calc(100dvh - 80px);
				padding: 7rem 0 4rem;
				background-color: var(--color-paper);
				display: flex;
				align-items: center;
			}

			.auth-container {
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: var(--space-lg);
			}

			.auth-card {
				width: 100%;
				max-width: 440px;
				background: var(--color-paper);
				border: 1px solid var(--color-rule);
				border-radius: var(--radius-lg);
				padding: clamp(1.75rem, 4vw, 2.5rem);
				position: relative;
			}

			.auth-brand {
				display: inline-flex;
				margin-bottom: 1.25rem;
				padding: var(--space-2xs);
			}

			/* Brand logo — colors routed through Cobalt tokens (no inline hex). */
			.auth-logo-bg { fill: var(--color-accent); }
			.auth-logo-mark { stroke: var(--color-accent-ink); }

			.auth-card h1 {
				font-size: clamp(1.6rem, 3vw, 2rem);
				margin: 0 0 0.35rem;
				letter-spacing: -0.02em;
			}

			.auth-sub {
				color: var(--color-ink-4);
				margin: 0 0 var(--space-lg);
				font-size: 0.95rem;
			}

			/* SSO */
			.auth-sso {
				display: grid;
				gap: var(--space-xs);
				margin-bottom: var(--space-md);
			}

			.sso-btn {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				gap: 0.6rem;
				min-height: 44px;
				padding: 0.6rem 1rem;
				border: 1px solid var(--color-border-control);
				background: var(--color-paper);
				border-radius: var(--radius-sm);
				color: var(--color-ink);
				font-family: inherit;
				font-size: 0.9rem;
				font-weight: 500;
				cursor: pointer;
				transition: background 180ms ease, border-color 180ms ease;
			}

			.sso-btn:hover {
				background: var(--color-paper-2);
				border-color: var(--color-accent);
			}

			.sso-btn svg { flex-shrink: 0; }

			/* Divider */
			.auth-divider {
				display: flex;
				align-items: center;
				gap: var(--space-sm);
				font-family: var(--font-mono);
				color: var(--color-ink-4);
				font-size: 0.68rem;
				letter-spacing: var(--tracking-label);
				text-transform: uppercase;
				margin: var(--space-md) 0;
			}

			.auth-divider::before,
			.auth-divider::after {
				content: '';
				flex: 1;
				height: 1px;
				background: var(--color-rule);
			}

			/* Form */
			.auth-form { display: grid; gap: 0.85rem; }

			.auth-field { display: grid; gap: 0.4rem; }

			.auth-label {
				display: flex;
				justify-content: space-between;
				font-size: 0.85rem;
				color: var(--color-ink);
				font-weight: 500;
			}

			.auth-aux {
				font-size: 0.8rem;
				color: var(--color-accent-2);
				font-weight: 500;
			}

			.auth-aux:hover { color: var(--color-accent); }

			.auth-field input {
				padding: 0.8rem 1rem;
				font-size: 0.95rem;
				font-family: inherit;
				border: 1px solid var(--color-border-control);
				border-radius: var(--radius-sm); /* tight technical radius — never pill on data fields */
				background: var(--color-paper);
				color: var(--color-ink);
				min-height: 46px;
				width: 100%;
				transition: border-color 180ms ease, box-shadow 180ms ease;
			}

			.auth-field input::placeholder { color: var(--color-ink-4); }

			/* Focus uses the global cobalt ring from global.css. */

			.auth-pwd {
				position: relative;
				display: flex;
				align-items: center;
			}

			.auth-pwd input { padding-right: 3rem; }

			.pwd-toggle {
				position: absolute;
				right: 0.35rem;
				top: 50%;
				transform: translateY(-50%);
				width: 36px;
				height: 36px;
				border-radius: var(--radius-sm);
				border: none;
				background: transparent;
				color: var(--color-ink-4);
				display: inline-flex;
				align-items: center;
				justify-content: center;
				cursor: pointer;
				transition: background 180ms ease, color 180ms ease;
			}

			.pwd-toggle:hover {
				background: var(--color-paper-2);
				color: var(--color-ink);
			}

			.auth-remember {
				display: flex;
				align-items: center;
				gap: 0.55rem;
				font-size: 0.88rem;
				color: var(--color-ink-3);
				margin: 0.15rem 0 0.25rem;
				cursor: pointer;
				user-select: none;
			}

			.auth-remember input {
				width: 16px;
				height: 16px;
				accent-color: var(--color-accent);
				margin: 0;
				cursor: pointer;
			}

			.auth-submit {
				min-height: 48px;
				width: 100%;
				margin-top: 0.35rem;
			}

			.auth-alt {
				text-align: center;
				font-size: 0.88rem;
				color: var(--color-ink-4);
				margin: 1.25rem 0 0;
			}

			.auth-alt a {
				color: var(--color-accent-2);
				font-weight: 500;
			}

			.auth-alt a:hover { color: var(--color-accent); }

			/* Trust row below card */
			.auth-trust {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-wrap: wrap;
				justify-content: center;
				gap: var(--space-lg);
				font-family: var(--font-mono);
				font-size: 0.72rem;
				letter-spacing: var(--tracking-label);
				text-transform: uppercase;
				color: var(--color-ink-4);
			}

			.auth-trust li {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
			}

			.auth-trust svg { color: var(--color-ink-3); flex-shrink: 0; }

			@media (max-width: 560px) {
				.auth { padding: 6rem 0 3rem; }
				.auth-trust { gap: 0.75rem 1rem; font-size: 0.66rem; }
				.auth-trust li svg { width: 12px; height: 12px; }
			}
		</style>

		<script is:inline>
			(function () {
				const toggle = document.querySelector('[data-pwd-toggle]');
				const input = document.getElementById('auth-pwd-input');
				if (!toggle || !input) return;
				toggle.addEventListener('click', function () {
					const showing = input.type === 'text';
					input.type = showing ? 'password' : 'text';
					toggle.setAttribute('aria-label', showing ? 'Show password' : 'Hide password');
				});
			})();
		</script>
	</body>
</html>
