---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
	title="Sign in"
	description="Sign in to Accountic — AI-powered Income Tax notice drafting for Indian Chartered Accountants."
	narrow={true}
>
	<div class="login-wrap">
		<article class="login-card">
			<h1>Welcome back.</h1>
			<p class="muted">Sign in to pick up where you left off.</p>

			<div class="sso">
				<button class="btn btn-secondary sso-btn" type="button">
					<svg width="18" height="18" viewBox="0 0 48 48" aria-hidden="true">
						<path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
						<path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
						<path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
						<path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
					</svg>
					Continue with Google
				</button>
				<button class="btn btn-secondary sso-btn" type="button">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 23c-6.077 0-11-4.923-11-11S5.923 1 12 1s11 4.923 11 11-4.923 11-11 11zm5-7a3.001 3.001 0 0 0-4.08-2.812 5 5 0 1 1-3.841-3.841A3 3 0 0 0 13 6a3 3 0 0 0 4 2.83 5 5 0 1 1-5 5 3 3 0 0 0 5 2.17z"/></svg>
					Continue with SSO
				</button>
			</div>

			<div class="divider"><span>or sign in with email</span></div>

			<form class="login-form" onsubmit="event.preventDefault(); alert('Dashboard coming soon. Launching May 2026.');">
				<label class="field">
					<span class="field-label">Work email</span>
					<input
						type="email"
						name="email"
						placeholder="firm-email@yourca.in"
						required
						autocomplete="email"
					/>
				</label>
				<label class="field">
					<span class="field-label">
						Password
						<a href="/reset" class="field-aux">Forgot?</a>
					</span>
					<input
						type="password"
						name="password"
						required
						autocomplete="current-password"
					/>
				</label>

				<button type="submit" class="btn btn-primary btn-block">
					Sign in
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
					</svg>
				</button>
			</form>

			<p class="login-footer-msg">
				New here? <a href="/#cta">Start a free trial</a> — 3 notices on us, no card required.
			</p>
		</article>

		<aside class="login-aside">
			<p class="aside-eyebrow">LAUNCHING MAY 2026</p>
			<h2>Income Tax notices, drafted in under 30 minutes.</h2>
			<ul class="aside-list">
				<li>
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg>
					Every citation verified — or the credit returns
				</li>
				<li>
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg>
					India-resident data · SOC 2 Type II · DPDP-ready
				</li>
				<li>
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg>
					Built by DPS &amp; Co. — 45 years of CA practice
				</li>
			</ul>
		</aside>
	</div>
</PageLayout>

<style>
	.login-wrap {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3rem;
		align-items: start;
	}

	.login-card {
		background: var(--eth-surface);
		border: 1px solid var(--eth-border);
		border-radius: var(--eth-card-radius);
		padding: clamp(1.5rem, 3vw, 2.5rem);
		box-shadow: var(--eth-shadow);
	}

	.login-card h1 { font-size: clamp(1.75rem, 3vw, 2.25rem); margin: 0 0 0.35rem; }
	.login-card .muted { color: var(--eth-text-muted); margin: 0 0 1.5rem; }

	.sso { display: grid; gap: 0.5rem; margin-bottom: 1.25rem; }

	.sso-btn {
		justify-content: flex-start;
		gap: 0.6rem;
		padding-left: 1rem;
		padding-right: 1rem;
		border-radius: 9999px;
	}

	.divider {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		color: var(--eth-text-muted);
		font-size: 0.78rem;
		margin: 1rem 0 1.25rem;
	}

	.divider::before,
	.divider::after {
		content: '';
		flex: 1;
		height: 1px;
		background: var(--eth-border);
	}

	.login-form { display: grid; gap: 1rem; }

	.field { display: grid; gap: 0.4rem; }

	.field-label {
		display: flex;
		justify-content: space-between;
		font-size: 0.85rem;
		color: var(--eth-text);
		font-weight: 500;
	}

	.field-aux { font-size: 0.8rem; color: var(--eth-accent); font-weight: 500; }

	.field input {
		padding: 0.85rem 1rem;
		font-size: 0.95rem;
		font-family: inherit;
		border: 1px solid var(--eth-border);
		border-radius: 9999px;
		background: var(--eth-surface);
		color: var(--eth-text);
		min-height: 48px;
	}

	.field input:focus-visible {
		outline: 2px solid var(--eth-accent);
		outline-offset: 1px;
		border-color: transparent;
	}

	.btn-block { width: 100%; margin-top: 0.25rem; min-height: 48px; }

	.login-footer-msg {
		font-size: 0.85rem;
		color: var(--eth-text-muted);
		text-align: center;
		margin: 1.25rem 0 0;
	}

	.login-footer-msg a { color: var(--eth-accent); font-weight: 500; }

	.login-aside {
		padding: 0 0.5rem;
	}

	.aside-eyebrow {
		color: var(--eth-accent);
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 0.14em;
		margin: 0 0 0.75rem;
	}

	.login-aside h2 { font-size: clamp(1.5rem, 2.2vw, 1.85rem); letter-spacing: -0.02em; margin: 0 0 1.25rem; }

	.aside-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 0.75rem;
	}

	.aside-list li {
		display: flex;
		align-items: flex-start;
		gap: 0.65rem;
		color: var(--eth-text-secondary);
		font-size: 0.95rem;
		line-height: 1.5;
	}

	.aside-list li svg { color: var(--eth-accent); margin-top: 4px; flex-shrink: 0; }

	@media (max-width: 820px) {
		.login-wrap { grid-template-columns: 1fr; gap: 1.5rem; }
		.login-aside { order: -1; padding: 0; }
	}
</style>
