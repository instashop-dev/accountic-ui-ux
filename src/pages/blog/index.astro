---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../../consts';
import { PILLARS, type Pillar, type Tone } from '../../blog-meta';

const metaTitle = `Blog · ${SITE_TITLE}`;
const metaDescription =
	"Field notes on Income Tax notices, faceless assessment, DPDP compliance, ICAI ethics, and the craft of running a CA firm in India.";

type Post = {
	id: string;
	data: {
		title: string;
		description: string;
		pubDate: Date;
		pillar: Pillar;
		author: string;
		readTime: number;
		tone: Tone;
		featured: boolean;
	};
};

// getCollection picks up both .md and .mdx files via the content config glob pattern.
// This replaces the old import.meta.glob('*.md') which silently excluded .mdx files.
const allPosts = await getCollection('blog');

const posts: Post[] = allPosts
	.map((entry) => ({
		id: entry.id,
		data: {
			title: entry.data.title,
			description: entry.data.description,
			pubDate: entry.data.pubDate,
			pillar: entry.data.pillar,
			author: entry.data.author,
			readTime: entry.data.readTime,
			tone: entry.data.tone,
			featured: !!entry.data.featured,
		},
	}))
	.sort((a, b) => +b.data.pubDate - +a.data.pubDate);

const featured = posts.find((p) => p.data.featured) ?? posts[0];
const rest = posts.filter((p) => p.id !== featured?.id);

/* Count per pillar for the filter chips */
const pillarCounts = PILLARS.map((p) => ({
	name: p,
	count: posts.filter((x) => x.data.pillar === p).length,
}));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={metaTitle} description={metaDescription} />
	</head>
	<body>
		<Header />

		<main id="main">
			<section class="blog-hero">
				<div class="container blog-hero-inner">
					<span class="eyebrow">Field notes</span>
					<h1>Notes from the firm.</h1>
					<p class="lede">
						Practical writing on Income Tax notices, faceless assessment, DPDP, ICAI ethics,
						and the operational craft of a modern CA practice — by the founders and team
						behind Accountic.
					</p>
				</div>
			</section>

			<section class="blog-filters" aria-label="Browse by pillar">
				<div class="container filter-bar">
					<button class="filter-chip is-active" data-pillar="all" type="button">
						All posts <span class="chip-count">{posts.length}</span>
					</button>
					{pillarCounts
						.filter((p) => p.count > 0)
						.map((p) => (
							<button class="filter-chip" data-pillar={p.name} type="button">
								{p.name} <span class="chip-count">{p.count}</span>
							</button>
						))}
				</div>
			</section>

			{featured && (
				<section class="blog-featured">
					<div class="container">
						<a
							class={`featured-card featured-tone-${featured.data.tone}`}
							href={`/blog/${featured.id}/`}
							data-pillar={featured.data.pillar}
						>
							<div class="featured-copy">
								<span class="featured-badge">
									<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M12 2l3 7h7l-5.5 4.5L18 21l-6-4-6 4 1.5-7.5L2 9h7z"/>
									</svg>
									Featured
								</span>
								<span class={`featured-pillar pillar-${featured.data.tone}`}>{featured.data.pillar}</span>
								<h2>{featured.data.title}</h2>
								<p>{featured.data.description}</p>
								<div class="featured-meta">
									<span>{featured.data.author}</span>
									<span class="sep" aria-hidden="true">·</span>
									<time datetime={featured.data.pubDate.toISOString()}>
										<FormattedDate date={featured.data.pubDate} />
									</time>
									<span class="sep" aria-hidden="true">·</span>
									<span>{featured.data.readTime} min read</span>
								</div>
							</div>

							<div class={`featured-visual visual-${featured.data.tone}`} aria-hidden="true">
								<svg viewBox="0 0 300 260" width="300" height="260" fill="none" xmlns="http://www.w3.org/2000/svg">
									<rect x="40" y="40" width="220" height="180" rx="16" fill="#ffffff" stroke="#e2e8f0" stroke-width="1.2" opacity="0.95" />
									<rect x="60" y="60" width="100" height="5" rx="2.5" fill="#1e293b" />
									<rect x="60" y="74" width="180" height="3" rx="1.5" fill="#cbd5e1" />
									<rect x="60" y="82" width="160" height="3" rx="1.5" fill="#cbd5e1" />
									<rect x="60" y="90" width="175" height="3" rx="1.5" fill="#cbd5e1" />
									<rect x="60" y="110" width="60" height="18" rx="9" fill="#10b981" opacity="0.14" />
									<path d="M72 119l4 3 6-6" stroke="#10b981" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" fill="none" />
									<rect x="60" y="140" width="180" height="3" rx="1.5" fill="#cbd5e1" />
									<rect x="60" y="148" width="160" height="3" rx="1.5" fill="#cbd5e1" />
									<rect x="60" y="168" width="40" height="14" rx="7" fill="#10b981" opacity="0.14" stroke="#10b981" stroke-width="0.8" />
									<rect x="106" y="168" width="46" height="14" rx="7" fill="#10b981" opacity="0.14" stroke="#10b981" stroke-width="0.8" />
									<rect x="158" y="168" width="38" height="14" rx="7" fill="#10b981" opacity="0.14" stroke="#10b981" stroke-width="0.8" />
								</svg>
							</div>
						</a>
					</div>
				</section>
			)}

			<section class="blog-grid-section">
				<div class="container">
					<ul class="blog-grid" id="post-grid">
						{rest.map((p) => (
							<li class="post-wrap" data-pillar={p.data.pillar}>
								<a class={`post-card tone-${p.data.tone}`} href={`/blog/${p.id}/`}>
									<div class={`post-cover cover-${p.data.tone}`} aria-hidden="true">
										<span class="cover-glyph">
											<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
												<path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/>
												<path d="M14 3v6h6"/>
												<path d="M10 14h5M10 18h5M9 10h1"/>
											</svg>
										</span>
									</div>
									<div class="post-body-card">
										<span class={`post-pill pillar-${p.data.tone}`}>{p.data.pillar}</span>
										<h3>{p.data.title}</h3>
										<p>{p.data.description}</p>
										<div class="card-meta">
											<span>{p.data.author.replace(/^CA\s+/, '').split(',')[0]}</span>
											<span class="sep" aria-hidden="true">·</span>
											<time datetime={p.data.pubDate.toISOString()}>
												<FormattedDate date={p.data.pubDate} />
											</time>
											<span class="sep" aria-hidden="true">·</span>
											<span>{p.data.readTime} min</span>
										</div>
									</div>
								</a>
							</li>
						))}
					</ul>

					<p class="blog-empty" hidden>No posts in this pillar yet. Back soon.</p>
				</div>
			</section>

			<section class="blog-subscribe">
				<div class="container">
					<div class="subscribe-card" data-capture data-source="blog-subscribe" data-endpoint="/api/capture">
						<div class="subscribe-form-state" data-state="form">
							<span class="eyebrow">Subscribe</span>
							<h2>Notes from the front line of notice drafting.</h2>
							<p>Written for practicing CAs. Income Tax notice drafting, DPDP, ICAI ethics, and the operational craft of running a firm. No recycled tax-law explainers.</p>
							<form class="subscribe-form" data-capture-form novalidate>
								<label class="sr-only" for="subscribe-email">Work email</label>
								<input id="subscribe-email" name="email" type="email" placeholder="firm-email@yourca.in" required autocomplete="email" />
								<button type="submit" class="btn btn-primary">Subscribe</button>
							</form>
							<p class="subscribe-error" data-capture-error role="alert" hidden>Please enter a valid work email.</p>
							<p class="subscribe-fine">Unsubscribe any time. We'll never share your email.</p>
						</div>

						<div class="subscribe-thanks" data-state="thanks" hidden>
							<div class="thanks-icon" aria-hidden="true">
								<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
							</div>
							<h2>You're subscribed.</h2>
							<p>We received <strong data-capture-email>your email</strong>. The next note lands in your inbox on a Tuesday.</p>
						</div>
					</div>
				</div>
			</section>
		</main>

		<Footer />

		<style>
			.blog-hero {
				position: relative;
				padding: 9rem 0 3rem;
				background-color: var(--eth-bg);
				background-image:
					linear-gradient(180deg, transparent 0%, transparent 55%, var(--eth-bg) 100%),
					radial-gradient(ellipse 60% 50% at 20% 30%, rgba(253, 230, 138, 0.45) 0%, transparent 100%),
					radial-gradient(ellipse 55% 45% at 85% 20%, rgba(249, 168, 212, 0.35) 0%, transparent 100%),
					radial-gradient(ellipse 50% 40% at 60% 70%, rgba(147, 197, 253, 0.3) 0%, transparent 100%);
			}

			.blog-hero-inner { max-width: 720px; }

			.blog-hero h1 {
				margin: 0.75rem 0 1rem;
				font-size: clamp(2.25rem, 5vw, 3.5rem);
			}

			.blog-hero .lede {
				font-size: clamp(1rem, 1.6vw, 1.125rem);
				color: var(--eth-text-secondary);
				max-width: 56ch;
				margin: 0;
			}

			/* ──────────────────────────── Filter chips */
			.blog-filters { padding: 1rem 0 var(--space-8); }

			.filter-bar {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
			}

			.filter-chip {
				display: inline-flex;
				align-items: center;
				gap: 0.45rem;
				padding: 0.5rem 0.95rem;
				background: var(--eth-surface);
				border: 1px solid var(--eth-border);
				border-radius: 9999px;
				color: var(--eth-text-secondary);
				font-family: inherit;
				font-size: 0.85rem;
				font-weight: 500;
				cursor: pointer;
				transition: background 180ms ease, color 180ms ease, border-color 180ms ease;
			}

			.filter-chip:hover { background: var(--eth-surface-alt); color: var(--eth-text); border-color: var(--eth-border-light); }

			.filter-chip.is-active {
				background: var(--eth-text);
				color: #ffffff;
				border-color: var(--eth-text);
			}

			.filter-chip.is-active .chip-count {
				background: rgba(255, 255, 255, 0.2);
				color: rgba(255, 255, 255, 0.9);
			}

			.chip-count {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				min-width: 20px;
				padding: 0 0.4rem;
				border-radius: 9999px;
				background: var(--eth-surface-alt);
				color: var(--eth-text-muted);
				font-size: 0.72rem;
				font-variant-numeric: tabular-nums;
			}

			/* ──────────────────────────── Featured card */
			.blog-featured { padding: 0 0 var(--space-12); }

			.featured-card {
				display: grid;
				grid-template-columns: 1.3fr 1fr;
				gap: 0;
				background: var(--eth-surface);
				border: 1px solid var(--eth-border);
				border-radius: var(--eth-layout-radius);
				overflow: hidden;
				box-shadow: var(--eth-shadow);
				color: var(--eth-text);
				transition: transform 200ms ease, box-shadow 200ms ease;
			}

			.featured-card:hover {
				transform: translateY(-2px);
				box-shadow: 0 40px 80px -20px rgba(0, 0, 0, 0.08);
				color: var(--eth-text);
			}

			.featured-copy {
				padding: clamp(1.75rem, 4vw, 2.75rem);
				display: flex;
				flex-direction: column;
				justify-content: center;
			}

			.featured-badge {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				align-self: flex-start;
				padding: 0.3rem 0.7rem;
				background: var(--eth-accent-soft);
				color: var(--eth-accent-hover);
				border-radius: 9999px;
				font-size: 0.7rem;
				font-weight: 600;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				margin-bottom: 0.75rem;
			}

			.featured-pillar {
				display: inline-block;
				align-self: flex-start;
				font-size: 0.72rem;
				font-weight: 600;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				padding: 0.3rem 0.75rem;
				border-radius: 9999px;
				margin-bottom: 1rem;
			}

			.pillar-emerald { background: rgba(16, 185, 129, 0.14); color: #065f46; }
			.pillar-amber   { background: rgba(245, 158, 11, 0.16); color: #78350f; }
			.pillar-rose    { background: rgba(244, 114, 182, 0.16); color: #9d174d; }
			.pillar-sky     { background: rgba(59, 130, 246, 0.14); color: #1e40af; }
			.pillar-violet  { background: rgba(139, 92, 246, 0.14); color: #5b21b6; }
			.pillar-stone   { background: rgba(100, 116, 139, 0.14); color: #334155; }

			.featured-card h2 {
				font-size: clamp(1.5rem, 2.6vw, 2rem);
				font-weight: 600;
				letter-spacing: -0.02em;
				line-height: 1.2;
				margin: 0 0 0.75rem;
				max-width: 20ch;
			}

			.featured-card p {
				color: var(--eth-text-secondary);
				line-height: 1.65;
				margin: 0 0 1.25rem;
				max-width: 52ch;
			}

			.featured-meta {
				font-size: 0.85rem;
				color: var(--eth-text-muted);
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem;
				align-items: center;
			}

			.featured-meta .sep { color: var(--eth-border-light); }

			.featured-visual {
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 1.5rem;
			}

			.visual-emerald { background: linear-gradient(135deg, #d1fae5 0%, #dbeafe 100%); }
			.visual-amber   { background: linear-gradient(135deg, #fef3c7 0%, #fce7f3 100%); }
			.visual-rose    { background: linear-gradient(135deg, #fce7f3 0%, #fef3c7 100%); }
			.visual-sky     { background: linear-gradient(135deg, #dbeafe 0%, #fce7f3 100%); }
			.visual-violet  { background: linear-gradient(135deg, #ede9fe 0%, #fce7f3 100%); }
			.visual-stone   { background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%); }

			.featured-visual svg { width: 100%; height: auto; max-width: 320px; }

			@media (max-width: 820px) {
				.featured-card { grid-template-columns: 1fr; }
				.featured-visual { order: -1; aspect-ratio: 16 / 9; padding: 1rem; }
			}

			/* ──────────────────────────── Grid */
			.blog-grid-section { padding: 0 0 var(--space-16); }

			.blog-grid {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.25rem;
			}

			.post-card {
				display: flex;
				flex-direction: column;
				background: var(--eth-surface);
				border: 1px solid var(--eth-border);
				border-radius: 1.5rem;
				overflow: hidden;
				box-shadow: var(--eth-shadow-sm);
				color: var(--eth-text);
				transition: transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease;
				height: 100%;
			}

			.post-card:hover {
				transform: translateY(-3px);
				box-shadow: var(--eth-shadow);
				border-color: var(--eth-border-light);
				color: var(--eth-text);
			}

			.post-cover {
				aspect-ratio: 16 / 9;
				display: flex;
				align-items: center;
				justify-content: center;
				color: var(--eth-text);
				position: relative;
			}

			.cover-emerald { background: linear-gradient(135deg, #d1fae5 0%, #dbeafe 100%); color: #065f46; }
			.cover-amber   { background: linear-gradient(135deg, #fef3c7 0%, #fce7f3 100%); color: #78350f; }
			.cover-rose    { background: linear-gradient(135deg, #fce7f3 0%, #fef3c7 100%); color: #9d174d; }
			.cover-sky     { background: linear-gradient(135deg, #dbeafe 0%, #fce7f3 100%); color: #1e40af; }
			.cover-violet  { background: linear-gradient(135deg, #ede9fe 0%, #fce7f3 100%); color: #5b21b6; }
			.cover-stone   { background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%); color: #334155; }

			.cover-glyph {
				width: 56px;
				height: 56px;
				border-radius: 9999px;
				background: rgba(255, 255, 255, 0.55);
				display: inline-flex;
				align-items: center;
				justify-content: center;
				backdrop-filter: blur(10px);
				-webkit-backdrop-filter: blur(10px);
			}

			.post-body-card {
				padding: 1.25rem 1.5rem 1.5rem;
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
				flex: 1;
			}

			.post-pill {
				align-self: flex-start;
				font-size: 0.68rem;
				font-weight: 600;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				padding: 0.3rem 0.65rem;
				border-radius: 9999px;
				margin-bottom: 0.1rem;
			}

			.post-card h3 {
				font-size: 1.1rem;
				font-weight: 600;
				letter-spacing: -0.015em;
				line-height: 1.3;
				margin: 0;
				color: var(--eth-text);
			}

			.post-card p {
				margin: 0;
				font-size: 0.9rem;
				line-height: 1.55;
				color: var(--eth-text-secondary);
				display: -webkit-box;
				-webkit-line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.card-meta {
				margin-top: auto;
				padding-top: 0.6rem;
				font-size: 0.8rem;
				color: var(--eth-text-muted);
				display: flex;
				flex-wrap: wrap;
				gap: 0.35rem;
				align-items: center;
			}

			.card-meta .sep { color: var(--eth-border-light); }

			.blog-empty {
				text-align: center;
				color: var(--eth-text-muted);
				padding: var(--space-12) 0;
				font-size: 0.95rem;
			}

			@media (max-width: 900px) {
				.blog-grid { grid-template-columns: repeat(2, 1fr); }
			}

			@media (max-width: 560px) {
				.blog-grid { grid-template-columns: 1fr; }
			}

			/* ──────────────────────────── Subscribe */
			.blog-subscribe { padding: var(--space-12) 0 var(--space-20); }

			.subscribe-card {
				background-color: var(--eth-bg);
				background-image:
					radial-gradient(ellipse 70% 55% at 25% 40%, rgba(253, 230, 138, 0.4) 0%, transparent 100%),
					radial-gradient(ellipse 60% 50% at 75% 60%, rgba(147, 197, 253, 0.3) 0%, transparent 100%);
				border: 1px solid rgba(255, 255, 255, 0.55);
				border-radius: var(--eth-layout-radius);
				padding: clamp(1.75rem, 4vw, 2.75rem);
				text-align: center;
				box-shadow: var(--eth-shadow);
			}

			.subscribe-card .eyebrow { color: var(--eth-accent); }
			.subscribe-card h2 { margin: 0.5rem auto 0.5rem; max-width: 18ch; }
			.subscribe-card p { color: var(--eth-text-secondary); max-width: 50ch; margin: 0 auto 1.25rem; }

			.subscribe-form {
				display: flex;
				gap: 0.5rem;
				max-width: 440px;
				margin: 0 auto 0.6rem;
			}

			.subscribe-form input {
				flex: 1;
				padding: 0.85rem 1.1rem;
				font-size: 0.95rem;
				font-family: inherit;
				border: 1px solid var(--eth-border);
				border-radius: 9999px;
				background: var(--eth-surface);
				color: var(--eth-text);
				min-height: 48px;
			}

			.subscribe-form input::placeholder { color: var(--eth-text-muted); }
			.subscribe-form .btn { min-height: 48px; }

			.subscribe-error { color: #b91c1c; font-size: 0.85rem; margin: 0.25rem 0; }
			.subscribe-fine { font-size: 0.8rem; color: var(--eth-text-muted); margin: 0.5rem 0 0; }

			.subscribe-thanks { display: flex; flex-direction: column; align-items: center; gap: 0.25rem; }
			.thanks-icon {
				width: 54px;
				height: 54px;
				border-radius: 9999px;
				background: var(--eth-accent-soft);
				color: var(--eth-accent);
				display: inline-flex;
				align-items: center;
				justify-content: center;
				margin-bottom: 0.5rem;
			}
			.subscribe-thanks h2 { margin: 0.25rem 0 0.5rem; }
			.subscribe-thanks strong { color: var(--eth-text); font-weight: 600; }

			@media (max-width: 560px) {
				.subscribe-form { flex-direction: column; }
			}
		</style>

		<script is:inline>
			(function () {
				const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

				/* Pillar filter */
				const chips = document.querySelectorAll('.filter-chip');
				const grid = document.getElementById('post-grid');
				const empty = document.querySelector('.blog-empty');
				if (chips.length && grid) {
					chips.forEach((chip) => {
						chip.addEventListener('click', function () {
							const pillar = chip.getAttribute('data-pillar');
							chips.forEach((c) => c.classList.toggle('is-active', c === chip));
							let visible = 0;
							grid.querySelectorAll('.post-wrap').forEach((li) => {
								const match = pillar === 'all' || li.getAttribute('data-pillar') === pillar;
								li.hidden = !match;
								if (match) visible++;
							});
							if (empty) empty.hidden = visible > 0;
						});
					});
				}

				/* Subscribe capture */
				function storeCapture(email, source) {
					try {
						const key = 'accountic:captures';
						const existing = JSON.parse(localStorage.getItem(key) || '[]');
						existing.push({ email, source, at: new Date().toISOString() });
						localStorage.setItem(key, JSON.stringify(existing));
					} catch (_) {}
				}

				document.querySelectorAll('[data-capture]').forEach((card) => {
					const form = card.querySelector('[data-capture-form]');
					if (!form) return;
					const err = card.querySelector('[data-capture-error]');
					const emailOut = card.querySelector('[data-capture-email]');
					const formState = card.querySelector('[data-state="form"]');
					const thanksState = card.querySelector('[data-state="thanks"]');

					form.addEventListener('submit', function (event) {
						event.preventDefault();
						const input = form.querySelector('input[type="email"]');
						const email = (input && input.value || '').trim();
						if (!EMAIL_RE.test(email)) {
							if (err) err.hidden = false;
							input && input.focus();
							return;
						}
						if (err) err.hidden = true;
						storeCapture(email, card.dataset.source || 'blog');
						if (emailOut) emailOut.textContent = email;
						if (formState) formState.hidden = true;
						if (thanksState) thanksState.hidden = false;
					});
				});
			})();
		</script>
	</body>
</html>
