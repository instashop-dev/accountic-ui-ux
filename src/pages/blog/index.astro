---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../../consts';
import { PILLARS, type Pillar, type Tone } from '../../blog-meta';

const metaTitle = `Blog · ${SITE_TITLE}`;
const metaDescription =
	"Field notes on Income Tax notices, faceless assessment, DPDP compliance, ICAI ethics, and the craft of running a CA firm in India.";

type Post = {
	id: string;
	data: {
		title: string;
		description: string;
		pubDate: Date;
		pillar: Pillar;
		author: string;
		readTime: number;
		tone: Tone;
		featured: boolean;
	};
};

// getCollection picks up both .md and .mdx files via the content config glob pattern.
// This replaces the old import.meta.glob('*.md') which silently excluded .mdx files.
const allPosts = await getCollection('blog');

const posts: Post[] = allPosts
	.map((entry) => ({
		id: entry.id,
		data: {
			title: entry.data.title,
			description: entry.data.description,
			pubDate: entry.data.pubDate,
			pillar: entry.data.pillar,
			author: entry.data.author,
			readTime: entry.data.readTime,
			tone: entry.data.tone,
			featured: !!entry.data.featured,
		},
	}))
	.sort((a, b) => +b.data.pubDate - +a.data.pubDate);

const featured = posts.find((p) => p.data.featured) ?? posts[0];
const rest = posts.filter((p) => p.id !== featured?.id);

/* Count per pillar for the filter chips */
const pillarCounts = PILLARS.map((p) => ({
	name: p,
	count: posts.filter((x) => x.data.pillar === p).length,
}));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={metaTitle} description={metaDescription} />
	</head>
	<body>
		<Header />

		<main id="main">
			<section class="blog-hero">
				<div class="container blog-hero-inner">
					<span class="eyebrow">Field notes</span>
					<h1>Notes from the firm.</h1>
					<p class="lede">
						Practical writing on Income Tax notices, faceless assessment, DPDP, ICAI ethics,
						and the operational craft of a modern CA practice — by the founders and team
						behind Accountic.
					</p>
				</div>
			</section>

			<section class="blog-filters" aria-label="Browse by pillar">
				<div class="container filter-bar">
					<button class="filter-chip is-active" data-pillar="all" type="button">
						All posts <span class="chip-count">{posts.length}</span>
					</button>
					{pillarCounts
						.filter((p) => p.count > 0)
						.map((p) => (
							<button class="filter-chip" data-pillar={p.name} type="button">
								{p.name} <span class="chip-count">{p.count}</span>
							</button>
						))}
				</div>
			</section>

			{featured && (
				<section class="blog-featured">
					<div class="container">
						<a
							class={`featured-card featured-tone-${featured.data.tone}`}
							href={`/blog/${featured.id}/`}
							data-pillar={featured.data.pillar}
						>
							<div class="featured-copy">
								<span class="featured-badge">
									<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M12 2l3 7h7l-5.5 4.5L18 21l-6-4-6 4 1.5-7.5L2 9h7z"/>
									</svg>
									Featured
								</span>
								<span class={`featured-pillar pillar-${featured.data.tone}`}>{featured.data.pillar}</span>
								<h2>{featured.data.title}</h2>
								<p>{featured.data.description}</p>
								<div class="featured-meta">
									<span>{featured.data.author}</span>
									<span class="sep" aria-hidden="true">·</span>
									<time datetime={featured.data.pubDate.toISOString()}>
										<FormattedDate date={featured.data.pubDate} />
									</time>
									<span class="sep" aria-hidden="true">·</span>
									<span>{featured.data.readTime} min read</span>
								</div>
							</div>

							<div class={`featured-visual visual-${featured.data.tone}`} aria-hidden="true">
								<svg viewBox="0 0 300 260" width="300" height="260" fill="none" xmlns="http://www.w3.org/2000/svg">
									<rect x="40" y="40" width="220" height="180" rx="10" fill="currentColor" opacity="0.05" />
										<rect x="40" y="40" width="220" height="180" rx="10" fill="none" stroke="currentColor" stroke-width="1" opacity="0.22" />
									<rect x="60" y="60" width="100" height="5" rx="2" fill="currentColor" opacity="0.85" />
									<rect x="60" y="74" width="180" height="3" rx="1.5" fill="currentColor" opacity="0.28" />
									<rect x="60" y="82" width="160" height="3" rx="1.5" fill="currentColor" opacity="0.28" />
									<rect x="60" y="90" width="175" height="3" rx="1.5" fill="currentColor" opacity="0.28" />
									<rect x="60" y="110" width="60" height="18" rx="4" fill="currentColor" opacity="0.14" style="color: var(--color-accent)" />
									<path d="M72 119l4 3 6-6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" fill="none" style="color: var(--color-accent)" />
									<rect x="60" y="140" width="180" height="3" rx="1.5" fill="currentColor" opacity="0.28" />
									<rect x="60" y="148" width="160" height="3" rx="1.5" fill="currentColor" opacity="0.28" />
									<rect x="60" y="168" width="40" height="14" rx="4" fill="currentColor" opacity="0.14" stroke="currentColor" stroke-width="0.8" />
									<rect x="106" y="168" width="46" height="14" rx="4" fill="currentColor" opacity="0.14" stroke="currentColor" stroke-width="0.8" />
									<rect x="158" y="168" width="38" height="14" rx="4" fill="currentColor" opacity="0.14" stroke="currentColor" stroke-width="0.8" />
								</svg>
							</div>
						</a>
					</div>
				</section>
			)}

			<section class="blog-grid-section">
				<div class="container">
					<ul class="blog-grid" id="post-grid">
						{rest.map((p) => (
							<li class="post-wrap" data-pillar={p.data.pillar}>
								<a class={`post-card tone-${p.data.tone}`} href={`/blog/${p.id}/`}>
									<div class={`post-cover cover-${p.data.tone}`} aria-hidden="true">
										<span class="cover-glyph">
											<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
												<path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/>
												<path d="M14 3v6h6"/>
												<path d="M10 14h5M10 18h5M9 10h1"/>
											</svg>
										</span>
									</div>
									<div class="post-body-card">
										<span class={`post-pill pillar-${p.data.tone}`}>{p.data.pillar}</span>
										<h3>{p.data.title}</h3>
										<p>{p.data.description}</p>
										<div class="card-meta">
											<span>{p.data.author.replace(/^CA\s+/, '').split(',')[0]}</span>
											<span class="sep" aria-hidden="true">·</span>
											<time datetime={p.data.pubDate.toISOString()}>
												<FormattedDate date={p.data.pubDate} />
											</time>
											<span class="sep" aria-hidden="true">·</span>
											<span>{p.data.readTime} min</span>
										</div>
									</div>
								</a>
							</li>
						))}
					</ul>

					<p class="blog-empty" hidden>No posts in this pillar yet. Back soon.</p>
				</div>
			</section>

			<section class="blog-subscribe">
				<div class="container">
					<div class="subscribe-card" data-capture data-source="blog-subscribe" data-endpoint="/api/capture">
						<div class="subscribe-form-state" data-state="form">
							<span class="eyebrow">Subscribe</span>
							<h2>Notes from the front line of notice drafting.</h2>
							<p>Written for practicing CAs. Income Tax notice drafting, DPDP, ICAI ethics, and the operational craft of running a firm. No recycled tax-law explainers.</p>
							<form class="subscribe-form" data-capture-form novalidate>
								<label class="sr-only" for="subscribe-email">Work email</label>
								<input id="subscribe-email" name="email" type="email" placeholder="firm-email@yourca.in" required autocomplete="email" />
								<button type="submit" class="btn btn-primary">Subscribe</button>
							</form>
							<p class="subscribe-error" data-capture-error role="alert" hidden>Please enter a valid work email.</p>
							<p class="subscribe-fine">Unsubscribe any time. We'll never share your email.</p>
						</div>

						<div class="subscribe-thanks" data-state="thanks" hidden>
							<div class="thanks-icon" aria-hidden="true">
								<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
							</div>
							<h2>You're subscribed.</h2>
							<p>We received <strong data-capture-email>your email</strong>. The next note lands in your inbox on a Tuesday.</p>
						</div>
					</div>
				</div>
			</section>
		</main>

		<Footer />

		<style>
			.blog-hero {
				padding: 9rem 0 var(--space-2xl);
				background: var(--color-paper);
				border-bottom: 1px solid var(--color-rule);
			}

			.blog-hero-inner { max-width: 720px; }

			.blog-hero h1 {
				margin: var(--space-sm) 0 var(--space-md);
				font-family: var(--font-display);
				font-style: normal;
				font-size: clamp(2.25rem, 5vw, 3.5rem);
			}

			.blog-hero .lede {
				font-size: clamp(1rem, 1.6vw, 1.125rem);
				color: var(--color-ink-3);
				max-width: 56ch;
				margin: 0;
			}

			/* ──────────────────────────── Filter chips */
			.blog-filters { padding: var(--space-md) 0 var(--space-xl); }

			.filter-bar {
				display: flex;
				flex-wrap: wrap;
				gap: var(--space-xs);
			}

			.filter-chip {
				display: inline-flex;
				align-items: center;
				gap: var(--space-xs);
				min-height: 44px;
				padding: var(--space-xs) var(--space-sm);
				background: var(--color-paper);
				border: 1px solid var(--color-rule);
				border-radius: var(--radius-pill);
				color: var(--color-ink-3);
				font-family: var(--font-mono);
				font-size: var(--text-xs);
				letter-spacing: var(--tracking-label);
				text-transform: uppercase;
				white-space: nowrap;
				cursor: pointer;
				transition: background-color var(--dur-1) var(--ease-out), color var(--dur-1) var(--ease-out), border-color var(--dur-1) var(--ease-out);
			}

			.filter-chip:hover { background: var(--color-paper-2); color: var(--color-ink); border-color: var(--color-rule-2); }

			.filter-chip.is-active {
				background: var(--color-ink);
				color: var(--color-paper);
				border-color: var(--color-ink);
			}

			.filter-chip.is-active .chip-count {
				background: color-mix(in oklab, var(--color-paper) 22%, transparent);
				color: var(--color-paper);
			}

			.chip-count {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				min-width: 20px;
				padding: 0 var(--space-2xs);
				border-radius: var(--radius-pill);
				background: var(--color-paper-3);
				color: var(--color-ink-4);
				font-size: var(--text-2xs);
				font-variant-numeric: tabular-nums;
			}

			/* ──────────────────────────── Featured card */
			.blog-featured { padding: 0 0 var(--space-2xl); }

			.featured-card {
				display: grid;
				grid-template-columns: minmax(0, 1.3fr) minmax(0, 1fr);
				gap: 0;
				background: var(--color-paper);
				border: 1px solid var(--color-rule);
				border-radius: var(--radius-lg);
				overflow: hidden;
				color: var(--color-ink);
				transition: border-color var(--dur-1) var(--ease-out);
			}

			.featured-card:hover {
				border-color: var(--color-rule-2);
				color: var(--color-ink);
			}

			.featured-copy {
				padding: clamp(var(--space-lg), 4vw, var(--space-2xl));
				display: flex;
				flex-direction: column;
				justify-content: center;
			}

			.featured-badge {
				display: inline-flex;
				align-items: center;
				gap: var(--space-xs);
				align-self: flex-start;
				padding: var(--space-2xs) var(--space-xs);
				background: var(--color-accent-soft);
				color: var(--color-accent-2);
				border-radius: var(--radius-pill);
				font-family: var(--font-mono);
				font-size: var(--text-xs);
				letter-spacing: var(--tracking-label);
				text-transform: uppercase;
				margin-bottom: var(--space-sm);
			}

			.featured-pillar {
				display: inline-block;
				align-self: flex-start;
				font-family: var(--font-mono);
				font-size: var(--text-xs);
				letter-spacing: var(--tracking-label);
				text-transform: uppercase;
				color: var(--color-ink-4);
				margin-bottom: var(--space-md);
			}

			.featured-card h2 {
				font-family: var(--font-display);
				font-style: normal;
				font-size: clamp(1.5rem, 2.6vw, 2rem);
				font-weight: 600;
				letter-spacing: var(--tracking-snug);
				line-height: 1.2;
				margin: 0 0 var(--space-sm);
				max-width: 20ch;
			}

			.featured-card p {
				color: var(--color-ink-3);
				font-size: var(--text-body);
				line-height: 1.65;
				margin: 0 0 var(--space-lg);
				max-width: 52ch;
			}

			.featured-meta {
				font-family: var(--font-mono);
				font-size: var(--text-xs);
				letter-spacing: var(--tracking-label);
				text-transform: uppercase;
				color: var(--color-ink-4);
				display: flex;
				flex-wrap: wrap;
				gap: var(--space-xs);
				align-items: center;
			}

			.featured-meta .sep { color: var(--color-rule-2); }

			.featured-visual {
				display: flex;
				align-items: center;
				justify-content: center;
				padding: var(--space-lg);
				background: var(--color-paper-2);
				border-left: 1px solid var(--color-rule);
				color: var(--color-ink-3);
			}

			.featured-visual svg { width: 100%; height: auto; max-width: 320px; }

			@media (max-width: 820px) {
				.featured-card { grid-template-columns: 1fr; }
				.featured-visual { order: -1; aspect-ratio: 16 / 9; padding: var(--space-md); border-left: none; border-bottom: 1px solid var(--color-rule); }
			}

			/* ──────────────────────────── Grid */
			.blog-grid-section { padding: 0 0 var(--space-3xl); }

			.blog-grid {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: var(--space-xl);
			}

			.post-card {
				display: flex;
				flex-direction: column;
				background: var(--color-paper);
				border: 1px solid var(--color-rule);
				border-radius: var(--radius-lg);
				overflow: hidden;
				color: var(--color-ink);
				transition: border-color var(--dur-1) var(--ease-out);
				height: 100%;
			}

			.post-card:hover {
				border-color: var(--color-rule-2);
				color: var(--color-ink);
			}

			.post-cover {
				aspect-ratio: 16 / 9;
				display: flex;
				align-items: center;
				justify-content: center;
				color: var(--color-ink-3);
				background: var(--color-paper-2);
				border-bottom: 1px solid var(--color-rule);
				position: relative;
			}

			.cover-glyph {
				width: 48px;
				height: 48px;
				border-radius: var(--radius-md);
				background: var(--color-paper);
				border: 1px solid var(--color-rule);
				display: inline-flex;
				align-items: center;
				justify-content: center;
				color: var(--color-ink-3);
			}

			.post-body-card {
				padding: var(--space-lg) var(--space-lg) var(--space-lg);
				display: flex;
				flex-direction: column;
				gap: var(--space-xs);
				flex: 1;
			}

			.post-pill {
				align-self: flex-start;
				font-family: var(--font-mono);
				font-size: var(--text-xs);
				letter-spacing: var(--tracking-label);
				text-transform: uppercase;
				color: var(--color-ink-4);
				margin-bottom: var(--space-3xs);
			}

			.post-card h3 {
				font-family: var(--font-display);
				font-style: normal;
				font-size: var(--text-lg);
				font-weight: 600;
				letter-spacing: var(--tracking-snug);
				line-height: 1.3;
				margin: 0;
				color: var(--color-ink);
			}

			.post-card p {
				margin: 0;
				font-size: var(--text-body);
				line-height: 1.55;
				color: var(--color-ink-3);
				display: -webkit-box;
				-webkit-line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.card-meta {
				margin-top: auto;
				padding-top: var(--space-xs);
				font-family: var(--font-mono);
				font-size: var(--text-xs);
				letter-spacing: var(--tracking-label);
				text-transform: uppercase;
				color: var(--color-ink-4);
				display: flex;
				flex-wrap: wrap;
				gap: var(--space-2xs);
				align-items: center;
			}

			.card-meta .sep { color: var(--color-rule-2); }

			.blog-empty {
				text-align: center;
				color: var(--color-ink-4);
				padding: var(--space-2xl) 0;
				font-size: var(--text-base);
			}

			@media (max-width: 900px) {
				.blog-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
			}

			@media (max-width: 560px) {
				.blog-grid { grid-template-columns: 1fr; }
			}

			/* ──────────────────────────── Subscribe */
			.blog-subscribe { padding: var(--space-2xl) 0 var(--space-4xl); }

			.subscribe-card {
				background: var(--color-paper-2);
				border: 1px solid var(--color-rule);
				border-radius: var(--radius-lg);
				padding: clamp(var(--space-lg), 4vw, var(--space-2xl));
				text-align: center;
			}

			.subscribe-card h2 { margin: var(--space-xs) auto var(--space-xs); max-width: 18ch; }
			.subscribe-card p { color: var(--color-ink-3); max-width: 50ch; margin: 0 auto var(--space-lg); }

			.subscribe-form {
				display: flex;
				gap: var(--space-xs);
				max-width: 440px;
				margin: 0 auto var(--space-xs);
			}

			.subscribe-form input {
				flex: 1;
				padding: var(--space-sm) var(--space-md);
				font-size: var(--text-base);
				font-family: var(--font-sans);
				border: 1px solid var(--color-border-control);
				border-radius: var(--radius-sm);
				background: var(--color-paper);
				color: var(--color-ink);
				min-height: 48px;
			}

			.subscribe-form input::placeholder { color: var(--color-ink-4); }
			.subscribe-form .btn { min-height: 48px; }

			.subscribe-error { color: var(--color-danger); font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: var(--tracking-label); margin: var(--space-2xs) 0; }
			.subscribe-fine { font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: var(--tracking-label); color: var(--color-ink-4); margin: var(--space-xs) 0 0; }

			.subscribe-thanks { display: flex; flex-direction: column; align-items: center; gap: var(--space-2xs); }
			.thanks-icon {
				width: 52px;
				height: 52px;
				border-radius: var(--radius-md);
				background: var(--color-accent-soft);
				color: var(--color-accent);
				display: inline-flex;
				align-items: center;
				justify-content: center;
				margin-bottom: var(--space-xs);
			}
			.subscribe-thanks h2 { margin: var(--space-2xs) 0 var(--space-xs); }
			.subscribe-thanks strong { color: var(--color-ink); font-weight: 600; }

			@media (max-width: 560px) {
				.subscribe-form { flex-direction: column; }
			}
			</style>

		<script is:inline>
			(function () {
				const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

				/* Pillar filter */
				const chips = document.querySelectorAll('.filter-chip');
				const grid = document.getElementById('post-grid');
				const empty = document.querySelector('.blog-empty');
				if (chips.length && grid) {
					chips.forEach((chip) => {
						chip.addEventListener('click', function () {
							const pillar = chip.getAttribute('data-pillar');
							chips.forEach((c) => c.classList.toggle('is-active', c === chip));
							let visible = 0;
							grid.querySelectorAll('.post-wrap').forEach((li) => {
								const match = pillar === 'all' || li.getAttribute('data-pillar') === pillar;
								li.hidden = !match;
								if (match) visible++;
							});
							if (empty) empty.hidden = visible > 0;
						});
					});
				}

				/* Subscribe capture */
				function storeCapture(email, source) {
					try {
						const key = 'accountic:captures';
						const existing = JSON.parse(localStorage.getItem(key) || '[]');
						existing.push({ email, source, at: new Date().toISOString() });
						localStorage.setItem(key, JSON.stringify(existing));
					} catch (_) {}
				}

				document.querySelectorAll('[data-capture]').forEach((card) => {
					const form = card.querySelector('[data-capture-form]');
					if (!form) return;
					const err = card.querySelector('[data-capture-error]');
					const emailOut = card.querySelector('[data-capture-email]');
					const formState = card.querySelector('[data-state="form"]');
					const thanksState = card.querySelector('[data-state="thanks"]');

					form.addEventListener('submit', function (event) {
						event.preventDefault();
						const input = form.querySelector('input[type="email"]');
						const email = (input && input.value || '').trim();
						if (!EMAIL_RE.test(email)) {
							if (err) err.hidden = false;
							input && input.focus();
							return;
						}
						if (err) err.hidden = true;
						storeCapture(email, card.dataset.source || 'blog');
						if (emailOut) emailOut.textContent = email;
						if (formState) formState.hidden = true;
						if (thanksState) thanksState.hidden = false;
					});
				});
			})();
		</script>
	</body>
</html>
