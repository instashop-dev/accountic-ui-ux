		chip: 'Auto-scored AR with chase emails',
		icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
	},
	{
		id: 'book-rag',
		name: 'Book Q&amp;A',
		description: 'Ask questions on the Income Tax Act 1961 &amp; 2025 and get citation-first answers grounded in statute — never hallucinated.',
		chip: 'Citation-first answers, never invented',
		icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><line x1="12" y1="7" x2="16" y2="7"/><line x1="12" y1="11" x2="16" y2="11"/><line x1="12" y1="15" x2="14" y2="15"/></svg>`,
	},
	{
		id: 'knowledge-base',
		name: 'Knowledge Base',
		description: 'Maintain your firm\'s private RAG store — case history, judgements, CBDT circulars, and Taxmann commentary — per-org isolated.',
		chip: 'Your firm’s private, isolated RAG',
		icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4.03 3-9 3S3 13.66 3 12"/><path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/></svg>`,
	},
	{
		id: 'sales-bills',
		name: 'Sales Bills',
		description: 'Generate GST-compliant invoices for your firm\'s own billing, email them to clients, and post to Tally as sales vouchers.',
		chip: 'GST invoice → Tally sales voucher',
		icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
	},
	{
		id: 'tally-agent',
		name: 'Tally Agent',
		description: 'A Windows system-tray connector that bridges Accountic cloud to your local TallyPrime instance — no manual export/import.',
		chip: 'Live bridge to your TallyPrime',
		icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
	},
];

const workflowFamilies = [
	{
		label: 'Compliance & Litigation',
		desc: 'Notices, appeals, and statute research.',
		steps: [
			'Upload a notice, appeal brief, or tax query',
			'Accountic retrieves verified case law and drafts',
			'Export on firm letterhead or push to Tally',
		],
	},
	{
		label: 'Data → Tally Automation',
		desc: 'Reconciliation, classification, and posting.',
		steps: [
			'Upload a bank statement, tradebook, or invoice',
			'Accountic classifies, reconciles, and matches',
			'Vouchers post straight into TallyPrime',
		],
	},
	{
		label: 'Firm Operations',
		desc: 'Billing, receivables, and reporting.',
		steps: [
			'Sync debtors or raise a GST sales bill',
			'Accountic scores risk and checks compliance',
			'Send chase emails or post to Tally',
		],
	},
];

const platformFeatures = [
	{
		title: 'Multi-tenant org model',
		desc: 'Owner / Admin / Member roles with invite flow. Every firm\'s data is fully isolated — no cross-org retrieval is possible by construction.',
		icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
	},
	{
		title: 'Credit billing — 1 credit = ₹1',
		desc: 'Credits are debited before work begins. Automatic HTTP 402 if insufficient; full refund on system failure. Top-ups available any time.',
		icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>`,
	},
	{
		title: 'LLM observability via Langfuse',
		desc: 'Every LLM call is traced end-to-end. Admins see spend per org, per module, per document — full auditability, no black box.',
		icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
	},
	{
		title: 'OTP auth via SMS (MSG91)',
		desc: 'No password to remember or leak. SMS OTP signup keeps access tied to the practitioner\'s mobile number.',
		icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>`,
	},
	{
		title: 'Real-time collaborative editing',
		desc: 'WebSocket-powered live sync on notice drafts via PieSocket. Multiple users can review and annotate the same draft simultaneously.',
		icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
	},
	{
		title: 'Super Admin console',
		desc: 'Cross-org usage and cost dashboards, user impersonation for support, credit overrides, and full org management in one place.',
		icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>`,
	},
];

const stats = [
	{ value: '14', label: 'Live workflows · 20+ in development' },
	{ value: '0', label: 'Hallucinated citations, by design' },
	{ value: '45 yrs', label: 'Of CA practice behind every rule' },
	{ value: '₹1,000', label: 'Free credits to try every module' },
