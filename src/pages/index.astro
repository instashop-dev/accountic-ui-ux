const painPoints = [
	{
		title: 'Every compliance task starts from scratch',
		desc: 'Notices, balance sheets, appeals, TDS audits — each one rebuilds the same work from zero, against a statutory deadline.',
	},
	{
		title: 'Reconciliation is still done by hand',
		desc: 'GSTR-2B, TDS, bank statements, broker tradebooks — matched line by line in spreadsheets, then re-keyed into Tally one voucher at a time.',
	},
	{
		title: 'Nothing leaves an audit trail',
