				color: var(--eth-text);
				font-weight: 600;
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
			}
			.hv-io-meta em { font-size: 0.66rem; color: var(--eth-text-muted); font-style: normal; }

			.hv-io--out .hv-io-meta { margin-right: auto; }

			.hv-io-check { display: inline-flex; color: var(--eth-accent-hover); flex-shrink: 0; }

			.hv-arrow {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				color: var(--eth-accent);
				flex-shrink: 0;
			}

			.hv-foot {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 1rem;
				padding: 0.7rem 1.25rem;
				border-top: 1px solid var(--eth-border);
				background: rgba(255, 255, 255, 0.45);
			}

			.hv-stat {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				font-size: 0.72rem;
				font-weight: 500;
				color: var(--eth-text-secondary);
			}

			.hv-stat--ok { color: var(--eth-accent-hover); font-weight: 600; }
			.hv-stat--time { margin-left: auto; color: var(--eth-text-muted); }

			@media (max-width: 680px) {
				.hv-flow-row { grid-template-columns: 1fr; gap: 0.4rem; }
				.hv-arrow { transform: rotate(90deg); }
				.hv-foot { gap: 0.6rem 1rem; }
				.hv-stat--time { margin-left: 0; flex-basis: 100%; }
			}

			/* ─────────────────────────── Stats strip */
			.stats-strip {
				border-top: 1px solid var(--eth-border);
				border-bottom: 1px solid var(--eth-border);
				background: var(--eth-surface);
				padding: 2.5rem 0;
			}

			.stats-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 1rem;
				text-align: center;
			}

			.stat-item {
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 0.25rem;
				padding: 0 1rem;
				border-right: 1px solid var(--eth-border);
			}

			.stat-item:last-child { border-right: none; }

			.stat-value {
				font-size: clamp(1.75rem, 3vw, 2.25rem);
				font-weight: 600;
				letter-spacing: -0.04em;
				color: var(--eth-text);
				font-variant-numeric: tabular-nums;
			}

			.stat-label {
				font-size: 0.82rem;
				color: var(--eth-text-muted);
				font-weight: 500;
			}

			@media (max-width: 640px) {
				.stats-list { grid-template-columns: repeat(2, 1fr); }
				.stat-item:nth-child(2) { border-right: none; }
				.stat-item:nth-child(3) { border-right: 1px solid var(--eth-border); }
				.stat-item:nth-child(1),
				.stat-item:nth-child(2) { border-bottom: 1px solid var(--eth-border); padding-bottom: 1.5rem; }
				.stat-item:nth-child(3),
				.stat-item:nth-child(4) { padding-top: 1.5rem; }
			}

			/* ─────────────────────────── Sections */
			.section {
				padding: var(--space-20) 0;
			}

			.section-head {
				max-width: 680px;
				margin-bottom: var(--space-12);
				text-align: center;
				margin-inline: auto;
			}

			.section-head h2 { margin-top: 0.5rem; }

			.lede {
				font-size: 1rem;
				color: var(--eth-text-secondary);
				line-height: 1.7;
				max-width: 62ch;
				margin-inline: auto;
				margin-bottom: 0;
			}

			/* ─────────────────────────── Problem */
			.problem-section { padding-bottom: var(--space-12); }

			.pain-grid {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1rem;
			}

			.pain-card {
				padding: var(--space-8);
				border-radius: var(--eth-card-radius);
				background: var(--eth-surface);
				border: 1px solid var(--eth-border);
				display: flex;
				flex-direction: column;
				gap: 0.6rem;
			}

			.pain-icon {
				width: 44px;
				height: 44px;
				border-radius: 14px;
				background: var(--eth-surface-alt);
				color: var(--eth-text-secondary);
				display: inline-flex;
				align-items: center;
				justify-content: center;
				flex-shrink: 0;
				margin-bottom: 0.25rem;
			}

			.pain-card h3 {
				font-size: 1.05rem;
				font-weight: 600;
				letter-spacing: -0.02em;
				margin: 0;
				color: var(--eth-text);
			}

			.pain-card p {
				margin: 0;
				font-size: 0.9rem;
				color: var(--eth-text-secondary);
				line-height: 1.6;
			}

			.problem-bridge {
				margin: var(--space-12) auto 0;
				max-width: 60ch;
				text-align: center;
				font-size: 1.05rem;
				line-height: 1.6;
				color: var(--eth-text-secondary);
			}

			.problem-bridge strong { color: var(--eth-accent-hover); font-weight: 600; }

			@media (max-width: 860px) { .pain-grid { grid-template-columns: 1fr; } }

			/* ─────────────────────────── Modules grid */
			.modules-section { padding-bottom: var(--space-24); }

			.modules-head { margin-bottom: var(--space-12); }

			.modules-grid {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 1rem;
			}

			.module-card {
				display: flex;
				flex-direction: column;
				gap: 0.75rem;
				padding: var(--space-8);
				position: relative;
				transition: transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease;
			}

			.module-card:hover {
				transform: translateY(-3px);
				box-shadow: var(--eth-shadow);
				border-color: rgba(16, 185, 129, 0.18);
			}

			/* Coming-soon card — visually muted, dashed border */
			.module-card--soon {
				background: transparent;
				border: 1px dashed var(--eth-border-light);
				box-shadow: none;
			}

			.module-card--soon:hover {
				transform: translateY(-3px);
				border-color: rgba(16, 185, 129, 0.3);
				box-shadow: var(--eth-shadow-sm);
			}

			.module-icon--soon {
				background: var(--eth-surface-alt);
				color: var(--eth-text-muted);
			}

			.module-card--soon .module-name { color: var(--eth-text-secondary); }

			.module-soon-link {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				margin-top: auto;
				align-self: flex-start;
				font-size: 0.8rem;
				font-weight: 600;
				color: var(--eth-accent-hover);
			}

			.module-soon-link svg { transition: transform 200ms ease; }
			.module-soon-link:hover svg { transform: translateX(3px); }

			.module-icon {
				width: 44px;
				height: 44px;
				border-radius: 14px;
				background: var(--eth-accent-soft);
				color: var(--eth-accent);
				display: inline-flex;
				align-items: center;
				justify-content: center;
				flex-shrink: 0;
			}

			.module-name {
				font-size: 1.05rem;
				font-weight: 600;
				letter-spacing: -0.02em;
				margin: 0;
				color: var(--eth-text);
			}

			.module-desc {
				margin: 0;
				font-size: 0.9rem;
				color: var(--eth-text-secondary);
				line-height: 1.6;
				flex: 1;
			}

			.module-chip {
				display: inline-flex;
				align-self: flex-start;
				margin-top: auto;
				padding: 0.3rem 0.65rem;
				font-family: 'ui-monospace', 'SF Mono', Consolas, monospace;
				font-size: 0.68rem;
				font-weight: 600;
				letter-spacing: 0.04em;
				background: var(--eth-accent-soft);
				color: var(--eth-accent-hover);
				border: 1px solid rgba(16, 185, 129, 0.18);
				border-radius: 9999px;
			}

			@media (max-width: 1024px) {
				.modules-grid { grid-template-columns: repeat(2, 1fr); }
			}

			@media (max-width: 520px) {
				.modules-grid { grid-template-columns: 1fr; }
			}

			/* ─────────────────────────── How it works */
			.how-it-works {
				background: var(--eth-surface);
				border-top: 1px solid var(--eth-border);
				border-bottom: 1px solid var(--eth-border);
			}

			.hiw-families {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1rem;
			}

			.hiw-family {
				padding: var(--space-8);
				border-radius: var(--eth-card-radius);
				display: flex;
				flex-direction: column;
				transition: transform 200ms ease, box-shadow 200ms ease;
			}

			.hiw-family:hover {
				transform: translateY(-3px);
				box-shadow: var(--eth-shadow);
			}

			.hiw-family-label {
				font-size: 1.05rem;
				font-weight: 600;
				letter-spacing: -0.02em;
				margin: 0 0 0.35rem;
				color: var(--eth-text);
			}

			.hiw-family-desc {
				margin: 0 0 1.25rem;
				font-size: 0.88rem;
				color: var(--eth-text-muted);
				line-height: 1.5;
			}

			.hiw-family-steps {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
				gap: 0.85rem;
			}

			.hiw-family-step {
				display: flex;
				gap: 0.75rem;
				align-items: flex-start;
				font-size: 0.9rem;
				color: var(--eth-text-secondary);
				line-height: 1.5;
			}

			.hiw-family-num {
				flex-shrink: 0;
				width: 26px;
				height: 26px;
				border-radius: 9999px;
				background: var(--eth-accent-soft);
				border: 1px solid rgba(16, 185, 129, 0.25);
				color: var(--eth-accent-hover);
				font-size: 0.72rem;
				font-weight: 700;
				font-variant-numeric: tabular-nums;
				display: inline-flex;
				align-items: center;
				justify-content: center;
			}

			@media (max-width: 800px) {
				.hiw-families { grid-template-columns: 1fr; }
			}

			/* ─────────────────────────── Why Accountic */
			.why .section-head { text-align: left; margin-inline: 0; }
			.why-head { max-width: none; }

			.cv-showcase {
				background: var(--eth-showcase-gradient);
				border-radius: var(--eth-layout-radius);
				padding: clamp(1.5rem, 4vw, 3rem);
				display: grid;
				grid-template-columns: repeat(6, 1fr);
				gap: 1.25rem;
			}

			.cv-card {
				border-radius: var(--eth-card-radius);
				padding: var(--space-8);
				display: flex;
				flex-direction: column;
				transition: transform 200ms ease, box-shadow 200ms ease;
			}

			.cv-card:hover {
				transform: translateY(-3px);
				box-shadow: var(--eth-shadow);
			}

			.cv-card h3 {
				font-size: 1.25rem;
				font-weight: 500;
				letter-spacing: -0.02em;
				margin: 0 0 0.6rem;
				color: var(--eth-text);
			}

			.cv-card p { margin: 0 0 0.6rem; color: var(--eth-text-secondary); }

			.cv-card p strong { color: var(--eth-text); font-weight: 600; }

			.cv-card .cv-meta {
				margin-top: auto;
				padding-top: 0.75rem;
				border-top: 1px solid rgba(255, 255, 255, 0.6);
				color: var(--eth-text-muted);
				font-size: 0.85rem;
			}

			.card-icon {
				width: 44px;
				height: 44px;
				border-radius: 14px;
				background: var(--eth-accent-soft);
				color: var(--eth-accent);
				display: inline-flex;
				align-items: center;
				justify-content: center;
				margin-bottom: 1rem;
				flex-shrink: 0;
			}

			.glass-card {
				background: var(--eth-glass-bg);
				border: 1px solid var(--eth-glass-border);
				backdrop-filter: var(--eth-glass-blur);
				-webkit-backdrop-filter: var(--eth-glass-blur);
				box-shadow: var(--eth-shadow-sm);
			}

			.cv-hero {
				grid-column: span 4;
				background: var(--eth-surface);
				border: 1px solid var(--eth-border);
				box-shadow: var(--eth-shadow);
			}

			.cv-hero h3 { font-size: 1.6rem; }

			.cv-hero .card-icon {
				background: var(--eth-text);
				color: #ffffff;
			}

			.cv-card:not(.cv-hero) { grid-column: span 2; }

			@media (max-width: 900px) {
				.cv-showcase { grid-template-columns: repeat(2, 1fr); }
				.cv-hero { grid-column: 1 / -1; }
				.cv-card:not(.cv-hero) { grid-column: span 1; }
			}

			@media (max-width: 560px) {
				.cv-showcase { grid-template-columns: 1fr; padding: 1.25rem; }
				.cv-hero, .cv-card:not(.cv-hero) { grid-column: 1 / -1; }
			}

			/* ─────────────────────────── Platform features */
			.platform-section { background: var(--eth-bg); }
			.platform-head { margin-bottom: var(--space-12); }

			.platform-grid {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1rem;
			}

			.platform-card {
				padding: var(--space-8);
				border-radius: var(--eth-card-radius);
				display: flex;
				flex-direction: column;
				gap: 0.75rem;
				transition: transform 200ms ease, box-shadow 200ms ease;
			}

			.platform-card:hover {
				transform: translateY(-2px);
				box-shadow: var(--eth-shadow);
			}

			.platform-icon {
				width: 40px;
				height: 40px;
				border-radius: 12px;
				background: var(--eth-accent-soft);
				color: var(--eth-accent);
				display: inline-flex;
				align-items: center;
				justify-content: center;
				flex-shrink: 0;
			}

			.platform-card h3 {
				font-size: 0.95rem;
				font-weight: 600;
				letter-spacing: -0.01em;
				margin: 0;
				color: var(--eth-text);
			}

			.platform-card p {
				margin: 0;
				font-size: 0.88rem;
				color: var(--eth-text-secondary);
				line-height: 1.65;
			}

			@media (max-width: 900px) { .platform-grid { grid-template-columns: repeat(2, 1fr); } }
			@media (max-width: 560px) { .platform-grid { grid-template-columns: 1fr; } }

			/* ─────────────────────────── Pricing */
			.pricing .section-head { text-align: left; margin-inline: 0; }
			.pricing-head { max-width: none; }
			.pricing-head .lede { margin-inline: 0; max-width: 62ch; }

			.tiers {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 1rem;
			}

			.tier {
				padding: var(--space-6);
				display: flex;
				flex-direction: column;
				position: relative;
				transition: transform 200ms ease, box-shadow 200ms ease;
				background: var(--eth-surface);
				border: 1px solid var(--eth-border);
			}

			.tier:hover {
				transform: translateY(-3px);
				box-shadow: var(--eth-shadow);
			}

			.tier.featured {
				background: var(--eth-text);
				color: #ffffff;
				border-color: var(--eth-text);
				box-shadow: var(--eth-shadow);
			}

			.tier.featured .tier-name { color: rgba(255, 255, 255, 0.7); }
			.tier.featured .tier-amount { color: #ffffff; }
			.tier.featured .tier-cadence { color: rgba(255, 255, 255, 0.65); }
			.tier.featured .tier-blurb { color: rgba(255, 255, 255, 0.75); }
			.tier.featured .tier-features li { color: rgba(255, 255, 255, 0.92); }
			.tier.featured .tier-features svg { color: var(--eth-accent); }

			.tier-badge {
				position: absolute;
				top: -12px;
				right: 16px;
				background: var(--eth-accent);
				color: #fff;
				font-size: 0.68rem;
				font-weight: 600;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				padding: 0.35rem 0.65rem;
				border-radius: 9999px;
				box-shadow: 0 4px 12px rgba(16, 185, 129, 0.35);
			}

			.tier-name {
				font-size: 0.72rem;
				font-weight: 600;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: var(--eth-text-muted);
				margin: 0;
			}

			.tier-price {
				display: flex;
				align-items: baseline;
				gap: 0.35rem;
				margin: 0.5rem 0 0.25rem;
			}

			.tier-amount {
				font-size: clamp(1.75rem, 3vw, 2rem);
				font-weight: 500;
				letter-spacing: -0.03em;
				color: var(--eth-text);
				font-variant-numeric: tabular-nums;
			}

			.tier-cadence { color: var(--eth-text-muted); font-size: 0.9rem; }

			.tier-blurb {
				color: var(--eth-text-secondary);
				font-size: 0.9rem;
				margin: 0 0 1rem;
				min-height: 3em;
			}

			.tier-features {
				list-style: none;
				padding: 0;
				margin: 0 0 1.5rem;
				display: grid;
				gap: 0.55rem;
				flex: 1;
			}

			.tier-features li {
				display: flex;
				align-items: flex-start;
				gap: 0.55rem;
				color: var(--eth-text);
				font-size: 0.9rem;
			}

			.tier-features svg { color: var(--eth-accent); flex-shrink: 0; margin-top: 3px; }

			.tier .btn { width: 100%; }

			.pricing-note {
				margin-top: var(--space-8);
				text-align: center;
				font-size: 0.88rem;
				color: var(--eth-text-muted);
			}

			@media (max-width: 1000px) { .tiers { grid-template-columns: repeat(2, 1fr); } }
			@media (max-width: 560px) { .tiers { grid-template-columns: 1fr; } }

			/* ─────────────────────────── Final CTA */
			.cta-section { padding: var(--space-20) 0; }

			.cta-card {
				background-color: var(--eth-bg);
				background-image:
					linear-gradient(135deg, rgba(16, 185, 129, 0.08) 0%, transparent 60%),
					radial-gradient(ellipse 80% 60% at 20% 40%, rgba(253, 230, 138, 0.45) 0%, transparent 100%),
					radial-gradient(ellipse 70% 50% at 80% 60%, rgba(249, 168, 212, 0.35) 0%, transparent 100%),
					radial-gradient(ellipse 60% 50% at 50% 80%, rgba(147, 197, 253, 0.3) 0%, transparent 100%);
				border-radius: var(--eth-layout-radius);
				padding: clamp(2rem, 5vw, 4rem);
				text-align: center;
				border: 1px solid rgba(255, 255, 255, 0.5);
				box-shadow: var(--eth-shadow);
			}

			.cta-eyebrow { color: var(--eth-accent); }

			.cta-card h2 {
				margin: 0.5rem auto 0.75rem;
				max-width: 18ch;
				font-weight: 300;
				letter-spacing: -0.05em;
			}

			.cta-card p {
				color: var(--eth-text-secondary);
				max-width: 52ch;
				margin: 0 auto 1.5rem;
			}

			.cta-form {
				display: flex;
				gap: 0.5rem;
				max-width: 480px;
				margin-inline: auto;
			}

			.cta-form input {
				flex: 1;
				padding: 0.85rem 1.1rem;
				font-size: 0.95rem;
				font-family: inherit;
				border-radius: 9999px;
				border: 1px solid var(--eth-border);
				background: var(--eth-surface);
				color: var(--eth-text);
				min-height: 48px;
			}

			.cta-form input::placeholder { color: var(--eth-text-muted); }

			.cta-form input:focus-visible {
				outline: 2px solid var(--eth-accent);
				outline-offset: 2px;
				border-color: transparent;
			}

			.cta-form .btn { min-height: 48px; }

			.cta-error {
				margin: 0.5rem auto 0;
				max-width: 480px;
				color: #b91c1c;
				font-size: 0.85rem;
				font-weight: 500;
				text-align: left;
				padding-left: 1rem;
			}

			.cta-thanks-state {
				text-align: center;
				display: flex;
				flex-direction: column;
				align-items: center;
			}

			.cta-thanks-icon {
				width: 58px;
				height: 58px;
				border-radius: 9999px;
				background: var(--eth-accent-soft);
				color: var(--eth-accent);
				display: inline-flex;
				align-items: center;
				justify-content: center;
				margin-bottom: 1rem;
			}

			.cta-thanks-state h2 { margin: 0.35rem 0 0.75rem; max-width: 20ch; }
			.cta-thanks-state p { max-width: 52ch; color: var(--eth-text-secondary); margin: 0 auto; }
			.cta-thanks-state strong { color: var(--eth-text); font-weight: 600; }

			.cta-thanks-meta { font-size: 0.9rem; margin-top: 1rem !important; }
			.cta-thanks-meta a { color: var(--eth-accent); font-weight: 500; }

			@media (max-width: 560px) {
				.cta-form { flex-direction: column; }
			}
		</style>

		<script is:inline>
			(function () {
				const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

				function storeCapture(email, source) {
					try {
						const key = 'accountic:captures';
						const existing = JSON.parse(localStorage.getItem(key) || '[]');
						existing.push({ email, source, at: new Date().toISOString() });
						localStorage.setItem(key, JSON.stringify(existing));
					} catch (_) { /* storage unavailable — silently skip */ }
				}

				function sendCapture(email, source) {
					const card = document.querySelector(`[data-capture][data-source="${source}"]`);
					const endpoint = card && card.dataset.endpoint;
					if (!endpoint) return Promise.resolve();
					return fetch(endpoint, {
						method: 'POST',
						headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
						body: JSON.stringify({ email, source, page: location.pathname }),
					}).catch(() => {});
				}

				document.querySelectorAll('[data-capture]').forEach((card) => {
					const form = card.querySelector('[data-capture-form]');
					if (!form) return;
					const err = card.querySelector('[data-capture-error]');
					const emailOut = card.querySelector('[data-capture-email]');
					const formState = card.querySelector('[data-state="form"]');
					const thanksState = card.querySelector('[data-state="thanks"]');

					form.addEventListener('submit', function (event) {
						event.preventDefault();
						const emailInput = form.querySelector('input[type="email"]');
						const email = (emailInput && emailInput.value || '').trim();

						if (!EMAIL_RE.test(email)) {
							if (err) err.hidden = false;
							emailInput && emailInput.focus();
							return;
						}
						if (err) err.hidden = true;

						const submitBtn = form.querySelector('button[type="submit"]');
						if (submitBtn) {
							submitBtn.disabled = true;
							submitBtn.style.opacity = '0.6';
						}

						storeCapture(email, card.dataset.source || 'unknown');
						sendCapture(email, card.dataset.source || 'unknown').finally(function () {
							if (emailOut) emailOut.textContent = email;
							if (formState) formState.hidden = true;
							if (thanksState) thanksState.hidden = false;
						});
					});
				});
			})();
		</script>
	</body>
</html>
