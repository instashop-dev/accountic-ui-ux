---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const metaTitle = `${SITE_TITLE} — Income Tax notice replies in under 30 minutes`;
const metaDescription =
	'AI-powered Income Tax notice analysis and reply drafting for Indian Chartered Accountants. Every citation verified — or we return the credit. ₹200 per notice.';

const steps = [
	{ n: '01', title: 'Upload', body: 'Drop a notice PDF or scan — s. 139(9), 142(1), 143(2), 148, 245. Bulk-upload past replies to bootstrap firm memory on day one.' },
	{ n: '02', title: 'Analyse', body: 'Accountic classifies the notice and extracts section, AY, demand, deadline, and grounds raised — then surfaces applicable law and case law.' },
	{ n: '03', title: 'Draft', body: 'A reply grounded in the notice, verified IT Act + CBDT + case law, and your own prior positions. Every citation is checked before it reaches the draft.' },
	{ n: '04', title: 'Export', body: 'Clean, portal-ready output with reasoning and citation audit log. Review, refine, and file — under your name, under your judgement.' },
];

const pricingTiers = [
	{ name: 'Free trial', price: '₹0', cadence: 'one-time', blurb: '3 notices on us. No card required.', features: ['3 notices, lifetime', 'Full citation verification', 'Firm-memory upload', 'Email support'], cta: 'Start free', href: '#cta', highlight: false },
	{ name: 'Basic', price: '₹2,000', cadence: '/ month', blurb: 'For solo practitioners and small books.', features: ['10 notices / month', '₹200 effective per notice', 'Soft quota — no mid-month cutoff', 'GST invoice with your GSTIN'], cta: 'Start free trial', href: '#cta', highlight: false },
	{ name: 'Pro', price: '₹20,000', cadence: '/ month', blurb: 'For high-volume solo CAs and small firms.', features: ['100 notices / month', 'Firm-memory across clients', 'Bulk historical upload', 'Priority support'], cta: 'Start free trial', href: '#cta', highlight: true },
	{ name: 'Firm', price: 'Custom', cadence: '', blurb: 'For 5–30-professional firms.', features: ['Higher quotas + seat controls', 'Role-based access (roadmap)', 'Data Processing Agreement', 'Dedicated onboarding'], cta: 'Contact sales', href: '/contact', highlight: false },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={metaTitle} description={metaDescription} />
	</head>
	<body>
		<Header />

		<main id="main">
			{/* ─── ETHEREAL HERO ─── */}
			<section class="hero">
				<div class="container hero-inner">
					<a class="hero-badge" href="#why-accountic" aria-label="Learn about Accountic">
						<span class="badge-dot" aria-hidden="true"></span>
						<span>LAUNCHING APRIL 2026 · FOR INDIAN CAs</span>
					</a>

					<h1 class="hero-title">
						Draft an Income Tax<br/>
						notice reply in <span class="highlight-green">30 minutes</span>.<br/>
						Every citation verified.
					</h1>

					<p class="hero-subtitle">
						AI-assisted drafting grounded in verified IT&nbsp;Act references, case law, and your own prior replies. If we miss a bad citation, the credit returns — automatically.
					</p>

					<div class="hero-cta">
						<a class="btn btn-primary" href="#cta">Start free trial</a>
						<a class="btn btn-secondary" href="#how-it-works">See how it works</a>
					</div>

					<ul class="trust-badges" aria-label="Compliance and trust">
						<li>
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
								<path d="m9 12 2 2 4-4"></path>
							</svg>
							<span>SOC 2 Type II</span>
						</li>
						<li>
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<rect x="4" y="11" width="16" height="10" rx="2"></rect>
								<path d="M8 11V7a4 4 0 0 1 8 0v4"></path>
							</svg>
							<span>DPDP-ready</span>
						</li>
						<li>
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<circle cx="12" cy="12" r="9"></circle>
								<path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"></path>
							</svg>
							<span>India-resident data</span>
						</li>
						<li>
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path>
								<path d="M14 3v6h6"></path>
								<path d="m9 15 2 2 4-4"></path>
							</svg>
							<span>ICAI-aligned</span>
						</li>
						<li>
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
								<circle cx="9" cy="7" r="4"></circle>
								<path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
							</svg>
							<span>Built by CAs</span>
						</li>
					</ul>

					{/* Floating sample-reply glass card */}
					<div class="hero-card glass" aria-hidden="false">
						<div class="hc-head">
							<span class="hc-pill">Sample reply · s. 148 Reassessment</span>
							<span class="hc-status">
								<span class="status-dot"></span> Verified
							</span>
						</div>
						<div class="hc-body">
							<p class="hc-meta">AY 2021–22 · Demand ₹14.7L · Deadline 29 Apr 2026</p>
							<div class="hc-block">
								<h4>Grounds raised</h4>
								<p>Escaped income on unexplained cash credits under s.&nbsp;68 r/w s.&nbsp;148.</p>
							</div>
							<div class="hc-block">
								<h4>Citations used <span class="chips-count">4 verified · 0 flagged</span></h4>
								<ul class="hc-chips">
									<li>s. 148 IT Act, 1961</li>
									<li>CBDT Circular No. 549</li>
									<li>ITO v. Lakhmani Mewal Das (SC, 1976)</li>
									<li>Your prior reply — Rameshwar &amp; Co.</li>
								</ul>
							</div>
							<div class="hc-footer">
								<span class="hc-ok">
									<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M20 6 9 17l-5-5"></path>
									</svg>
									Citation audit log attached
								</span>
								<span class="hc-time">12m 48s</span>
							</div>
						</div>
					</div>
				</div>
			</section>

			{/* ─── STATS ─── */}
			<section class="section stats-section" aria-label="Key outcomes">
				<div class="container stats-grid">
					<div class="stat">
						<p class="stat-value">3–4h <span class="arrow">→</span> <strong>30m</strong></p>
						<p class="stat-label">Routine-notice turnaround, end-to-end</p>
					</div>
					<div class="stat">
						<p class="stat-value">&lt; <strong>1%</strong></p>
						<p class="stat-label">Target verified citation error rate</p>
					</div>
					<div class="stat">
						<p class="stat-value"><strong>₹200</strong> <span class="arrow">/ notice</span></p>
						<p class="stat-label">No per-seat fees. GST-compliant Indian billing.</p>
					</div>
				</div>
			</section>

			{/* ─── SEE IT IN ACTION — diptych ─── */}
			<section class="section action" aria-labelledby="action-title">
				<div class="container">
					<div class="section-head action-head">
						<span class="eyebrow">See it in action</span>
						<h2 id="action-title">From a 14-page reassessment notice to a filable reply.</h2>
						<p class="lede">No screenshots, no demos — this is what the workflow produces. Citations verified, grounded in your firm's own prior positions.</p>
					</div>

					<div class="action-panel">
						{/* Left: source notice */}
						<article class="action-notice" aria-label="Source Income Tax notice">
							<div class="notice-head">
								<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<circle cx="12" cy="12" r="10" />
									<path d="M12 2a14 14 0 0 0 0 20" />
									<path d="M2 12h20" />
								</svg>
								<div>
									<p class="notice-org">Income Tax Department, Government of India</p>
									<p class="notice-dir">DIN: ITBA/AST/S/148/2025-26</p>
								</div>
								<span class="notice-stamp">INCOMING</span>
							</div>
							<div class="notice-body">
								<p class="notice-sub">NOTICE UNDER SECTION 148</p>
								<p class="notice-para">Whereas I have reason to believe that income chargeable to tax for the Assessment Year <strong>2021–22</strong> has escaped assessment within the meaning of section 147 of the Income Tax Act, 1961.</p>
								<p class="notice-para muted-line">Particulars of escaped income include unexplained cash credits appearing in the books of accounts under section 68 of the Income Tax Act, 1961, aggregating to <strong>₹14,70,000</strong>…</p>
								<div class="notice-dash"></div>
								<div class="notice-meta">
									<span><strong>Deadline</strong> 29 Apr 2026</span>
									<span><strong>PAN</strong> ABCDE1234F</span>
								</div>
							</div>
						</article>

						{/* Middle: transformation flow */}
						<div class="action-flow" aria-hidden="true">
							<svg class="flow-arrow" viewBox="0 0 120 200" fill="none" xmlns="http://www.w3.org/2000/svg">
								<path d="M4 100 C 50 100, 70 100, 116 100" stroke="#10b981" stroke-width="2" stroke-dasharray="4 6" stroke-linecap="round" />
								<path d="M108 94l8 6-8 6" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none" />
							</svg>
							<ul class="flow-chips">
								<li>
									<span class="chip-dot"></span>
									Parsed &amp; classified
								</li>
								<li>
									<span class="chip-dot"></span>
									Researched IT Act + case law
								</li>
								<li>
									<span class="chip-dot verified"></span>
									<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg>
									Every citation verified
								</li>
							</ul>
						</div>

						{/* Right: drafted reply */}
						<article class="action-reply" aria-label="Generated reply draft">
							<div class="reply-head">
								<span class="reply-pill">Generated draft · Reply to s. 148</span>
								<span class="reply-time">12m 48s</span>
							</div>
							<div class="reply-body">
								<p class="reply-sub">Reply to Notice under Section 148 — AY 2021–22</p>
								<p class="reply-para">With reference to the captioned notice, the assessee respectfully submits that the amounts credited to the books during the relevant previous year have been duly reconciled with verifiable banking sources and are supported by confirmations on record.</p>
								<p class="reply-para">The aggregate of <strong>₹14,70,000</strong> represents sale proceeds from listed securities, already reflected in the return filed u/s 139(1). Consequently, the condition precedent for reassessment u/s 147 is not satisfied…</p>
								<ul class="reply-chips">
									<li>
										<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg>
										s. 148 IT Act, 1961
									</li>
									<li>
										<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg>
										CBDT Circular 549
									</li>
									<li>
										<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg>
										ITO v. Lakhmani Mewal Das
									</li>
									<li>
										<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg>
										Your prior reply — Rameshwar &amp; Co.
									</li>
								</ul>
							</div>
							<div class="reply-footer">
								<span class="reply-verified">
									<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg>
									4 verified · 0 flagged · audit log attached
								</span>
							</div>
						</article>
					</div>
				</div>
			</section>

			{/* ─── HOW IT WORKS ─── */}
			<section class="section how" id="how-it-works" aria-labelledby="how-title">
				<div class="container">
					<div class="section-head">
						<span class="eyebrow">The workflow</span>
						<h2 id="how-title">Upload → Analyse → Draft → Export</h2>
						<p class="lede">Four steps. One notice. Under thirty minutes. Human review at every stage — because the AO will read what <em>you</em> sign.</p>
					</div>

					<ol class="steps">
						<li class="step">
							<div class="step-scene" aria-hidden="true">
								<svg viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg">
									<rect x="1" y="1" width="158" height="118" rx="20" fill="#fef3c7" />
									<rect x="42" y="28" width="76" height="82" rx="6" fill="#ffffff" stroke="#cbd5e1" stroke-width="1.2" />
									<rect x="52" y="42" width="40" height="3" rx="1.5" fill="#e2e8f0" />
									<rect x="52" y="50" width="56" height="3" rx="1.5" fill="#e2e8f0" />
									<rect x="52" y="58" width="48" height="3" rx="1.5" fill="#e2e8f0" />
									<rect x="52" y="66" width="52" height="3" rx="1.5" fill="#e2e8f0" />
									<rect x="52" y="74" width="32" height="3" rx="1.5" fill="#e2e8f0" />
									<g>
										<circle cx="80" cy="22" r="14" fill="#10b981" />
										<path d="M80 16v12M74 22l6-6 6 6" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
									</g>
								</svg>
							</div>
							<span class="step-n">{steps[0].n}</span>
							<h3>{steps[0].title}</h3>
							<p>{steps[0].body}</p>
						</li>
						<li class="step">
							<div class="step-scene" aria-hidden="true">
								<svg viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg">
									<rect x="1" y="1" width="158" height="118" rx="20" fill="#fce7f3" />
									<rect x="28" y="26" width="80" height="84" rx="6" fill="#ffffff" stroke="#cbd5e1" stroke-width="1.2" />
									<rect x="38" y="40" width="26" height="4" rx="2" fill="#10b981" opacity="0.55" />
									<rect x="38" y="50" width="54" height="3" rx="1.5" fill="#e2e8f0" />
									<rect x="38" y="58" width="38" height="4" rx="2" fill="#10b981" opacity="0.55" />
									<rect x="38" y="68" width="60" height="3" rx="1.5" fill="#e2e8f0" />
									<rect x="38" y="76" width="48" height="3" rx="1.5" fill="#e2e8f0" />
									<rect x="38" y="84" width="30" height="4" rx="2" fill="#10b981" opacity="0.55" />
									<g>
										<circle cx="115" cy="70" r="20" fill="#ffffff" stroke="#10b981" stroke-width="2.2" />
										<path d="m128 83 8 8" stroke="#10b981" stroke-width="2.6" stroke-linecap="round" />
										<circle cx="115" cy="70" r="11" fill="none" stroke="#94a3b8" stroke-width="1" stroke-dasharray="2 2" />
									</g>
								</svg>
							</div>
							<span class="step-n">{steps[1].n}</span>
							<h3>{steps[1].title}</h3>
							<p>{steps[1].body}</p>
						</li>
						<li class="step">
							<div class="step-scene" aria-hidden="true">
								<svg viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg">
									<rect x="1" y="1" width="158" height="118" rx="20" fill="#dbeafe" />
									<rect x="30" y="24" width="78" height="84" rx="6" fill="#ffffff" stroke="#cbd5e1" stroke-width="1.2" />
									<rect x="40" y="36" width="46" height="3" rx="1.5" fill="#1e293b" />
									<rect x="40" y="44" width="58" height="2.5" rx="1.25" fill="#cbd5e1" />
									<rect x="40" y="50" width="52" height="2.5" rx="1.25" fill="#cbd5e1" />
									<rect x="40" y="56" width="56" height="2.5" rx="1.25" fill="#cbd5e1" />
									<rect x="40" y="70" width="22" height="8" rx="4" fill="#10b981" opacity="0.18" stroke="#10b981" stroke-width="0.9" />
									<rect x="66" y="70" width="18" height="8" rx="4" fill="#10b981" opacity="0.18" stroke="#10b981" stroke-width="0.9" />
									<rect x="88" y="70" width="14" height="8" rx="4" fill="#10b981" opacity="0.18" stroke="#10b981" stroke-width="0.9" />
									<rect x="40" y="84" width="40" height="2.5" rx="1.25" fill="#cbd5e1" />
									<g>
										<path d="M112 90 135 67l-4-4L108 86z" fill="#10b981" />
										<path d="m131 63 4 4 4-4-4-4z" fill="#059669" />
										<circle cx="112" cy="90" r="2.5" fill="#1e293b" />
									</g>
								</svg>
							</div>
							<span class="step-n">{steps[2].n}</span>
							<h3>{steps[2].title}</h3>
							<p>{steps[2].body}</p>
						</li>
						<li class="step">
							<div class="step-scene" aria-hidden="true">
								<svg viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg">
									<rect x="1" y="1" width="158" height="118" rx="20" fill="#d1fae5" />
									<rect x="42" y="20" width="76" height="82" rx="6" fill="#ffffff" stroke="#cbd5e1" stroke-width="1.2" />
									<rect x="52" y="32" width="40" height="3" rx="1.5" fill="#e2e8f0" />
									<rect x="52" y="40" width="56" height="3" rx="1.5" fill="#e2e8f0" />
									<rect x="52" y="48" width="48" height="3" rx="1.5" fill="#e2e8f0" />
									<rect x="52" y="56" width="52" height="3" rx="1.5" fill="#e2e8f0" />
									<rect x="52" y="64" width="32" height="3" rx="1.5" fill="#e2e8f0" />
									<g>
										<circle cx="80" cy="94" r="14" fill="#10b981" />
										<path d="M80 88v12M74 94l6 6 6-6" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
									</g>
								</svg>
							</div>
							<span class="step-n">{steps[3].n}</span>
							<h3>{steps[3].title}</h3>
							<p>{steps[3].body}</p>
						</li>
					</ol>
				</div>
			</section>

			{/* ─── WHY — ETHEREAL SHOWCASE ─── */}
			<section class="section why" id="why-accountic" aria-labelledby="why-title">
				<div class="container">
					<div class="section-head">
						<span class="eyebrow">Why Accountic</span>
						<h2 id="why-title">Five reasons a senior partner will put their name on it.</h2>
					</div>

					<div class="cv-showcase">
						<article class="cv-card cv-hero">
							<div class="card-icon">
								<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
									<path d="m9 12 2 2 4-4"></path>
								</svg>
							</div>
							<h3>Citation verification — or the credit returns.</h3>
							<p>
								Every IT&nbsp;Act section, CBDT circular, and case cited in a draft is checked
								against a live repository before the draft reaches you. If the layer misses
								a bad citation, the credit is refunded automatically — no ticket, no review.
							</p>
							<p class="cv-meta">
								No other Indian notice tool ships a refund commitment on citation accuracy —
								because none has the verification layer to stand behind one.
							</p>
						</article>

						<article class="cv-card glass-card">
							<div class="card-icon">
								<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
									<path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
								</svg>
							</div>
							<h3>Firm memory from day one.</h3>
							<p>
								Upload past notice-reply PDFs at onboarding. Accountic learns your drafting
								voice, preferred grounds, and recurring client positions on the first run —
								no tagging, no manual structuring.
							</p>
						</article>

						<article class="cv-card glass-card">
							<div class="card-icon">
								<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
									<path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
								</svg>
							</div>
							<h3>India-first DPDP posture.</h3>
							<p>
								India-resident processing, consent-per-document, PII-aware pipelines, and
