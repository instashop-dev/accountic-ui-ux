---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={metaTitle} description={metaDescription} />
	</head>
	<body>
		<Header />

		<main id="main">

			{/* ─────────────── HERO ─────────────── */}
			<section class="hero">
				<div class="wrap hero-grid">
					<div class="hero-copy">
						<p class="kicker rv"><span class="kicker-tick" aria-hidden="true"></span>EARLY ACCESS 2026 · FOR CAs, ACCOUNTING TEAMS &amp; FIRMS</p>

						<h1 class="hero-title rv">
							The accounting work that fills your week —
							<span class="accent">Accountic’s AI finishes it in minutes.</span>
						</h1>

						<p class="hero-sub rv">
							Accountic's AI runs the compliance, reconciliation, and reporting your team repeats every week — finishing in minutes what used to take hours, and cutting the cost of every workflow. All posted straight into TallyPrime.
						</p>

						<div class="hero-cta rv">
							<a class="btn btn--solid" href="https://app.accountic.in/signup">Start free — ₹1,000 credits</a>
							<a class="btn btn--line" href="#modules">
								See all 14 modules
								<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
							</a>
						</div>

						<p class="hero-note rv">No credit card · ₹1,000 in credits to start · cancel anytime</p>

						<ul class="trust rv" aria-label="Platform compliance and trust signals">
							<li>Built by CAs</li>
							<li>India-resident data</li>
							<li>DPDP-ready</li>
							<li>SOC 2 Type II</li>
							<li>Tally-native</li>
						</ul>
					</div>

					{/* Hero instrument panel — document in → verified → Tally voucher out */}
					<div class="panel rv" role="img" aria-label="Accountic automation readout: an income-tax notice, a bank statement, and a supplier invoice are each processed into a drafted reply with verified citations, 847 posted Tally vouchers, and a GST purchase voucher — with zero hallucinations and all data kept in India.">
						<div class="panel-head">
							<span class="panel-name"><span class="panel-glyph" aria-hidden="true"></span>accountic · automation</span>
							<span class="panel-status"><span class="panel-status-dot" aria-hidden="true"></span>LIVE</span>
						</div>
						<div class="panel-body">
							<div class="flow">
								<div class="flow-io flow-io--in">
									<span class="flow-ic" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></span>
									<span class="flow-meta"><strong>Notice_143(3).pdf</strong><em>s.143(3) scrutiny · SCN</em></span>
								</div>
								<span class="flow-arrow" aria-hidden="true"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
								<div class="flow-io flow-io--out">
									<span class="flow-meta"><strong class="typein">Drafted reply</strong><em>7 citations verified</em></span>
									<span class="flow-check" aria-hidden="true"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>
								</div>
							</div>
							<div class="flow">
								<div class="flow-io flow-io--in">
									<span class="flow-ic" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg></span>
									<span class="flow-meta"><strong>HDFC_statement.csv</strong><em>847 transactions</em></span>
								</div>
								<span class="flow-arrow" aria-hidden="true"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
								<div class="flow-io flow-io--out">
									<span class="flow-meta"><strong>847 Tally vouchers</strong><em>Classified &amp; posted</em></span>
									<span class="flow-check" aria-hidden="true"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>
								</div>
							</div>
