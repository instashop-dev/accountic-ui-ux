---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const metaTitle = `${SITE_TITLE} — Income Tax notice replies in under 30 minutes`;
const metaDescription =
	'AI-powered Income Tax notice analysis and reply drafting for Indian Chartered Accountants. Every citation verified — or we return the credit. Replies in 30 minutes.';

const steps = [
	{ n: '01', title: 'Upload', body: 'Drop a notice PDF or scan — s. 139(9), 142(1), 143(2), 148, 245. Bulk-upload past replies to bootstrap firm memory on day one.' },
	{ n: '02', title: 'Analyse', body: 'Accountic classifies the notice and extracts section, AY, demand, deadline, and grounds raised — then surfaces applicable law and case law.' },
	{ n: '03', title: 'Draft', body: 'A reply grounded in the notice, verified IT Act + CBDT + case law, and your own prior positions. Every citation is checked before it reaches the draft.' },
	{ n: '04', title: 'Export', body: 'Clean, portal-ready output with reasoning and citation audit log. Review, refine, and file — under your name, under your judgement.' },
];

const pricingTiers = [
	{ name: 'Free trial', price: '₹0', cadence: 'one-time', blurb: '3 notices on us. No card required.', features: ['3 notices, lifetime', 'Full citation verification', 'Firm-memory upload', 'Email support'], cta: 'Start free', href: '#cta', highlight: false },
	{ name: 'Basic', price: '₹2,000', cadence: '/ month', blurb: 'For solo practitioners and small books.', features: ['10 notices / month', 'Every citation verified', 'Soft quota — no mid-month cutoff', 'GST invoice with your GSTIN'], cta: 'Start free trial', href: '#cta', highlight: false },
	{ name: 'Pro', price: '₹20,000', cadence: '/ month', blurb: 'For high-volume solo CAs and small firms.', features: ['100 notices / month', 'Firm-memory across clients', 'Bulk historical upload', 'Priority support'], cta: 'Start free trial', href: '#cta', highlight: true },
	{ name: 'Firm', price: 'Custom', cadence: '', blurb: 'For 5–30-professional firms.', features: ['Higher quotas + seat controls', 'Role-based access (roadmap)', 'Data Processing Agreement', 'Dedicated onboarding'], cta: 'Contact sales', href: '/contact', highlight: false },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={metaTitle} description={metaDescription} />
	</head>
	<body>
		<Header />

		<main id="main">
			{/* ─── ETHEREAL HERO ─── */}
			<section class="hero">
				<div class="container hero-inner">
					<a class="hero-badge" href="#why-accountic" aria-label="Learn about Accountic">
						<span class="badge-dot" aria-hidden="true"></span>
						<span>LAUNCHING MAY 2026 · FOR INDIAN CAs</span>
					</a>

					<h1 class="hero-title">
						Draft an Income Tax<br/>
						notice reply in <span class="highlight-green">30 minutes</span>.<br/>
						Every citation verified.
					</h1>

					<p class="hero-subtitle">
						AI-assisted drafting grounded in verified IT&nbsp;Act references, case law, and your own prior replies. If we miss a bad citation, the credit returns — automatically.
					</p>

					<div class="hero-cta">
						<a class="btn btn-primary" href="#cta">Start free trial</a>
						<a class="btn btn-secondary" href="#how-it-works">See how it works</a>
					</div>

					<ul class="trust-badges" aria-label="Compliance and trust">
						<li>
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
								<path d="m9 12 2 2 4-4"></path>
							</svg>
							<span>SOC 2 Type II</span>
						</li>
						<li>
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<rect x="4" y="11" width="16" height="10" rx="2"></rect>
								<path d="M8 11V7a4 4 0 0 1 8 0v4"></path>
							</svg>
							<span>DPDP-ready</span>
						</li>
						<li>
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<circle cx="12" cy="12" r="9"></circle>
								<path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"></path>
							</svg>
							<span>India-resident data</span>
						</li>
						<li>
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path>
								<path d="M14 3v6h6"></path>
								<path d="m9 15 2 2 4-4"></path>
							</svg>
							<span>ICAI-aligned</span>
						</li>
						<li>
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
								<circle cx="9" cy="7" r="4"></circle>
								<path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
							</svg>
							<span>Built by CAs</span>
						</li>
					</ul>

					{/* Floating sample-reply glass card */}
					<div class="hero-card glass" aria-hidden="false">
						<div class="hc-head">
							<span class="hc-pill">Sample reply · s. 148 Reassessment</span>
							<span class="hc-status">
								<span class="status-dot"></span> Verified
							</span>
						</div>
						<div class="hc-body">
							<p class="hc-meta">AY 2021–22 · Demand ₹14.7L · Deadline 29 Apr 2026</p>
							<div class="hc-block">
								<h4>Grounds raised</h4>
								<p>Escaped income on unexplained cash credits under s.&nbsp;68 r/w s.&nbsp;148.</p>
							</div>
							<div class="hc-block">
								<h4>Citations used <span class="chips-count">4 verified · 0 flagged</span></h4>
								<ul class="hc-chips">
									<li>s. 148 IT Act, 1961</li>
									<li>CBDT Circular No. 549</li>
									<li>ITO v. Lakhmani Mewal Das (SC, 1976)</li>
									<li>Your prior reply — Rameshwar &amp; Co.</li>
								</ul>
							</div>
							<div class="hc-footer">
								<span class="hc-ok">
									<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M20 6 9 17l-5-5"></path>
									</svg>
									Citation audit log attached
								</span>
								<span class="hc-time">12m 48s</span>
							</div>
						</div>
					</div>
				</div>
			</section>

			{/* ─── OUTCOME — 30-minute turnaround, broken down ─── */}
			<section class="section outcome-section" aria-label="Routine-notice turnaround">
				<div class="container">
					<article class="outcome-card">
						<div class="outcome-stat">
							<span class="outcome-stat-icon" aria-hidden="true">
								<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
									<path d="M9 2h6" />
									<path d="M12 6V4" />
									<circle cx="12" cy="14" r="8" />
									<path d="M12 14v-4" />
									<path d="m18.5 8 1.5-1.5" />
								</svg>
							</span>
							<p class="outcome-stat-value">
								<strong>30</strong>
								<span class="outcome-stat-unit">minutes</span>
							</p>
							<p class="outcome-stat-label">
								From a notice PDF on the desk to a filable reply, end-to-end.
							</p>
							<p class="outcome-stat-foot">
								<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<path d="M20 6 9 17l-5-5" />
								</svg>
								Every citation verified before signature.
							</p>
						</div>

						<ol class="outcome-steps" aria-label="Where the 30 minutes go">
							<li class="outcome-step">
								<span class="outcome-step-num" aria-hidden="true">01</span>
								<span class="outcome-step-body">
									<span class="outcome-step-name">Upload</span>
									<span class="outcome-step-detail">Parse the PDF, classify the section.</span>
								</span>
								<span class="outcome-step-time">2 min</span>
							</li>
							<li class="outcome-step">
								<span class="outcome-step-num" aria-hidden="true">02</span>
								<span class="outcome-step-body">
									<span class="outcome-step-name">Analyse</span>
									<span class="outcome-step-detail">Extract grounds, retrieve law and prior replies.</span>
								</span>
								<span class="outcome-step-time">8 min</span>
							</li>
							<li class="outcome-step">
								<span class="outcome-step-num" aria-hidden="true">03</span>
								<span class="outcome-step-body">
									<span class="outcome-step-name">Draft</span>
									<span class="outcome-step-detail">Reply written, every citation verified.</span>
								</span>
								<span class="outcome-step-time">15 min</span>
							</li>
							<li class="outcome-step">
								<span class="outcome-step-num" aria-hidden="true">04</span>
								<span class="outcome-step-body">
									<span class="outcome-step-name">Export</span>
									<span class="outcome-step-detail">CA review, portal-ready output, audit log.</span>
								</span>
								<span class="outcome-step-time">5 min</span>
							</li>
						</ol>
					</article>
				</div>
			</section>

			{/* ─── DRAFT QUALITY — vs generic LLM ─── */}
			<section class="section quality" aria-labelledby="quality-title">
				<div class="container">
					<div class="section-head quality-head">
						<span class="section-label">Draft quality</span>
						<h2 id="quality-title">A draft a senior partner will put their name on.</h2>
						<p class="lede">
							Generic LLMs draft fast. They also hallucinate repealed sections, invent
							case law, and ship PAN and GSTIN to servers outside India with no DPA.
							Accountic is built the other way — for the CA whose signature is on the
							reply.
						</p>
					</div>

					<div class="quality-panel">
						<article class="q-card q-generic" aria-label="Generic LLM output">
							<header class="q-card-head">
								<span class="q-pill q-pill-muted">
									<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<rect x="3" y="3" width="18" height="18" rx="4" />
										<path d="M8 9h8M8 13h5" />
									</svg>
									ChatGPT / generic LLM
								</span>
								<span class="q-verdict q-verdict-fail">Not fit to file</span>
							</header>
							<ul class="q-list">
								<li>
									<span class="q-ico q-ico-x" aria-hidden="true">
										<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"></path></svg>
									</span>
									Cites <span class="q-strike">"section 147A"</span> — doesn't exist in the IT Act
								</li>
								<li>
									<span class="q-ico q-ico-x" aria-hidden="true">
										<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"></path></svg>
									</span>
									Invents <span class="q-strike">ITO v. Modi Industries (2019)</span> — no such case
								</li>
								<li>
									<span class="q-ico q-ico-x" aria-hidden="true">
										<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"></path></svg>
									</span>
									Boilerplate tone — reads like every other generic reply before the AO
								</li>
								<li>
									<span class="q-ico q-ico-x" aria-hidden="true">
										<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"></path></svg>
									</span>
									Uploads PAN &amp; GSTIN to a US-hosted model with no DPA
								</li>
								<li>
									<span class="q-ico q-ico-x" aria-hidden="true">
										<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"></path></svg>
									</span>
									No audit log — no accountability if a citation is wrong
								</li>
							</ul>
						</article>

						<article class="q-card q-accountic" aria-label="Accountic draft">
							<header class="q-card-head">
								<span class="q-pill q-pill-accent">
									<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
										<path d="m9 12 2 2 4-4" />
									</svg>
									Accountic draft
								</span>
								<span class="q-verdict q-verdict-ok">Ready for senior review</span>
							</header>
							<ul class="q-list">
								<li>
									<span class="q-ico q-ico-check" aria-hidden="true">
										<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
									</span>
									Every citation verified against a live IT Act &amp; case-law repository
								</li>
								<li>
									<span class="q-ico q-ico-check" aria-hidden="true">
										<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
									</span>
									Grounded in ITAT / High Court / Supreme Court judgments, checked for currency
								</li>
								<li>
									<span class="q-ico q-ico-check" aria-hidden="true">
										<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
									</span>
									Matched to your firm's voice — learned from your prior replies on day one
								</li>
								<li>
									<span class="q-ico q-ico-check" aria-hidden="true">
										<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
									</span>
									India-resident processing. Your corpus never trains anyone else's model.
								</li>
								<li>
									<span class="q-ico q-ico-check" aria-hidden="true">
										<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
									</span>
									Credit-refund if the verification layer misses a bad citation
								</li>
							</ul>
						</article>
					</div>

					<p class="quality-closing">
						Drafted to a standard a 45-year CA firm will put their name on — because it
						<em>is</em>&nbsp;built by one.
					</p>
				</div>
			</section>

			{/* ─── HOW IT WORKS ─── */}
			<section class="section how" id="how-it-works" aria-labelledby="how-title">
				<div class="container">
					<div class="section-head">
						<span class="section-label">The workflow</span>
						<h2 id="how-title">Upload → Analyse → Draft → Export</h2>
						<p class="lede">Four steps. One notice. Under thirty minutes. Human review at every stage — because the AO will read what <em>you</em> sign.</p>
					</div>

					<ol class="steps">
						<li class="step">
							<div class="step-scene" aria-hidden="true">
								<svg viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg">
									<rect x="1" y="1" width="158" height="118" rx="20" fill="#fef3c7" />
									<rect x="42" y="28" width="76" height="82" rx="6" fill="#ffffff" stroke="#cbd5e1" stroke-width="1.2" />
									<rect x="52" y="42" width="40" height="3" rx="1.5" fill="#e2e8f0" />
									<rect x="52" y="50" width="56" height="3" rx="1.5" fill="#e2e8f0" />
									<rect x="52" y="58" width="48" height="3" rx="1.5" fill="#e2e8f0" />
									<rect x="52" y="66" width="52" height="3" rx="1.5" fill="#e2e8f0" />
									<rect x="52" y="74" width="32" height="3" rx="1.5" fill="#e2e8f0" />
									<g>
										<circle cx="80" cy="22" r="14" fill="#10b981" />
										<path d="M80 16v12M74 22l6-6 6 6" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
									</g>
								</svg>
							</div>
							<span class="step-n">{steps[0].n}</span>
							<h3>{steps[0].title}</h3>
							<p>{steps[0].body}</p>
						</li>
						<li class="step">
							<div class="step-scene" aria-hidden="true">
								<svg viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg">
									<rect x="1" y="1" width="158" height="118" rx="20" fill="#fce7f3" />
									<rect x="28" y="26" width="80" height="84" rx="6" fill="#ffffff" stroke="#cbd5e1" stroke-width="1.2" />
									<rect x="38" y="40" width="26" height="4" rx="2" fill="#10b981" opacity="0.55" />
									<rect x="38" y="50" width="54" height="3" rx="1.5" fill="#e2e8f0" />
									<rect x="38" y="58" width="38" height="4" rx="2" fill="#10b981" opacity="0.55" />
									<rect x="38" y="68" width="60" height="3" rx="1.5" fill="#e2e8f0" />
									<rect x="38" y="76" width="48" height="3" rx="1.5" fill="#e2e8f0" />
									<rect x="38" y="84" width="30" height="4" rx="2" fill="#10b981" opacity="0.55" />
									<g>
										<circle cx="115" cy="70" r="20" fill="#ffffff" stroke="#10b981" stroke-width="2.2" />
										<path d="m128 83 8 8" stroke="#10b981" stroke-width="2.6" stroke-linecap="round" />
										<circle cx="115" cy="70" r="11" fill="none" stroke="#94a3b8" stroke-width="1" stroke-dasharray="2 2" />
									</g>
								</svg>
							</div>
							<span class="step-n">{steps[1].n}</span>
							<h3>{steps[1].title}</h3>
							<p>{steps[1].body}</p>
						</li>
						<li class="step">
							<div class="step-scene" aria-hidden="true">
								<svg viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg">
									<rect x="1" y="1" width="158" height="118" rx="20" fill="#dbeafe" />
									<rect x="30" y="24" width="78" height="84" rx="6" fill="#ffffff" stroke="#cbd5e1" stroke-width="1.2" />
									<rect x="40" y="36" width="46" height="3" rx="1.5" fill="#1e293b" />
									<rect x="40" y="44" width="58" height="2.5" rx="1.25" fill="#cbd5e1" />
									<rect x="40" y="50" width="52" height="2.5" rx="1.25" fill="#cbd5e1" />
									<rect x="40" y="56" width="56" height="2.5" rx="1.25" fill="#cbd5e1" />
									<rect x="40" y="70" width="22" height="8" rx="4" fill="#10b981" opacity="0.18" stroke="#10b981" stroke-width="0.9" />
									<rect x="66" y="70" width="18" height="8" rx="4" fill="#10b981" opacity="0.18" stroke="#10b981" stroke-width="0.9" />
									<rect x="88" y="70" width="14" height="8" rx="4" fill="#10b981" opacity="0.18" stroke="#10b981" stroke-width="0.9" />
									<rect x="40" y="84" width="40" height="2.5" rx="1.25" fill="#cbd5e1" />
									<g>
										<path d="M112 90 135 67l-4-4L108 86z" fill="#10b981" />
										<path d="m131 63 4 4 4-4-4-4z" fill="#059669" />
										<circle cx="112" cy="90" r="2.5" fill="#1e293b" />
									</g>
								</svg>
							</div>
							<span class="step-n">{steps[2].n}</span>
							<h3>{steps[2].title}</h3>
							<p>{steps[2].body}</p>
						</li>
						<li class="step">
							<div class="step-scene" aria-hidden="true">
								<svg viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg">
									<rect x="1" y="1" width="158" height="118" rx="20" fill="#d1fae5" />
									<rect x="42" y="20" width="76" height="82" rx="6" fill="#ffffff" stroke="#cbd5e1" stroke-width="1.2" />
									<rect x="52" y="32" width="40" height="3" rx="1.5" fill="#e2e8f0" />
									<rect x="52" y="40" width="56" height="3" rx="1.5" fill="#e2e8f0" />
									<rect x="52" y="48" width="48" height="3" rx="1.5" fill="#e2e8f0" />
									<rect x="52" y="56" width="52" height="3" rx="1.5" fill="#e2e8f0" />
									<rect x="52" y="64" width="32" height="3" rx="1.5" fill="#e2e8f0" />
									<g>
										<circle cx="80" cy="94" r="14" fill="#10b981" />
										<path d="M80 88v12M74 94l6 6 6-6" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
									</g>
								</svg>
							</div>
