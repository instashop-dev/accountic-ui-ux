			.cta-error {
				margin: 0.5rem auto 0;
				max-width: 480px;
				color: #b91c1c;
				font-size: 0.85rem;
				font-weight: 500;
				text-align: left;
				padding-left: 1rem;
			}

			.cta-thanks-state {
				text-align: center;
				display: flex;
				flex-direction: column;
				align-items: center;
			}

			.cta-thanks-icon {
				width: 58px;
				height: 58px;
				border-radius: 9999px;
				background: var(--eth-accent-soft);
				color: var(--eth-accent);
				display: inline-flex;
				align-items: center;
				justify-content: center;
				margin-bottom: 1rem;
			}

			.cta-thanks-state h2 { margin: 0.35rem 0 0.75rem; max-width: 20ch; }
			.cta-thanks-state p { max-width: 52ch; color: var(--eth-text-secondary); margin: 0 auto; }
			.cta-thanks-state strong { color: var(--eth-text); font-weight: 600; }

			.cta-thanks-meta { font-size: 0.9rem; margin-top: 1rem !important; }
			.cta-thanks-meta a { color: var(--eth-accent); font-weight: 500; }

			@media (max-width: 560px) {
				.cta-form { flex-direction: column; }
			}
		</style>

		<script is:inline>
			(function () {
				const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

				function storeCapture(email, source) {
					try {
						const key = 'accountic:captures';
						const existing = JSON.parse(localStorage.getItem(key) || '[]');
						existing.push({ email, source, at: new Date().toISOString() });
						localStorage.setItem(key, JSON.stringify(existing));
					} catch (_) { /* storage unavailable — silently skip */ }
				}

				function sendCapture(email, source) {
					// Placeholder: plug in Formspree/Getform/own endpoint via data-endpoint attr
					const card = document.querySelector(`[data-capture][data-source="${source}"]`);
					const endpoint = card && card.dataset.endpoint;
					if (!endpoint) return Promise.resolve();
					return fetch(endpoint, {
						method: 'POST',
						headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
						body: JSON.stringify({ email, source, page: location.pathname }),
					}).catch(() => {});
				}

				document.querySelectorAll('[data-capture]').forEach((card) => {
					const form = card.querySelector('[data-capture-form]');
					if (!form) return;
					const err = card.querySelector('[data-capture-error]');
					const emailOut = card.querySelector('[data-capture-email]');
					const formState = card.querySelector('[data-state="form"]');
					const thanksState = card.querySelector('[data-state="thanks"]');

					form.addEventListener('submit', function (event) {
						event.preventDefault();
						const emailInput = form.querySelector('input[type="email"]');
						const email = (emailInput && emailInput.value || '').trim();

						if (!EMAIL_RE.test(email)) {
							if (err) err.hidden = false;
							emailInput && emailInput.focus();
							return;
						}
						if (err) err.hidden = true;

						const submitBtn = form.querySelector('button[type="submit"]');
						if (submitBtn) {
							submitBtn.disabled = true;
							submitBtn.style.opacity = '0.6';
						}

						storeCapture(email, card.dataset.source || 'unknown');
						sendCapture(email, card.dataset.source || 'unknown').finally(function () {
							if (emailOut) emailOut.textContent = email;
							if (formState) formState.hidden = true;
							if (thanksState) thanksState.hidden = false;
						});
					});
				});
			})();
		</script>
	</body>
</html>
