---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const metaTitle = `${SITE_TITLE} — AI Accounting Agent for Indian CA Firms`;
const metaDescription =
	'Accountic automates Indian accounting and tax workflows end-to-end: IT notice drafting, audit vouching, GST reconciliation, broker ledger, balance sheet generation, TDS compliance, bank-statement classification, and Tally OCR — all with verified citations, zero hallucination, and India-resident data.';

const modules = [
	{
		id: 'notice-workflow',
		name: 'Notice Workflow',
		description: 'Draft IT notice replies (s. 142(1), 143(3), 148A) grounded in verified case law and IT Act sections.',
		chip: 'Notice PDF → filed reply in < 30 min',
		icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="m9 15 2 2 4-4"/></svg>`,
	},
	{
		id: 'appeal-drafting',
		name: 'Appeal Drafting',
		description: 'Prepare formal tax appeals before CIT(A) and ITAT — grounds of appeal, addition-by-addition rebuttals, and final PDF/DOCX.',
		chip: 'Appeal ready for CIT(A) & ITAT',
		icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h11"/><path d="m15 15 2 2 4-4"/></svg>`,
	},
	{
		id: 'broker-ledger',
		name: 'Broker Ledger',
		description: 'Convert broker tradebooks to Tally journal vouchers via a 4-stage FIFO engine — equity, ETF, F&O, and commodity.',
		chip: 'Tradebook → Tally in minutes',
		icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>`,
	},
	{
		id: 'ledger-predictor',
		name: 'Ledger Predictor',
		description: 'Classify bank-statement transactions to the right Tally ledger via a 10-stage cascade plus Claude review, then push vouchers.',
		chip: '90–98% auto-classified, hands-free',
		icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12"/></svg>`,
	},
	{
		id: 'tally-ocr',
		name: 'Tally OCR',
		description: 'Extract supplier invoices (PDF, image, Word) via Azure DI and push GST-split Purchase vouchers directly into TallyPrime.',
		chip: 'Invoice → Tally Purchase voucher',
		icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>`,
