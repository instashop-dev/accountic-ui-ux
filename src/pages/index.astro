---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const metaTitle = `${SITE_TITLE} — AI Accounting Agent for Indian CA Firms`;
const metaDescription =
	'Accountic automates Indian accounting and tax workflows end-to-end: IT notice drafting, audit vouching, GST reconciliation, broker ledger, balance sheet generation, TDS compliance, bank-statement classification, and Tally OCR — all with verified citations, zero hallucination, and India-resident data.';

const modules = [
	{
		id: 'notice-workflow',
		name: 'Notice Workflow',
		description: 'Draft IT notice replies (s. 142(1), 143(3), 148A) grounded in verified case law and IT Act sections.',
		chip: 'Notice PDF → filed reply in < 30 min',
		icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="m9 15 2 2 4-4"/></svg>`,
	},
	{
		id: 'appeal-drafting',
		name: 'Appeal Drafting',
		description: 'Prepare formal tax appeals before CIT(A) and ITAT — grounds of appeal, addition-by-addition rebuttals, and final PDF/DOCX.',
		chip: 'Appeal ready for CIT(A) & ITAT',
		icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h11"/><path d="m15 15 2 2 4-4"/></svg>`,
	},
	{
		id: 'broker-ledger',
		name: 'Broker Ledger',
		description: 'Convert broker tradebooks to Tally journal vouchers via a 4-stage FIFO engine — equity, ETF, F&O, and commodity.',
		chip: 'Tradebook → Tally in minutes',
		icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>`,
	},
	{
		id: 'ledger-predictor',
		name: 'Ledger Predictor',
		description: 'Classify bank-statement transactions to the right Tally ledger via a 10-stage cascade plus Claude review, then push vouchers.',
		chip: '90–98% auto-classified, hands-free',
		icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12"/></svg>`,
	},
	{
		id: 'tally-ocr',
		name: 'Tally OCR',
		description: 'Extract supplier invoices (PDF, image, Word) via Azure DI and push GST-split Purchase vouchers directly into TallyPrime.',
		chip: 'Invoice → Tally Purchase voucher',
		icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>`,
	},
	{
		id: 'vouching',
		name: 'Vouching',
		description: 'Match Tally entries against source documents (invoices, bank statements) and render SA 230-compliant audit verdicts.',
		chip: 'Audit-ready working papers, auto-built',
		icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`,
	},
	{
		id: 'tds-reconciliation',
		name: 'TDS Reconciliation',
		description: 'Audit TDS compliance per vendor, per bill, per FY — matched against statutory section rates and party exemptions.',
		chip: 'Every vendor TDS-checked automatically',
		icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.2"/></svg>`,
	},
	{
		id: 'gstr-2b',
		name: 'GSTR-2B Reconciliation',
		description: 'Reconcile your GSTR-2B ITC statement against the purchase register — bucketed mismatches by rule tag, export-ready.',
		chip: 'A day of reconciliation → minutes',
		icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>`,
	},
	{
		id: 'balance-sheet-builder',
		name: 'Balance Sheet Builder',
		description: 'Turn trial balances into Schedule III financial statements — BS, P&L, Cash Flow, and Notes — for any entity type.',
		chip: 'Trial balance → Schedule III statements',
		icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="9" x2="9" y2="21"/></svg>`,
	},
	{
		id: 'debtor-followup',
		name: 'Debtor Follow-up',
		description: 'Sync Sundry Debtor balances from Tally, auto-score risk per debtor, and send chase emails in configurable runs.',
		chip: 'Auto-scored AR with chase emails',
		icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
	},
	{
		id: 'book-rag',
		name: 'Book Q&amp;A',
		description: 'Ask questions on the Income Tax Act 1961 &amp; 2025 and get citation-first answers grounded in statute — never hallucinated.',
		chip: 'Citation-first answers, never invented',
		icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><line x1="12" y1="7" x2="16" y2="7"/><line x1="12" y1="11" x2="16" y2="11"/><line x1="12" y1="15" x2="14" y2="15"/></svg>`,
	},
	{
		id: 'knowledge-base',
		name: 'Knowledge Base',
		description: 'Maintain your firm\'s private RAG store — case history, judgements, CBDT circulars, and Taxmann commentary — per-org isolated.',
		chip: 'Your firm’s private, isolated RAG',
		icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4.03 3-9 3S3 13.66 3 12"/><path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/></svg>`,
	},
	{
		id: 'sales-bills',
		name: 'Sales Bills',
		description: 'Generate GST-compliant invoices for your firm\'s own billing, email them to clients, and post to Tally as sales vouchers.',
		chip: 'GST invoice → Tally sales voucher',
		icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
	},
	{
		id: 'tally-agent',
		name: 'Tally Agent',
		description: 'A Windows system-tray connector that bridges Accountic cloud to your local TallyPrime instance — no manual export/import.',
		chip: 'Live bridge to your TallyPrime',
		icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
	},
];

const workflowFamilies = [
	{
		label: 'Compliance & Litigation',
		desc: 'Notices, appeals, and statute research.',
		steps: [
			'Upload a notice, appeal brief, or tax query',
			'Accountic retrieves verified case law and drafts',
			'Export on firm letterhead or push to Tally',
		],
	},
	{
		label: 'Data → Tally Automation',
		desc: 'Reconciliation, classification, and posting.',
		steps: [
			'Upload a bank statement, tradebook, or invoice',
			'Accountic classifies, reconciles, and matches',
			'Vouchers post straight into TallyPrime',
		],
	},
	{
		label: 'Firm Operations',
		desc: 'Billing, receivables, and reporting.',
		steps: [
			'Sync debtors or raise a GST sales bill',
			'Accountic scores risk and checks compliance',
			'Send chase emails or post to Tally',
		],
	},
];

const platformFeatures = [
	{
		title: 'Multi-tenant org model',
		desc: 'Owner / Admin / Member roles with invite flow. Every firm\'s data is fully isolated — no cross-org retrieval is possible by construction.',
		icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
	},
	{
		title: 'Credit billing — 1 credit = ₹1',
		desc: 'Credits are debited before work begins. Automatic HTTP 402 if insufficient; full refund on system failure. Top-ups available any time.',
		icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>`,
	},
	{
		title: 'LLM observability via Langfuse',
		desc: 'Every LLM call is traced end-to-end. Admins see spend per org, per module, per document — full auditability, no black box.',
		icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
	},
	{
		title: 'OTP auth via SMS (MSG91)',
		desc: 'No password to remember or leak. SMS OTP signup keeps access tied to the practitioner\'s mobile number.',
		icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>`,
	},
	{
		title: 'Real-time collaborative editing',
		desc: 'WebSocket-powered live sync on notice drafts via PieSocket. Multiple users can review and annotate the same draft simultaneously.',
		icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
	},
	{
		title: 'Super Admin console',
		desc: 'Cross-org usage and cost dashboards, user impersonation for support, credit overrides, and full org management in one place.',
		icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>`,
	},
];

const stats = [
	{ value: '₹1,000', label: 'Free credits to try every module' },
	{ value: '14', label: 'Live workflows · 20+ in development' },
	{ value: '45 yrs', label: 'Of CA practice behind every rule' },
	{ value: '0', label: 'Hallucinated citations, by design' },
];

const painPoints = [
	{
		title: 'Every compliance task starts from scratch',
		desc: 'Notices, balance sheets, appeals, TDS audits — each one rebuilds the same work from zero, against a statutory deadline.',
		icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 14"/></svg>`,
	},
	{
		title: 'Reconciliation is still done by hand',
		desc: 'GSTR-2B, TDS, bank statements, broker tradebooks — matched line by line in spreadsheets, then re-keyed into Tally one voucher at a time.',
		icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>`,
	},
	{
		title: 'Nothing leaves an audit trail',
		desc: 'CSV cleanups and copy-paste move data into Tally, but nothing records why an entry was classified the way it was — or where a citation came from.',
		icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
	},
];

const pricingTiers = [
	{
		name: 'Free',
		price: '₹0',
		cadence: 'one-time',
		blurb: '₹1,000 credits. No card required.',
		features: ['₹1,000 free credits', 'All 14 modules', 'Manual top-up available', 'Full citation verification', 'Email support'],
		cta: 'Start free',
		href: 'https://app.accountic.in/signup',
		highlight: false,
	},
	{
		name: 'Basic',
		price: '₹2,000',
		cadence: '/ month',
		blurb: 'For solo practitioners.',
		features: ['2,000 credits / month', 'All 14 modules', 'Manual top-up available', 'Soft quota — no mid-month cutoff', 'GST invoice with your GSTIN'],
		cta: 'Start free trial',
		href: 'https://app.accountic.in/signup',
		highlight: false,
	},
	{
		name: 'Pro',
		price: '₹20,000',
		cadence: '/ month',
		blurb: 'For high-volume CAs and firms.',
		features: ['60,000 credits / month', 'All 14 modules', 'Manual top-up available', 'Priority support', 'Bulk historical upload'],
		cta: 'Start free trial',
		href: 'https://app.accountic.in/signup',
		highlight: true,
	},
	{
		name: 'Firm',
		price: 'Custom',
		cadence: '',
		blurb: 'For 5–30-professional firms.',
		features: ['Higher quotas + seat controls', 'Role-based access (roadmap)', 'Data Processing Agreement', 'Dedicated onboarding'],
		cta: 'Contact sales',
		href: '/contact',
		highlight: false,
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={metaTitle} description={metaDescription} />
	</head>
	<body>
		<Header />

		<main id="main">

			{/* ─── HERO ─── */}
			<section class="hero">
				<div class="container hero-inner">
					<a class="hero-badge" href="#modules" aria-label="See all Accountic modules">
						<span class="badge-dot" aria-hidden="true"></span>
						<span>EARLY ACCESS 2026 · FOR CAs, ACCOUNTING TEAMS &amp; FIRMS</span>
					</a>

					<h1 class="hero-title">
						The accounting work that fills your week —<br/>
						<span class="highlight-green">Accountic’s AI finishes it in minutes.</span>
					</h1>

					<p class="hero-subtitle">
						Accountic's AI runs the compliance, reconciliation, and reporting your team repeats every week — finishing in minutes what used to take hours, and cutting the cost of every workflow. All posted straight into TallyPrime.
					</p>

					<div class="hero-cta">
						<a class="btn btn-primary" href="https://app.accountic.in/signup">Start free — ₹1,000 credits</a>
						<a class="btn btn-secondary" href="#modules">See all 14 modules</a>
					</div>

					<p class="hero-cta-note">
						<span class="hero-cta-check" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg></span>
						No credit card · ₹1,000 in credits to start · cancel anytime
					</p>

					<ul class="trust-badges" aria-label="Platform compliance and trust signals">
						<li>
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
							<span>Built by CAs</span>
						</li>
						<li>
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/></svg>
							<span>India-resident data</span>
						</li>
						<li>
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
							<span>DPDP-ready</span>
						</li>
						<li>
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
							<span>SOC 2 Type II</span>
						</li>
						<li>
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
							<span>Tally-native</span>
						</li>
					</ul>

					{/* Product mockup — three documents processed in parallel */}
					<div class="hero-visual" role="img" aria-label="Accountic automation platform: three different documents — an income-tax notice, a bank statement, and a supplier invoice — are processed in parallel into a drafted reply, posted Tally vouchers, and a GST purchase voucher.">
						<div class="hv-window">
							<div class="hv-bar">
								<span class="hv-dots" aria-hidden="true"><i></i><i></i><i></i></span>
								<span class="hv-tab">Accountic · Automation Platform</span>
								<span class="hv-live"><span class="hv-live-dot" aria-hidden="true"></span>Draft ready</span>
							</div>
							<div class="hv-body hv-body--flows">
								<div class="hv-flow-row">
									<div class="hv-io hv-io--in">
										<span class="hv-io-icon" aria-hidden="true"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></span>
										<span class="hv-io-meta"><strong>Notice_143(3).pdf</strong><em>s.143(3) scrutiny · SCN</em></span>
									</div>
									<span class="hv-arrow" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
									<div class="hv-io hv-io--out">
										<span class="hv-io-meta"><strong>Drafted reply</strong><em>7 citations verified</em></span>
										<span class="hv-io-check" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg></span>
									</div>
								</div>
								<div class="hv-flow-row">
									<div class="hv-io hv-io--in">
										<span class="hv-io-icon" aria-hidden="true"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg></span>
										<span class="hv-io-meta"><strong>HDFC_statement.csv</strong><em>847 transactions</em></span>
									</div>
