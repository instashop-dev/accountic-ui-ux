const whyReasons = [
	{
		title: 'Tally-native across every module.',
		desc: 'Every workflow posts directly into TallyPrime — vouchers, ledger masters, XML imports. No middleware, no re-keying, no CSV gymnastics. What Accountic produces, Tally accepts.',
