			.foot-stat--ok { color: var(--color-accent-2); }
			.foot-stat--ok svg { color: var(--color-accent); }

			@media (max-width: 34rem) {
				.flow { grid-template-columns: 1fr; gap: var(--space-2xs); }
				.flow-arrow { transform: rotate(90deg); justify-self: start; margin-left: 0.5rem; }
			}

			/* ─────────────── STATS ─────────────── */
			.stats { border-bottom: 1px solid var(--color-rule); background: var(--color-paper); }
			.stats-grid {
				display: grid;
				grid-template-columns: repeat(4, minmax(0, 1fr));
				padding-block: var(--space-2xl);
			}
			.stat { padding-inline: var(--space-lg); border-right: 1px solid var(--color-rule); }
			.stat:first-child { padding-left: 0; }
			.stat:last-child { border-right: none; }
			.stat-value {
				display: block;
				font-family: var(--font-display);
				font-size: clamp(2rem, 4vw, 2.75rem);
				font-weight: 600;
				letter-spacing: -0.03em;
				color: var(--color-ink);
				font-variant-numeric: tabular-nums;
			}
			.stat-label { display: block; margin-top: var(--space-2xs); font-size: var(--text-sm); color: var(--color-ink-3); line-height: 1.4; }

			@media (max-width: 48rem) {
				.stats-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: var(--space-xl) 0; }
				.stat { padding-inline: var(--space-md); }
				.stat:nth-child(odd) { padding-left: 0; }
				.stat:nth-child(2) { border-right: none; }
			}

			/* ─────────────── PROBLEM ─────────────── */
			.pain-list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: var(--space-xl);
			}
			.pain { padding-top: var(--space-md); border-top: 1px solid var(--color-rule-2); }
			.pain-num { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--color-accent-2); }
			.pain h3 { margin: var(--space-sm) 0 var(--space-xs); font-size: var(--text-xl); font-weight: 600; letter-spacing: -0.02em; }
			.pain p { margin: 0; font-size: var(--text-body); line-height: 1.6; color: var(--color-ink-3); }

			.bridge {
				margin: var(--space-2xl) 0 0;
				max-width: 62ch;
				font-size: var(--text-lg);
				line-height: 1.55;
				color: var(--color-ink-2);
			}
			.bridge strong { color: var(--color-accent-2); font-weight: 600; }

			@media (max-width: 52rem) { .pain-list { grid-template-columns: 1fr; gap: var(--space-lg); } }

			/* ─────────────── HOW IT WORKS — dark band ─────────────── */
			.band { background: var(--color-graphite); padding-block: var(--space-4xl); }

			.families {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: var(--space-xl);
			}
			.family { padding-top: var(--space-md); border-top: 1px solid var(--color-rule-dark); }
			.family-idx { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--color-accent); }
			.family h3 { margin: var(--space-sm) 0 var(--space-2xs); font-size: var(--text-xl); font-weight: 600; letter-spacing: -0.02em; color: var(--color-on-dark); }
			.family-desc { margin: 0 0 var(--space-lg); font-size: var(--text-sm2); color: var(--color-on-dark-2); }

			.steps { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--space-md); }
			.steps li { display: flex; gap: var(--space-sm); align-items: flex-start; font-size: var(--text-sm2); line-height: 1.5; color: var(--color-on-dark-2); }
			.step-num {
				flex-shrink: 0;
				width: 24px; height: 24px;
				display: inline-flex; align-items: center; justify-content: center;
				border: 1px solid var(--color-rule-dark);
				border-radius: var(--radius-xs);
				font-family: var(--font-mono);
				font-size: var(--text-xs);
				color: var(--color-accent);
				font-variant-numeric: tabular-nums;
			}

			@media (max-width: 52rem) { .families { grid-template-columns: 1fr; gap: var(--space-lg); } }

			/* ─────────────── MODULES — tabular ─────────────── */
			.mod-table { list-style: none; margin: 0; padding: 0; border-top: 1px solid var(--color-rule); }
			.mod-row {
				display: grid;
				grid-template-columns: 2.25rem 2.25rem minmax(0, 1fr) auto;
				align-items: center;
				gap: var(--space-md);
				padding: var(--space-lg) var(--space-xs);
				border-bottom: 1px solid var(--color-rule);
				/* keep the reveal (opacity/transform) working alongside the hover tint */
				transition: background-color var(--dur-1) var(--ease-out), opacity var(--dur-4) var(--ease-out), transform var(--dur-4) var(--ease-out);
			}
			.mod-row:hover { background: var(--color-paper-2); }
			.mod-idx { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--color-ink-4); font-variant-numeric: tabular-nums; }
			.mod-ic {
				display: inline-flex; align-items: center; justify-content: center;
				width: 36px; height: 36px;
				border: 1px solid var(--color-rule); border-radius: var(--radius-sm);
				color: var(--color-ink-3);
			}
			.mod-row:hover .mod-ic { color: var(--color-accent); border-color: color-mix(in oklab, var(--color-accent) 30%, var(--color-rule)); }
			.mod-main { min-width: 0; display: flex; flex-direction: column; gap: 2px; }
			.mod-name { font-family: var(--font-display); font-size: var(--text-base); font-weight: 600; letter-spacing: -0.01em; color: var(--color-ink); }
			.mod-desc { font-size: var(--text-body); line-height: 1.5; color: var(--color-ink-3); }
			.mod-chip {
				justify-self: end;
				font-family: var(--font-mono);
				font-size: var(--text-xs);
				color: var(--color-accent-2);
				background: var(--color-accent-soft);
				border-radius: var(--radius-pill);
				padding: 0.3rem 0.7rem;
				white-space: nowrap;
			}
			.mod-row--soon { border-bottom: none; }
			.mod-row--soon .mod-ic { color: var(--color-ink-4); border-style: dashed; }
			.mod-row--soon .mod-name { color: var(--color-ink-2); }
			.mod-soon-link {
				justify-self: end;
				display: inline-flex; align-items: center; gap: var(--space-2xs);
				font-family: var(--font-display); font-weight: 600;
				font-size: var(--text-sm2); color: var(--color-accent-2);
				white-space: nowrap;
			}
			.mod-soon-link svg { transition: transform var(--dur-2) var(--ease-out); }
			.mod-soon-link:hover svg { transform: translateX(3px); }

			@media (max-width: 46rem) {
				.mod-row { grid-template-columns: 2rem minmax(0, 1fr); grid-template-areas: 'idx main' 'chip chip'; row-gap: var(--space-sm); }
				.mod-idx { grid-area: idx; }
				.mod-ic { display: none; }
				.mod-main { grid-area: main; }
				.mod-chip, .mod-soon-link { grid-area: chip; justify-self: start; }
			}

			/* ─────────────── WHY ─────────────── */
			.why-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0; border-top: 1px solid var(--color-rule); border-left: 1px solid var(--color-rule); }
			.why-card {
				padding: var(--space-xl);
				border-right: 1px solid var(--color-rule);
				border-bottom: 1px solid var(--color-rule);
			}
			.why-card--lead { grid-column: 1 / -1; background: var(--color-accent-soft); border-top: 2px solid var(--color-accent); }
			.why-card h3 { margin: 0 0 var(--space-sm); font-size: var(--text-xl); font-weight: 600; letter-spacing: -0.02em; }
			.why-card--lead h3 { font-size: var(--text-2xl); max-width: 20ch; }
			.why-card p { margin: 0; font-size: var(--text-sm2); line-height: 1.6; color: var(--color-ink-3); max-width: 52ch; }
			.why-card--lead p { color: var(--color-ink-2); max-width: 56ch; }
			.why-card p strong { color: var(--color-ink); font-weight: 600; }
			.why-meta { margin-top: var(--space-md) !important; font-family: var(--font-mono); font-size: var(--text-xs); color: var(--color-accent-2) !important; }

			@media (max-width: 52rem) {
				.why-grid { grid-template-columns: 1fr; }
				.why-card--lead { grid-column: auto; }
			}

			/* ─────────────── PLATFORM ─────────────── */
			.plat-grid {
				list-style: none; margin: 0; padding: 0;
				display: grid; grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: var(--space-xl) var(--space-2xl);
			}
			.plat { padding-top: var(--space-md); border-top: 1px solid var(--color-rule); }
			.plat-ic { display: inline-flex; color: var(--color-ink-3); margin-bottom: var(--space-sm); }
			.plat h3 { margin: 0 0 var(--space-xs); font-size: var(--text-lg); font-weight: 600; letter-spacing: -0.02em; }
			.plat p { margin: 0; font-size: var(--text-sm2); line-height: 1.55; color: var(--color-ink-3); }

			@media (max-width: 52rem) { .plat-grid { grid-template-columns: 1fr; gap: var(--space-lg); } }

			/* ─────────────── PRICING ─────────────── */
			.tiers { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: var(--space-md); }
			.tier {
				display: flex; flex-direction: column;
				padding: var(--space-xl);
				border: 1px solid var(--color-rule);
				border-radius: var(--radius-lg);
				background: var(--color-paper);
				position: relative;
			}
			.tier { transition: border-color var(--dur-1) var(--ease-out); }
			.tier:not(.tier--pro):hover { border-color: var(--color-rule-2); }
			.tier--pro { border-color: var(--color-accent); border-width: 1.5px; }
			.tier-tag {
				position: absolute; top: -0.7rem; left: var(--space-xl);
				font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.08em;
				background: var(--color-accent); color: var(--color-accent-ink);
				padding: 0.25rem 0.55rem; border-radius: var(--radius-xs);
			}
			.tier-name { margin: 0; font-size: var(--text-lg); font-weight: 600; }
			.tier-price { margin: var(--space-sm) 0 var(--space-2xs); display: flex; align-items: baseline; gap: var(--space-2xs); }
			.tier-amount { font-family: var(--font-display); font-size: var(--text-3xl); font-weight: 600; letter-spacing: -0.03em; color: var(--color-ink); }
			.tier-cad { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--color-ink-4); }
			.tier-blurb { margin: 0 0 var(--space-lg); font-size: var(--text-sm2); color: var(--color-ink-3); }
			.tier-feats { list-style: none; margin: 0 0 var(--space-xl); padding: 0; display: flex; flex-direction: column; gap: var(--space-sm); }
			.tier-feats li { display: flex; align-items: flex-start; gap: var(--space-xs); font-size: var(--text-sm2); color: var(--color-ink-2); line-height: 1.4; }
			.tier-feats svg { color: var(--color-accent); flex-shrink: 0; margin-top: 2px; }
			.tier-cta { margin-top: auto; width: 100%; }

			.pricing-note {
				margin: var(--space-2xl) 0 0;
				max-width: 72ch;
				font-family: var(--font-mono);
				font-size: var(--text-xs);
				line-height: 1.7;
				color: var(--color-ink-4);
			}

			@media (max-width: 64rem) { .tiers { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
			@media (max-width: 40rem) { .tiers { grid-template-columns: 1fr; } }

			/* ─────────────── FAQ ─────────────── */
			.faq-wrap { max-width: var(--wrap-narrow); }
			.faq-list { border-top: 1px solid var(--color-rule); }
			.faq-item { border-bottom: 1px solid var(--color-rule); }
			.faq-item summary {
				display: flex; align-items: center; justify-content: space-between; gap: var(--space-md);
				padding: var(--space-lg) 0;
				cursor: pointer;
				font-family: var(--font-display);
				font-size: var(--text-lg);
				font-weight: 600;
				letter-spacing: -0.01em;
				color: var(--color-ink);
				list-style: none;
			}
			.faq-item summary::-webkit-details-marker { display: none; }
			.faq-mark { position: relative; width: 14px; height: 14px; flex-shrink: 0; }
			.faq-mark::before, .faq-mark::after { content: ''; position: absolute; background: var(--color-accent); transition: transform var(--dur-2) var(--ease-out); }
			.faq-mark::before { top: 6px; left: 0; width: 14px; height: 2px; }
			.faq-mark::after { top: 0; left: 6px; width: 2px; height: 14px; }
			.faq-item[open] .faq-mark::after { transform: scaleY(0); }
			.faq-a { padding: 0 0 var(--space-lg); }
			.faq-a p { margin: 0; max-width: 66ch; font-size: var(--text-body); line-height: 1.65; color: var(--color-ink-3); }

			/* ─────────────── FINAL CTA ─────────────── */
			.cta-card {
				padding: clamp(2rem, 5vw, 3.5rem);
				border: 1px solid var(--color-rule-2);
				border-radius: var(--radius-lg);
				background: var(--color-paper-2);
			}
			.cta-card h2 { margin: var(--space-2xs) 0 var(--space-md); font-size: var(--text-3xl); font-weight: 600; letter-spacing: -0.025em; }
			.cta-body { margin: 0; max-width: 56ch; font-size: var(--text-base); line-height: 1.6; color: var(--color-ink-3); }
			.cta-form { display: flex; gap: var(--space-sm); margin-top: var(--space-lg); max-width: 460px; }
			.cta-form input {
				flex: 1; min-width: 0;
				height: 46px;
				padding-inline: 0.9rem;
				border: 1px solid var(--color-border-control);
				border-radius: var(--radius-sm);
				background: var(--color-paper);
				font-family: var(--font-sans);
				font-size: var(--text-sm2);
				color: var(--color-ink);
			}
			.cta-form input::placeholder { color: var(--color-ink-4); }
			.cta-error { margin: var(--space-sm) 0 0; font-size: var(--text-sm); color: var(--color-danger); }
			.cta-thanks-icon {
				display: inline-flex; align-items: center; justify-content: center;
				width: 44px; height: 44px; margin-bottom: var(--space-md);
				border-radius: var(--radius-md);
				background: var(--color-accent-soft); color: var(--color-accent);
			}
			.cta-thanks-meta { margin-top: var(--space-md); font-size: var(--text-sm2); color: var(--color-ink-4); }
			.cta-thanks-meta a { color: var(--color-accent-2); }
			.cta-card strong { color: var(--color-ink); font-weight: 600; }

			@media (max-width: 34rem) { .cta-form { flex-direction: column; } .cta-form .btn { width: 100%; } }

			@media (max-width: 62rem) {
				.hero-grid { grid-template-columns: 1fr; }
				.panel { max-width: 560px; }
			}

			@media (prefers-reduced-motion: reduce) {
				.rv { opacity: 1; transform: none; transition: none; }
				.btn, .btn svg, .mod-soon-link svg, .mod-row, .faq-mark::before, .faq-mark::after { transition: none; }
			}
		</style>

		<script>
			(() => {
				const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
				const supportsIO = 'IntersectionObserver' in window;

				// Reveal on scroll
				const revealEls = Array.from(document.querySelectorAll('.rv'));
				if (reduce || !supportsIO) {
					revealEls.forEach((el) => el.classList.add('is-in'));
				} else {
					const io = new IntersectionObserver((entries) => {
						entries.forEach((en) => {
							if (en.isIntersecting) { en.target.classList.add('is-in'); io.unobserve(en.target); }
						});
					}, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });
					revealEls.forEach((el) => io.observe(el));
				}

				// Counter tick on the stat strip
				const counters = Array.from(document.querySelectorAll<HTMLElement>('[data-count]'));
				const fmt = (n: number) => n.toLocaleString('en-IN');
				const runCount = (el: HTMLElement) => {
					const raw = el.dataset.count || el.textContent || '';
					const m = raw.match(/^(\D*)([\d,]+)(.*)$/);
					if (!m) return;
					const prefix = m[1];
					const target = parseInt(m[2].replace(/,/g, ''), 10);
					const suffix = m[3];
					if (reduce || !target) { el.textContent = raw; return; }
					const dur = 900;
					const start = performance.now();
					const step = (now: number) => {
						const p = Math.min(1, (now - start) / dur);
						const eased = 1 - Math.pow(1 - p, 3);
						el.textContent = prefix + fmt(Math.round(target * eased)) + suffix;
						if (p < 1) requestAnimationFrame(step);
						else el.textContent = raw;
					};
					requestAnimationFrame(step);
				};
				if (!reduce && supportsIO) {
					const cio = new IntersectionObserver((entries) => {
						entries.forEach((en) => {
							if (en.isIntersecting) { runCount(en.target as HTMLElement); cio.unobserve(en.target); }
						});
					}, { threshold: 0.6 });
					counters.forEach((c) => cio.observe(c));
				}

				// Type-in one line in the hero panel (plays once)
				if (!reduce) {
					document.querySelectorAll<HTMLElement>('.typein').forEach((el) => {
						const full = el.textContent || '';
						el.textContent = '';
						let i = 0;
						const step = () => {
							el.textContent = full.slice(0, i);
							i += 1;
							if (i <= full.length) window.setTimeout(step, 45);
						};
						window.setTimeout(step, 550);
					});
				}
			})();
		</script>

		<script is:inline>
			(function () {
				const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

				function storeCapture(email, source) {
					try {
						const key = 'accountic:captures';
						const existing = JSON.parse(localStorage.getItem(key) || '[]');
						existing.push({ email, source, at: new Date().toISOString() });
						localStorage.setItem(key, JSON.stringify(existing));
					} catch (_) { /* storage unavailable — silently skip */ }
				}

				function sendCapture(email, source) {
					const card = document.querySelector(`[data-capture][data-source="${source}"]`);
					const endpoint = card && card.dataset.endpoint;
					if (!endpoint) return Promise.resolve();
					return fetch(endpoint, {
						method: 'POST',
						headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
						body: JSON.stringify({ email, source, page: location.pathname }),
					}).catch(() => {});
				}

				document.querySelectorAll('[data-capture]').forEach((card) => {
					const form = card.querySelector('[data-capture-form]');
					if (!form) return;
					const err = card.querySelector('[data-capture-error]');
					const emailOut = card.querySelector('[data-capture-email]');
					const formState = card.querySelector('[data-state="form"]');
					const thanksState = card.querySelector('[data-state="thanks"]');

					form.addEventListener('submit', function (event) {
						event.preventDefault();
						const emailInput = form.querySelector('input[type="email"]');
						const email = (emailInput && emailInput.value || '').trim();

						if (!EMAIL_RE.test(email)) {
							if (err) err.hidden = false;
							emailInput && emailInput.focus();
							return;
						}
						if (err) err.hidden = true;

						const submitBtn = form.querySelector('button[type="submit"]');
						if (submitBtn) {
							submitBtn.disabled = true;
							submitBtn.style.opacity = '0.6';
						}

						storeCapture(email, card.dataset.source || 'unknown');
						sendCapture(email, card.dataset.source || 'unknown').finally(function () {
							if (emailOut) emailOut.textContent = email;
							if (formState) formState.hidden = true;
							if (thanksState) thanksState.hidden = false;
						});
					});
				});
			})();
		</script>
	</body>
</html>
