---
import PageLayout from '../layouts/PageLayout.astro';

const pillars = [
	{
		title: 'India-resident processing',
		body: 'Every notice, every draft, and every model invocation stays within Indian data centres. No cross-border transfer of client data, by design. Infrastructure provided by SOC 2 Type II–compliant technology partner Thalia.',
	},
	{
		title: 'No training on your data',
		body: 'Your corpus and outputs are never used to train models serving any other firm or customer. Explicit "no training" commitment — the only posture a senior CA can sign off on under ICAI confidentiality and DPDP.',
	},
	{
		title: 'Consent-per-document uploads',
		body: 'Each PDF upload is tied to a specific matter and consent scope. PII-aware pipelines identify and scope PAN, GSTIN, and related identifiers so they never leak between clients.',
	},
	{
		title: 'Data Processing Agreements on request',
		body: 'Firm customers receive a DPA suitable for handing to a listed-company client without qualification. We act as your Data Processor under DPDP; you remain the Data Fiduciary. See the DPA page for the full text.',
	},
	{
		title: 'Audit logs on every draft',
		body: 'Every citation is traceable. Every draft carries a verification audit log — the section, circular, or case cited, the repository version checked, the timestamp, and the confidence score — suitable for ICAI peer review.',
	},
	{
		title: 'Encryption in transit and at rest',
		body: 'TLS 1.2+ in transit. AES-256 at rest. Key rotation on a published cadence. No customer data ever appears in logs, error reports, or telemetry.',
	},
];
---

<PageLayout
	title="Security & trust"
	description="How Accountic secures the data that runs through a Chartered Accountant's highest-stakes work — SOC 2 Type II, India-resident processing, DPDP-ready, DPA available."
	eyebrow="Security &amp; Trust"
	heading="Security built for the signature on the reply."
	lede="Your name goes on every draft that leaves Accountic. The way we build, deploy, and secure the product reflects what's actually at stake."
>
	<svg slot="visual" class="hero-visual" viewBox="0 0 260 200" width="260" height="200" fill="none" xmlns="http://www.w3.org/2000/svg">
		<path d="M130 20 L210 48 V108 C210 142 175 168 130 180 C85 168 50 142 50 108 V48 Z" class="hv-paper hv-accent-stroke" stroke-width="2" />
		<path d="M130 20 L210 48 V108 C210 142 175 168 130 180 Z" class="hv-accent-fill" />
		<path d="M100 100 l20 20 l40 -42" class="hv-accent-stroke" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" fill="none" />
		<g opacity="0.9">
			<circle cx="42" cy="150" r="18" class="hv-paper hv-rule-stroke" stroke-width="1.5" />
			<rect x="34" y="146" width="16" height="12" rx="2" class="hv-ink-fill" />
			<path d="M37 146v-4a5 5 0 0 1 10 0v4" class="hv-ink-stroke" stroke-width="2" fill="none" />
		</g>
		<g opacity="0.9">
			<circle cx="220" cy="40" r="18" class="hv-paper hv-rule-stroke" stroke-width="1.5" />
			<path d="M213 40l4 5 10-11" class="hv-accent-stroke" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none" />
		</g>
	</svg>
	<section class="pillars" aria-labelledby="pillars-title">
		<div class="pillars-head">
			<span class="section-label">Six commitments</span>
			<h2 id="pillars-title">How we earn the signature on the reply.</h2>
		</div>
		<div class="pillar-grid">
			{pillars.map((p) => (
				<article class="pillar-card">
					<div class="pillar-icon">
						<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
							<path d="m9 12 2 2 4-4"></path>
						</svg>
					</div>
					<h3>{p.title}</h3>
					<p>{p.body}</p>
				</article>
			))}
		</div>
	</section>

	<section class="standards">
		<div class="standards-head">
			<span class="eyebrow">Standards &amp; certifications</span>
			<h2>What we're accountable to.</h2>
		</div>
		<div class="standards-grid">
			<article class="standard">
				<p class="std-name">SOC 2 Type II</p>
				<p class="std-body">Infrastructure provided by technology partner Thalia, under a continuous-audit SOC 2 Type II programme. Audit summary available to customers under NDA.</p>
			</article>
			<article class="standard">
				<p class="std-name">DPDP Act, 2023</p>
				<p class="std-body">Designed from day one to make your own DPDP compliance easier — consent framework, retention controls, deletion-on-request, notification commitments.</p>
			</article>
			<article class="standard">
				<p class="std-name">ICAI Code of Ethics (effective 1 April 2026)</p>
				<p class="std-body">Positioned as an assistant to the CA's professional judgment. Workflow records support peer review and faceless-assessment "application of mind" expectations.</p>
			</article>
			<article class="standard">
				<p class="std-name">ISO 27001 (on roadmap)</p>
				<p class="std-body">Independent ISO 27001 certification on the 12-month roadmap as we scale. Progress will be published quarterly alongside the citation-verification error rate.</p>
			</article>
		</div>
	</section>

	<section class="practices">
		<div class="practices-head">
			<span class="eyebrow">Operational practices</span>
			<h2>How we run the service.</h2>
		</div>
		<dl class="practices-list">
			<div>
				<dt>Access controls</dt>
				<dd>Least-privilege access, hardware-token 2FA for all engineers, quarterly access reviews. Role-based access controls for firm customers ship within 90 days of launch.</dd>
			</div>
			<div>
				<dt>Key management</dt>
				<dd>Encryption keys held in a managed KMS with scheduled rotation. Customer data is encrypted per-tenant; cross-tenant access is structurally impossible, not merely policy-restricted.</dd>
			</div>
			<div>
				<dt>Monitoring &amp; incident response</dt>
				<dd>24×7 monitoring on production systems. Incident protocol defined and rehearsed pre-launch, with customer notification commitments under DPDP timelines. Status page goes live at launch.</dd>
			</div>
			<div>
				<dt>Vendor management</dt>
				<dd>Every subprocessor is listed publicly, with DPAs in place and data-residency attestations on file. Changes to the subprocessor list are announced in advance.</dd>
			</div>
			<div>
				<dt>Responsible disclosure</dt>
				<dd>Report a vulnerability to <a href="mailto:security@accountic.com">security@accountic.com</a>. We aim to acknowledge within 24 hours and publish remediation within 30 days for high-severity issues.</dd>
			</div>
		</dl>
	</section>

	<section class="resources">
		<div class="resources-card">
			<div>
				<span class="eyebrow">Resources</span>
				<h2>Documents your legal team will ask for.</h2>
				<p>DPA, subprocessor list, and a one-page security brief — request access below and we'll share them via a signed link.</p>
			</div>
			<div class="resources-actions">
				<a class="btn btn-primary" href="/contact">Request documents</a>
				<a class="btn btn-secondary" href="/dpa">View DPA overview</a>
			</div>
		</div>
	</section>
</PageLayout>

<style>
	/* Hero illustration — colour routed through CSS (no inline hex) */
	.hero-visual { color: var(--color-accent); }
	.hv-paper { fill: var(--color-paper); }
	.hv-accent-stroke { stroke: var(--color-accent); }
	.hv-accent-fill { fill: var(--color-accent-soft); }
	.hv-ink-fill { fill: var(--color-ink-3); }
	.hv-ink-stroke { stroke: var(--color-ink-3); }
	.hv-rule-stroke { stroke: var(--color-rule-2); }

	.pillar-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: var(--space-lg);
		margin-bottom: var(--space-3xl);
	}

	.pillar-card {
		background: var(--color-paper);
		border: 1px solid var(--color-rule);
		border-radius: var(--radius-lg);
		padding: var(--space-xl);
		transition: border-color var(--dur-1) var(--ease-out);
	}

	.pillar-card:hover { border-color: var(--color-rule-2); }

	/* Decorative icon — neutral at rest (accent scarcity); cobalt only on card hover */
	.pillar-icon {
		width: 44px;
		height: 44px;
		border-radius: var(--radius-sm);
		border: 1px solid var(--color-rule);
		background: transparent;
		color: var(--color-ink-3);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		margin-bottom: var(--space-md);
		transition: color var(--dur-1) var(--ease-out), border-color var(--dur-1) var(--ease-out);
	}

	.pillar-card:hover .pillar-icon {
		color: var(--color-accent);
		border-color: color-mix(in oklab, var(--color-accent) 30%, var(--color-rule));
	}

	.pillar-card h3 { font-family: var(--font-display); font-size: var(--text-lg); font-weight: 600; margin: 0 0 var(--space-xs); color: var(--color-ink); }
	.pillar-card p { margin: 0; font-size: var(--text-body); line-height: 1.6; color: var(--color-ink-3); }

	.pillars-head,
	.standards-head,
	.practices-head { margin-bottom: var(--space-xl); }
	.pillars-head h2,
	.standards-head h2,
	.practices-head h2 { margin-top: var(--space-2xs); }

	.standards-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: var(--space-md);
		margin-bottom: var(--space-3xl);
	}

	.standard {
		background: var(--color-paper-2);
		border: 1px solid var(--color-rule);
		border-radius: var(--radius-lg);
		padding: var(--space-xl);
	}

	/* Standard name — mono label, not a heading (per design.md mono-label spec) */
	.std-name {
		margin: 0 0 var(--space-xs);
		font-family: var(--font-mono);
		font-size: var(--text-sm2);
		font-weight: 600;
		letter-spacing: var(--tracking-label);
		text-transform: uppercase;
		color: var(--color-ink-4);
	}

	.std-body { margin: 0; font-size: var(--text-body); color: var(--color-ink-3); line-height: 1.6; }

	.practices-list {
		display: grid;
		gap: 0;
		margin: 0 0 var(--space-3xl);
		border-top: 1px solid var(--color-rule);
	}

	.practices-list > div {
		display: grid;
		grid-template-columns: 240px 1fr;
		gap: var(--space-xl);
		padding: var(--space-lg) 0;
		border-bottom: 1px solid var(--color-rule);
	}

	.practices-list dt { font-family: var(--font-display); font-weight: 600; font-size: var(--text-base); margin: 0; color: var(--color-ink); }
	.practices-list dd { margin: 0; color: var(--color-ink-3); font-size: var(--text-body); line-height: 1.65; }
	.practices-list dd a { color: var(--color-accent-2); font-weight: 500; }

	.resources-card {
		background: var(--color-paper-2);
		border: 1px solid var(--color-rule);
		border-radius: var(--radius-lg);
		padding: clamp(var(--space-xl), 4vw, var(--space-2xl));
		display: grid;
		grid-template-columns: 1.4fr 1fr;
		gap: var(--space-xl);
		align-items: center;
	}

	.resources-card h2 { margin: var(--space-xs) 0 var(--space-sm); font-size: clamp(1.5rem, 2.2vw, 1.85rem); color: var(--color-ink); }
	.resources-card p { margin: 0; font-size: var(--text-base); color: var(--color-ink-3); }

	.resources-actions { display: flex; flex-direction: column; gap: var(--space-sm); align-items: stretch; }

	@media (max-width: 900px) {
		.pillar-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
		.standards-grid { grid-template-columns: 1fr; }
		.practices-list > div { grid-template-columns: 1fr; gap: var(--space-xs); }
		.resources-card { grid-template-columns: 1fr; }
	}

	@media (max-width: 560px) {
		.pillar-grid { grid-template-columns: 1fr; }
	}
</style>
