---
export const prerender = false;

const ADMIN_PASSWORD = 'accounticadmin';

let error = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const token = (form.get('token') ?? '').toString().trim();
  if (token === ADMIN_PASSWORD) {
    Astro.cookies.set('admin_token', token, {
      httpOnly: true,
      secure: true,
      sameSite: 'strict',
      maxAge: 60 * 60 * 8, // 8 hours
      path: '/admin',
    });
    return Astro.redirect('/admin/queue');
  }
  error = 'Invalid token.';
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Admin Login — Accountic</title>
    <meta name="robots" content="noindex,nofollow" />
    <style>
      *, *::before, *::after { box-sizing: border-box; }
      body { font-family: system-ui, sans-serif; margin: 0; background: #f9fafb; color: #111; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
      .card { background: #fff; border-radius: 10px; box-shadow: 0 1px 4px rgba(0,0,0,0.12); padding: 2rem; width: 100%; max-width: 360px; }
      h1 { font-size: 1.2rem; margin: 0 0 1.25rem; color: #1e1b4b; }
      label { font-size: 0.875rem; font-weight: 600; display: block; margin-bottom: 0.35rem; }
      input[type=password] { width: 100%; border: 1px solid #d1d5db; border-radius: 6px; padding: 0.55rem 0.75rem; font-size: 0.9rem; outline: none; }
      input[type=password]:focus { border-color: #1e1b4b; box-shadow: 0 0 0 2px #e0e7ff; }
      button { margin-top: 1rem; width: 100%; background: #1e1b4b; color: #fff; border: none; border-radius: 6px; padding: 0.65rem; font-size: 0.95rem; font-weight: 600; cursor: pointer; }
      button:hover { background: #312e81; }
      .error { background: #fee2e2; color: #991b1b; padding: 0.65rem 0.9rem; border-radius: 6px; font-size: 0.875rem; margin-bottom: 1rem; }
    </style>
  </head>
  <body>
    <div class="card">
      <h1>Accountic Admin</h1>
      {error && <div class="error">{error}</div>}
      <form method="POST">
        <label for="token">Password</label>
        <input id="token" type="password" name="token" autofocus autocomplete="current-password" />
        <button type="submit">Sign in</button>
      </form>
    </div>
  </body>
</html>
